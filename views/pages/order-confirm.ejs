<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">Almost there</p>
      <h1 class="page-title light">Confirm Your Order</h1>
    </div>
  </section>

  <section class="section">
    <div class="container confirm-layout">

      <!-- Cart summary -->
      <div class="confirm-items-col">
        <h2 class="confirm-section-title">Your items</h2>
        <div id="confirmItems"><div class="confirm-empty">Loading cart…</div></div>
      </div>

      <!-- Order details -->
      <div class="confirm-form-col">
        <div class="confirm-card">
          <h2 class="confirm-section-title">Order details</h2>

          <div class="form-group">
            <label>Your name</label>
            <input type="text" id="cfName" class="confirm-input" placeholder="e.g. Lerato" />
          </div>
          <div class="form-group">
            <label>Phone number</label>
            <input type="tel" id="cfPhone" class="confirm-input" placeholder="e.g. 082 123 4567" />
          </div>
          <div class="form-group">
            <label>Email <span style="opacity:0.4;font-weight:400;">(required for online payment)</span></label>
            <input type="email" id="cfEmail" class="confirm-input" placeholder="e.g. you@email.com" />
          </div>
          <div class="form-group">
            <label>Collection method</label>
            <div class="opt-card-row" id="colPills" style="margin-top:0.5rem;">
              <button class="opt-card opt-card-active" data-val="Walk-up at truck">
                <span class="opt-card-main">Walk-up</span>
                <span class="opt-card-sub">Pay in store</span>
              </button>
              <button class="opt-card" data-val="Pre-order (ready on arrival)">
                <span class="opt-card-main">Pre-order</span>
                <span class="opt-card-sub">Ready on arrival</span>
              </button>
            </div>
          </div>
          <div class="form-group">
            <label>Special instructions <span style="opacity:0.4;font-weight:400;">(optional)</span></label>
            <textarea class="modal-notes" id="cfNotes" placeholder="Allergies, timing, anything else…" rows="2"></textarea>
          </div>

          <div class="confirm-total-box">
            <span>Order total</span>
            <span class="confirm-total-num" id="cfTotal">R0</span>
          </div>

          <!-- Payment options -->
          <div class="payment-options">
            <p class="payment-options-label">How would you like to pay?</p>
            <div class="payment-btns">
              <button class="btn btn-primary" id="payOnlineBtn">
                <span class="pay-btn-icon">💳</span>
                <div>
                  <span class="pay-btn-main">Confirm &amp; pay online</span>
                  <span class="pay-btn-sub">Get your virtual slip</span>
                </div>
              </button>
              <button class="btn btn-outline pay-instore-btn" id="payInstoreBtn">
                <span class="pay-btn-icon">🏪</span>
                <div>
                  <span class="pay-btn-main">Pay in store</span>
                  <span class="pay-btn-sub">Cash or card at collection</span>
                </div>
              </button>
            </div>
          </div>

          <p class="confirm-disclaimer">Your order will be ready for collection at the truck.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

<script>
const cart = JSON.parse(sessionStorage.getItem('cl_cart') || '[]');
let colMethod = 'Walk-up at truck';

// Collection opt-cards
document.querySelectorAll('#colPills .opt-card').forEach(btn => {
  btn.addEventListener('click', () => {
    colMethod = btn.dataset.val;
    document.querySelectorAll('#colPills .opt-card').forEach(b => b.classList.remove('opt-card-active'));
    btn.classList.add('opt-card-active');
  });
});

function renderConfirm() {
  const el = document.getElementById('confirmItems');
  if (!cart.length) {
    el.innerHTML = '<div class="confirm-empty">Your cart is empty. <a href="/order" style="color:var(--maroon);">Add items →</a></div>';
    document.getElementById('cfTotal').textContent = 'R0';
    document.getElementById('payOnlineBtn').disabled = true;
    document.getElementById('payInstoreBtn').disabled = true;
    return;
  }
  const total = cart.reduce((s,i) => s+i.price, 0);
  document.getElementById('cfTotal').textContent = `R${total}`;
  el.innerHTML = cart.map(item => `
    <div class="cart-item">
      <div class="cart-item-img">${item.image?`<img src="${item.image}" alt="${item.name}"/>`:`<span>${item.type==='pastry'?'🥐':item.category==='cold'?'🧊':'☕'}</span>`}</div>
      <div class="cart-item-body">
        <p class="cart-item-name">${item.name}</p>
        <div class="cart-item-opts">
          ${item.size?`<span class="cart-opt-pill">${item.size} · ${item.ml}</span>`:''}
          ${item.flavour?`<span class="cart-opt-pill">${item.flavour}</span>`:''}
          ${item.milk&&item.milk!=='Full cream'?`<span class="cart-opt-pill">${item.milk}</span>`:''}
          ${item.sugar&&item.sugar!=='Regular'?`<span class="cart-opt-pill">${item.sugar}</span>`:''}
        </div>
        ${item.notes?`<p class="cart-item-note">"${item.notes}"</p>`:''}
      </div>
      <span class="cart-item-price">R${item.price}</span>
    </div>`).join('');
}

function getFormData() {
  const name  = document.getElementById('cfName').value.trim();
  const phone = document.getElementById('cfPhone').value.trim();
  const email = document.getElementById('cfEmail').value.trim();
  return { name, phone, email };
}

async function placeOrder(paymentMethod) {
  const { name, phone, email } = getFormData();
  if (!name) { alert('Please enter your name.'); return null; }
  if (!cart.length) { alert('Your cart is empty.'); return null; }

  const res = await fetch('/order/place', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name, phone, email,
      collection: colMethod,
      notes: document.getElementById('cfNotes').value.trim(),
      items: cart,
      paymentMethod: paymentMethod || 'online',
      total: cart.reduce((s,i) => s+i.price, 0)
    })
  });
  return await res.json();
}

// ── Pay in store ─────────────────────────────────────────────────
document.getElementById('payInstoreBtn').addEventListener('click', async () => {
  const btn = document.getElementById('payInstoreBtn');
  btn.disabled = true; btn.innerHTML = '<span class="pay-btn-icon">⏳</span><div><span class="pay-btn-main">Placing order…</span></div>';

  const data = await placeOrder('cash');
  if (!data || !data.ok) {
    alert(data ? (data.message || data.error) : 'Something went wrong.');
    btn.disabled = false;
    btn.innerHTML = '<span class="pay-btn-icon">🏪</span><div><span class="pay-btn-main">Pay in store</span><span class="pay-btn-sub">Cash or card at collection</span></div>';
    return;
  }
  sessionStorage.removeItem('cl_cart');
  window.location = '/order/slip/' + encodeURIComponent(data.ref);
});

// ── Pay online via Ozow ───────────────────────────────────────────
document.getElementById('payOnlineBtn').addEventListener('click', async () => {
  const { name, email } = getFormData();
  if (!name)  { alert('Please enter your name.');  return; }
  if (!cart.length) { alert('Your cart is empty.'); return; }

  const btn = document.getElementById('payOnlineBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="pay-btn-icon">⏳</span><div><span class="pay-btn-main">Processing…</span></div>';

  const data = await placeOrder('online');
  if (!data || !data.ok) {
    alert(data ? data.error : 'Something went wrong.');
    btn.disabled = false;
    btn.innerHTML = '<span class="pay-btn-icon">💳</span><div><span class="pay-btn-main">Pay now via Ozow</span><span class="pay-btn-sub">Instant EFT — secure redirect</span></div>';
    return;
  }

  sessionStorage.removeItem('cl_cart');

  // Post to Ozow initiate — will render self-submitting form
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/payment/initiate';
  [
    ['orderRef',       data.ref],
    ['total',          cart.reduce((s,i) => s+i.price, 0)],
    ['customerEmail',  email],
    ['_csrf',          ''], // add CSRF token here if you use csurf
  ].forEach(([k, v]) => {
    const input = document.createElement('input');
    input.type = 'hidden'; input.name = k; input.value = v;
    form.appendChild(input);
  });
  document.body.appendChild(form);
  form.submit();
});

renderConfirm();
</script>

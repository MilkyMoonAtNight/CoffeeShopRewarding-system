<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="auth-section">
    <div class="auth-card">
      <div class="auth-logo">
        <img src="/images/logo.png" alt="Con Leche" />
      </div>
      <h1 class="auth-title">Welcome back</h1>
      <p class="auth-sub">Sign in to access your battlepass and rewards.</p>

      <% if (success) { %>
      <div class="auth-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
      <div class="auth-error"><%= error %></div>
      <% } %>

      <form action="/login" method="POST" class="auth-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" />
        </div>
        <div class="form-group">
          <label for="password" style="display:flex;justify-content:space-between;align-items:center;">
            Password
            <a href="/forgot-password" style="font-size:0.75rem;color:var(--maroon);font-weight:400;">Forgot password?</a>
          </label>
          <input type="password" id="password" name="password" required placeholder="••••••••" />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Sign In</button>
      </form>

      <p class="auth-switch">Don't have an account? <a href="/register">Join the pack →</a></p>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

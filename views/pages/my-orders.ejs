<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">Your account</p>
      <h1 class="page-title light">My Orders</h1>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:720px;">

      <% if (!orders || !orders.length) { %>
      <div class="myorders-empty">
        <div style="font-size:3rem;margin-bottom:1rem;">🛒</div>
        <h2 style="font-family:var(--font-nimbus);font-size:1.4rem;margin-bottom:0.5rem;">No orders yet</h2>
        <p style="color:rgba(44,44,44,0.5);margin-bottom:1.5rem;">Place your first order and it will appear here.</p>
        <a href="/order" class="btn btn-primary">Order Now →</a>
      </div>
      <% } else { %>

      <% orders.forEach(order => { %>
      <%
        const STATUS_LABEL = { pending:'Order received', preparing:'Being prepared', ready:'Ready for pickup', done:'Collected' };
        const STATUS_STEP  = { pending:1, preparing:2, ready:3, done:4 };
        const step = STATUS_STEP[order.status] || 1;
        const label = STATUS_LABEL[order.status] || order.status;
        const placedDate = new Date(order.placedAt).toLocaleString('en-ZA',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});
        const isDone = order.status === 'done';
      %>
      <div class="myorder-card <%= isDone ? 'myorder-done' : '' %>">

        <!-- Header -->
        <div class="myorder-header">
          <div>
            <p class="myorder-ref"><%= order.ref %></p>
            <p class="myorder-date"><%= placedDate %></p>
          </div>
          <div class="myorder-total-col">
            <span class="myorder-total">R<%= order.total %></span>
            <span class="myorder-collection"><%= order.pickupMethod %></span>
          </div>
        </div>

        <!-- Progress tracker -->
        <div class="order-tracker">
          <div class="tracker-steps">
            <div class="tracker-step <%= step >= 1 ? 'done' : '' %>">
              <div class="tracker-dot"><span>✓</span></div>
              <span class="tracker-label">Received</span>
            </div>
            <div class="tracker-line <%= step >= 2 ? 'done' : '' %>"></div>
            <div class="tracker-step <%= step >= 2 ? 'done' : '' %> <%= step === 2 ? 'active' : '' %>">
              <div class="tracker-dot"><span><%= step >= 2 ? '✓' : '2' %></span></div>
              <span class="tracker-label">Preparing</span>
            </div>
            <div class="tracker-line <%= step >= 3 ? 'done' : '' %>"></div>
            <div class="tracker-step <%= step >= 3 ? 'done' : '' %> <%= step === 3 ? 'active' : '' %>">
              <div class="tracker-dot"><span><%= step >= 3 ? '✓' : '3' %></span></div>
              <span class="tracker-label">Ready</span>
            </div>
            <div class="tracker-line <%= step >= 4 ? 'done' : '' %>"></div>
            <div class="tracker-step <%= step >= 4 ? 'done' : '' %>">
              <div class="tracker-dot"><span><%= step >= 4 ? '✓' : '4' %></span></div>
              <span class="tracker-label">Collected</span>
            </div>
          </div>
          <div class="tracker-status-text" style="color:<%= order.status==='ready'?'var(--maroon)':order.status==='done'?'rgba(44,44,44,0.4)':'rgba(44,44,44,0.7)' %>">
            <% if (order.status === 'ready') { %>🐾 <strong>Your order is ready!</strong> Come grab it.
            <% } else if (order.status === 'preparing') { %>☕ We're making your order now…
            <% } else if (order.status === 'done') { %>✓ Collected — enjoy!
            <% } else { %>📋 Order received — we'll start soon.
            <% } %>
          </div>
        </div>

        <!-- Virtual slip / barista QR view -->
        <% if (!isDone) { %>
        <details class="slip-details">
          <summary class="slip-summary">Show order slip to barista</summary>
          <div class="virtual-slip">
            <div class="slip-header">
              <img src="/images/logo.png" alt="Con Leche" class="slip-logo" />
              <div>
                <p class="slip-ref"><%= order.ref %></p>
                <p class="slip-date"><%= placedDate %></p>
              </div>
            </div>
            <div class="slip-items">
              <% order.items.forEach(item => { %>
              <div class="slip-item">
                <div class="slip-item-main">
                  <strong><%= item.name %></strong>
                  <% if (item.size) { %><span class="slip-tag"><%= item.size %> · <%= item.ml %></span><% } %>
                  <% if (item.flavour) { %><span class="slip-tag"><%= item.flavour %></span><% } %>
                  <% if (item.milk && item.milk !== 'Full cream') { %><span class="slip-tag"><%= item.milk %></span><% } %>
                  <% if (item.sugar && item.sugar !== 'Regular') { %><span class="slip-tag"><%= item.sugar %></span><% } %>
                </div>
                <% if (item.notes) { %><p class="slip-note">"<%= item.notes %>"</p><% } %>
                <span class="slip-item-price">R<%= item.price %></span>
              </div>
              <% }) %>
            </div>
            <div class="slip-footer">
              <span>Total</span>
              <strong>R<%= order.total %></strong>
            </div>
            <div class="slip-collection">
              <span>📍 <%= order.pickupMethod %></span>
              <% if (order.notes) { %><span> · "<%= order.notes %>"</span><% } %>
            </div>
          </div>
        </details>
        <% } %>

      </div>
      <% }) %>

      <% } %>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

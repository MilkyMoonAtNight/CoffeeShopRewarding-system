<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">Your account</p>
      <h1 class="page-title light">My Orders</h1>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:720px;">

      <div id="ordersWrap">
        <%- include('../partials/orders-list', { orders }) %>
      </div>

    </div>
  </section>
</main>

<%- include('../partials/footer') %>

<script>
// ── SSE live updates ──────────────────────────────────────────────
// Renders the same status tracker live when admin changes an order
function renderOrders(orders) {
  const STATUS_LABEL = { pending:'Order received', preparing:'Being prepared', ready:'Ready for pickup', done:'Collected' };
  const STATUS_STEP  = { pending:1, preparing:2, ready:3, done:4 };

  if (!orders || !orders.length) {
    document.getElementById('ordersWrap').innerHTML = `
      <div class="myorders-empty">
        <div style="font-size:3rem;margin-bottom:1rem;">🛒</div>
        <h2 style="font-family:var(--font-nimbus);font-size:1.4rem;margin-bottom:0.5rem;">No orders yet</h2>
        <p style="color:rgba(44,44,44,0.5);margin-bottom:1.5rem;">Place your first order and it will appear here.</p>
        <a href="/order" class="btn btn-primary">Order Now →</a>
      </div>`;
    return;
  }

  document.getElementById('ordersWrap').innerHTML = orders.map(order => {
    const step   = STATUS_STEP[order.status]  || 1;
    const isDone = order.status === 'done';
    const placedDate = new Date(order.placedAt).toLocaleString('en-ZA', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});
    const stepDot = (n, label) => `
      <div class="tracker-step ${step >= n ? 'done' : ''} ${step === n ? 'active' : ''}">
        <div class="tracker-dot"><span>${step >= n ? '✓' : n}</span></div>
        <span class="tracker-label">${label}</span>
      </div>`;

    const statusText = order.status === 'ready'    ? '🐾 <strong>Your order is ready!</strong> Come grab it.'
                     : order.status === 'preparing' ? '☕ We\'re making your order now…'
                     : order.status === 'done'      ? '✓ Collected — enjoy!'
                     : '📋 Order received — we\'ll start soon.';

    const statusColor = order.status === 'ready' ? 'var(--maroon)'
                       : order.status === 'done'  ? 'rgba(44,44,44,0.4)'
                       : 'rgba(44,44,44,0.7)';

    const slipItems = (order.items || []).map(item => {
      const tags = [
        item.size  ? `<span class="slip-tag">${item.size} · ${item.ml}</span>` : '',
        item.flavour ? `<span class="slip-tag">${item.flavour}</span>` : '',
        item.milk && item.milk !== 'Full cream' ? `<span class="slip-tag">${item.milk}</span>` : '',
        item.sugar && item.sugar !== 'Regular'  ? `<span class="slip-tag">${item.sugar}</span>`  : '',
      ].join('');
      return `<div class="slip-item">
        <div class="slip-item-main"><strong>${item.name}</strong>${tags ? '<br/>'+tags : ''}</div>
        ${item.notes ? `<p class="slip-note">"${item.notes}"</p>` : ''}
        <span class="slip-item-price">R${item.price}</span>
      </div>`;
    }).join('');

    // Pulse animation if status is ready
    const readyPulse = order.status === 'ready' ? 'myorder-ready-pulse' : '';

    return `
    <div class="myorder-card ${isDone ? 'myorder-done' : ''} ${readyPulse}">
      <div class="myorder-header">
        <div>
          <p class="myorder-ref">${order.ref}</p>
          <p class="myorder-date">${placedDate}</p>
        </div>
        <div class="myorder-total-col">
          <span class="myorder-total">R${order.total}</span>
          <span class="myorder-collection">${order.pickupMethod || order.collection || ''}</span>
        </div>
      </div>

      <div class="order-tracker">
        <div class="tracker-steps">
          ${stepDot(1,'Received')}
          <div class="tracker-line ${step >= 2 ? 'done' : ''}"></div>
          ${stepDot(2,'Preparing')}
          <div class="tracker-line ${step >= 3 ? 'done' : ''}"></div>
          ${stepDot(3,'Ready')}
          <div class="tracker-line ${step >= 4 ? 'done' : ''}"></div>
          ${stepDot(4,'Collected')}
        </div>
        <div class="tracker-status-text" style="color:${statusColor};">${statusText}</div>
      </div>

      ${!isDone ? `
      <details class="slip-details">
        <summary class="slip-summary">Show order slip to barista</summary>
        <div class="virtual-slip">
          <div class="slip-header">
            <img src="/images/logo.png" alt="Con Leche" class="slip-logo" />
            <div>
              <p class="slip-ref">${order.ref}</p>
              <p class="slip-date">${placedDate}</p>
            </div>
          </div>
          <div class="slip-items">${slipItems}</div>
          <div class="slip-footer"><span>Total</span><strong>R${order.total}</strong></div>
          <div class="slip-collection">📍 ${order.pickupMethod || order.collection || ''}</div>
        </div>
      </details>` : ''}
    </div>`;
  }).join('');
}

// Connect to SSE stream
if (!!window.EventSource) {
  const source = new EventSource('/order/my-orders/stream');
  source.onmessage = (e) => {
    try {
      const data = JSON.parse(e.data);
      if (data.orders) renderOrders(data.orders);
    } catch(err) {}
  };
  source.onerror = () => {
    // Reconnects automatically — no action needed
  };
}
</script>

<style>
/* Ready pulse animation */
@keyframes readyPulse {
  0%   { box-shadow: 0 0 0 0 rgba(88,18,23,0.25); }
  70%  { box-shadow: 0 0 0 12px rgba(88,18,23,0); }
  100% { box-shadow: 0 0 0 0 rgba(88,18,23,0); }
}
.myorder-ready-pulse {
  animation: readyPulse 2s ease infinite;
  border-color: rgba(88,18,23,0.3) !important;
}
</style>

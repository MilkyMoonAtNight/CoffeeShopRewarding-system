<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <!-- Header — same dark style as drinks -->
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">Baked Fresh Daily</p>
      <h1 class="page-title light">Pastries</h1>
      <p style="color:rgba(253,246,237,0.5);font-size:1rem;margin-top:0.5rem;">Gone by noon. Worth waking up for.</p>
    </div>
  </section>

  <!-- Category tabs -->
  <div class="drinks-tabs-wrap">
    <div class="drinks-tabs" id="pastryTabs">
      <% ORDER.forEach((cat, i) => { %>
        <% if (grouped[cat] && grouped[cat].length > 0) { %>
        <button class="drinks-tab <%= i === 0 ? 'active' : '' %>"
                data-cat="<%= cat %>">
          <%= ICONS[cat] %> <%= LABELS[cat] %>
        </button>
        <% } %>
      <% }) %>
    </div>
  </div>

  <!-- Items section — bloop background same as drinks -->
  <section class="section pastries-section section-bloop">
    <div class="container">

      <% ORDER.forEach((cat, i) => { %>
        <% if (grouped[cat] && grouped[cat].length > 0) { %>
        <div class="pastry-panel <%= i === 0 ? '' : 'hidden' %>" id="pcat-<%= cat %>">
          <div class="drink-grid">
            <% grouped[cat].forEach((pastry, idx) => { %>
            <%
              const globalIdx = ORDER.slice(0, ORDER.indexOf(cat))
                .reduce((sum, c) => sum + (grouped[c] ? grouped[c].length : 0), 0) + idx;
            %>
            <div class="drink-card order-item-card"
                 data-pastry-idx="<%= globalIdx %>">
              <div class="drink-card-inner-wrap">
                <div class="drink-img-wrap">
                  <% if (pastry.image) { %>
                    <img src="<%= pastry.image %>" alt="<%= pastry.name %>" loading="lazy" />
                  <% } else { %>
                    <div class="drink-img-placeholder">
                      <span><%= ICONS[cat] %></span>
                      <span><%= pastry.name %></span>
                    </div>
                  <% } %>
                </div>
                <div class="drink-card-top">
                  <span class="drink-name"><%= pastry.name %></span>
                  <span class="drink-price-pill">R<%= pastry.price %></span>
                </div>
                <p style="font-size:0.78rem;color:rgba(44,44,44,0.55);line-height:1.4;margin-top:0.25rem;"><%= pastry.description %></p>
                <% if (pastry.isSpecial) { %><span class="drink-special-tag">✦ Special</span><% } %>
                <span class="order-add-hint">Tap to add →</span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      <% }) %>

      <% const totalPastries = ORDER.reduce((s,c) => s + (grouped[c]?grouped[c].length:0), 0); %>
      <% if (totalPastries === 0) { %>
        <p class="drinks-empty">Pastries coming soon!</p>
      <% } %>

    </div>
  </section>
</main>

<script>
// Flatten all pastries in ORDER for the modal's pastry index
const ALL_PASTRIES = <%- JSON.stringify(
  ORDER.flatMap(cat => (grouped[cat]||[]).map(p => ({
    name:        p.name,
    description: p.description || '',
    price:       p.price,
    image:       p.image || null
  })))
) %>;

window.CL_DATA = {
  loggedIn: <%= !!(locals.session && session.userId) %>,
  hot:      [],
  cold:     [],
  pastries: ALL_PASTRIES
};
</script>

<%- include('../partials/item-modal') %>

<script>
// Tab switching
document.querySelectorAll('#pastryTabs .drinks-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('#pastryTabs .drinks-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.pastry-panel').forEach(p => p.classList.add('hidden'));
    tab.classList.add('active');
    document.getElementById('pcat-' + tab.dataset.cat).classList.remove('hidden');
  });
});
</script>

<%- include('../partials/footer') %>

          </div>
        </div>
        <div class="special-card special-card-placeholder">
          <div class="special-card-image special-ph-img-2"><span class="special-ph-mark">✦</span></div>
          <div class="special-card-body">
            <h3 class="special-card-title">Special Coming Soon</h3>
            <p class="special-card-desc">Upload this one from the admin panel.</p>
          </div>
        </div>
        <div class="special-card special-card-placeholder">
          <div class="special-card-image special-ph-img-3"><span class="special-ph-mark">✦</span></div>
          <div class="special-card-body">
            <h3 class="special-card-title">Special Coming Soon</h3>
            <p class="special-card-desc">Upload this one from the admin panel.</p>

    <div class="strip-inner">
      <span>Specialty Coffee</span><span class="strip-dot">✦</span>
      <span>Fresh Pastries Daily</span><span class="strip-dot">✦</span>
      <span>Cat-Friendly Space</span><span class="strip-dot">✦</span>
      <span>Mobile Truck</span><span class="strip-dot">✦</span>
      <span>Pase de Café</span><span class="strip-dot">✦</span>
      <span>Community Driven</span><span class="strip-dot">✦</span>
      <span>Specialty Coffee</span><span class="strip-dot">✦</span>
      <span>Fresh Pastries Daily</span><span class="strip-dot">✦</span>
      <span>Cat-Friendly Space</span><span class="strip-dot">✦</span>
      <span>Mobile Truck</span><span class="strip-dot">✦</span>
      <span>Pase de Café</span><span class="strip-dot">✦</span>
      <span>Community Driven</span><span class="strip-dot">✦</span>
    </div>
  </section>

  <!-- Specials + Battlepass share one continuous background -->
  <div class="home-duo">

  <section class="section specials-home">
    <div class="container">
      <p class="section-eyebrow">Right Now at Con Leche</p>
      <h2 class="section-title">This Week's <em>Specials</em></h2>
      <% if (typeof specials !== 'undefined' && specials && specials.length > 0) { %>
      <div class="specials-grid">
        <% specials.forEach((special, i) => { %>
        <div class="special-card">
          <% if (special.image) { %>
          <div class="special-card-image" style="background-image:url('<%= special.image %>');"></div>
          <% } else { %>
          <div class="special-card-image special-ph-img-<%= (i % 3) + 1 %>"><span class="special-ph-mark">✦</span></div>
          <% } %>
          <div class="special-card-body">
            <h3 class="special-card-title"><%= special.title %></h3>
            <% if (special.description) { %><p class="special-card-desc"><%= special.description %></p><% } %>
            <% if (special.price) { %><span class="special-card-price">R<%= special.price %></span><% } %>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <!-- Placeholder blocks — replaced automatically once specials are uploaded via the admin page -->
      <div class="specials-grid">
        <div class="special-card special-card-placeholder">
          <div class="special-card-image special-ph-img-1"><span class="special-ph-mark">✦</span></div>
          <div class="special-card-body">
            <h3 class="special-card-title">Special Coming Soon</h3>
            <p class="special-card-desc">Upload this one from the admin panel.</p>
          </div>
        </div>
        <div class="special-card special-card-placeholder">
          <div class="special-card-image special-ph-img-2"><span class="special-ph-mark">✦</span></div>
          <div class="special-card-body">
            <h3 class="special-card-title">Special Coming Soon</h3>
            <p class="special-card-desc">Upload this one from the admin panel.</p>
          </div>
        </div>
        <div class="special-card special-card-placeholder">
          <div class="special-card-image special-ph-img-3"><span class="special-ph-mark">✦</span></div>
          <div class="special-card-body">
            <h3 class="special-card-title">Special Coming Soon</h3>
            <p class="special-card-desc">Upload this one from the admin panel.</p>
          </div>
        </div>
      </div>
      <% } %>

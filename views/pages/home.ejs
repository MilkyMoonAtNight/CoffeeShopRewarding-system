  <!-- Google Reviews — coloured placeholder blocks for now -->
  <section class="section reviews-home" id="reviewsHome">
    <!-- Background animation: silver pitcher pours a silky stream, milk rises -->
    <div class="milk-stage" aria-hidden="true">
      <div class="milk-fill"></div>
      <div class="milk-stream"></div>
      <svg class="milk-pitcher" viewBox="0 0 130 100" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="silver" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%"  stop-color="#e8e8ea"/>
            <stop offset="35%" stop-color="#b9bcc2"/>
            <stop offset="60%" stop-color="#d8dadf"/>
            <stop offset="100%" stop-color="#94989f"/>
          </linearGradient>
          <linearGradient id="silverDark" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#c4c7cc"/>
            <stop offset="100%" stop-color="#7e828a"/>
          </linearGradient>
        </defs>
        <!-- body -->
        <path d="M30 22 L96 22 L88 78 Q87 86 78 86 L46 86 Q37 86 36 78 Z" fill="url(#silver)" stroke="#84878e" stroke-width="1.5"/>
        <!-- spout -->
        <path d="M22 14 L34 22 L30 34 Z" fill="url(#silverDark)" stroke="#84878e" stroke-width="1.2"/>
        <!-- handle -->
        <path d="M96 30 Q116 34 112 52 Q109 66 90 66" fill="none" stroke="url(#silverDark)" stroke-width="7" stroke-linecap="round"/>
        <!-- rim -->
        <path d="M30 22 L96 22" stroke="#f2f3f5" stroke-width="3" stroke-linecap="round"/>
        <!-- light reflection -->
        <path d="M44 30 Q42 52 47 74" stroke="rgba(255,255,255,0.85)" stroke-width="5" stroke-linecap="round" fill="none"/>
        <path d="M56 28 Q55 44 57 60" stroke="rgba(255,255,255,0.4)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div class="container">
      <p class="section-eyebrow">Don't Take Our Word For It</p>
      <h2 class="section-title">What Our <em>Regulars</em> Say</h2>
      <div class="reviews-rating-line">
        <span class="reviews-stars">★★★★★</span>
        <% if (typeof googleRating !== 'undefined' && googleRating) { %>
        <span class="reviews-source"><%= googleRating %> on Google · <%= googleReviewCount %> reviews</span>
        <% } else { %>
        <span class="reviews-source">Reviews from Google</span>
        <% } %>
      </div>

      <% if (typeof reviews !== 'undefined' && reviews && reviews.length > 0) { %>
      <!-- Live 5★ Google reviews, dressed in Con Leche colours -->
      <div class="reviews-grid">
        <% reviews.slice(0, 6).forEach((review, i) => { %>
        <div class="review-card review-live review-theme-<%= (i % 3) + 1 %>">
          <span class="review-live-stars">★★★★★</span>
          <p class="review-live-text">"<%= review.text.length > 220 ? review.text.slice(0, 220).trim() + '…' : review.text %>"</p>
          <div class="review-live-author">
            <% if (review.photo) { %>
            <img src="<%= review.photo %>" alt="" class="review-live-avatar" referrerpolicy="no-referrer" />
            <% } else { %>
            <span class="review-live-avatar review-live-avatar-fallback">🐾</span>
            <% } %>
            <div>
              <span class="review-live-name"><%= review.author %></span>
              <span class="review-live-when"><%= review.when %> · Google</span>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <!-- Placeholder review blocks — shown until GOOGLE_PLACES_API_KEY + GOOGLE_PLACE_ID are set in .env -->
      <div class="reviews-grid">
        <div class="review-card review-ph-1">
          <span class="review-ph-stars">★★★★★</span>
          <div class="review-ph-line review-ph-line-90"></div>
          <div class="review-ph-line review-ph-line-100"></div>
          <div class="review-ph-line review-ph-line-70"></div>
          <div class="review-ph-author">
            <span class="review-ph-avatar"></span>
            <span class="review-ph-name"></span>
          </div>
        </div>
        <div class="review-card review-ph-2">
          <span class="review-ph-stars">★★★★★</span>
          <div class="review-ph-line review-ph-line-100"></div>
          <div class="review-ph-line review-ph-line-80"></div>
          <div class="review-ph-line review-ph-line-90"></div>
          <div class="review-ph-author">
            <span class="review-ph-avatar"></span>
            <span class="review-ph-name"></span>
          </div>
        </div>
        <div class="review-card review-ph-3">
          <span class="review-ph-stars">★★★★★</span>
          <div class="review-ph-line review-ph-line-80"></div>
          <div class="review-ph-line review-ph-line-100"></div>
          <div class="review-ph-line review-ph-line-60"></div>
          <div class="review-ph-author">
            <span class="review-ph-avatar"></span>
            <span class="review-ph-name"></span>
          </div>
        </div>
      </div>
      <% } %>

      <div class="reviews-cta">
        <p class="reviews-cta-text">Had a great visit? Tell the world — it takes 30 seconds.</p>
        <a href="https://g.page/r/CcRPEqlBsgJXEBM/review" target="_blank" rel="noopener" class="btn btn-primary">
          ★ Leave Us a Google Review
        </a>
      </div>
    </div>
  </section>

  <!-- Upcoming events — always shown -->
  <section class="section events-home">
    <div class="container">
      <p class="section-eyebrow">What's On</p>
      <h2 class="section-title">Coming Up</h2>
      <% if (upcomingEvents && upcomingEvents.length > 0) { %>
      <div class="events-row">
        <% upcomingEvents.forEach(event => { %>
        <div class="event-card-small">
          <div class="event-type-badge event-<%= event.type %>">
            <%= event.type === 'truck_location' ? '🚐 Truck' : event.type === 'run_club' ? '🏃 Run Club' : event.type === 'painting' ? '🎨 Painting' : event.type === 'pop_up' ? '⭐ Pop-Up' : event.type === 'special' ? '🎉 Special' : '⭐ ' + (event.type || 'Event').replace(/_/g, ' ') %>
          </div>
          <h3 class="event-card-title"><%= event.title %></h3>
          <p class="event-card-date"><%= event.date.toLocaleDateString('en-ZA', { weekday: 'short', day: 'numeric', month: 'long' }) %></p>
          <p class="event-card-location"><%= event.location %></p>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="events-empty-home">
        <p>No events posted yet — follow <strong>@conleche_coffee</strong> on Instagram for real-time truck locations and updates.</p>
      </div>
      <% } %>
      <a href="/events" class="btn btn-outline">See All Events</a>
    </div>
  </section>
</main>

<!-- ── Floating coffee beans (subtle, parallax on scroll) ── -->
<div class="bean-field" id="beanField" aria-hidden="true"></div>

<script>
// ── Coffee bean drift ─────────────────────────────────────────────
(function () {
  const field = document.getElementById('beanField');
  if (!field) return;

  const beans = [];
  const BEAN_COUNT = 24;
  const GROGU_SLOT = Math.floor(8 + Math.random() * 8); // one little green guy, mediumly hidden 👀
  const total = BEAN_COUNT + 1;

  for (let i = 0; i < total; i++) {
    const el = document.createElement('span');
    el.className = 'bean';
    const isGrogu = i === GROGU_SLOT;
    const size = 16 + Math.random() * 16;

    if (isGrogu) {
      el.innerHTML = `<img src="/images/baby-yoda.png" alt="" class="bean-grogu-img" />`;
      el.classList.add('bean-grogu');
      el.style.opacity = 0.35;   // visible if you look, easy to scroll past
      el.addEventListener('click', () => { window.location = '/the-bean-awakens'; });
    } else {
      // Same bean, different roast — brightness/hue filters give each its own brown
      const bright = (0.55 + Math.random() * 0.7).toFixed(2);   // dark to light roast
      const hue    = Math.floor(Math.random() * 26) - 8;        // subtle shade shifts
      const sat    = (0.7 + Math.random() * 0.6).toFixed(2);
      el.innerHTML = `<img src="/images/coffee-bean.png" alt="" class="bean-img"
        style="filter: brightness(${bright}) saturate(${sat}) hue-rotate(${hue}deg);" />`;
      // Some fainter, some stronger — never loud
      el.style.opacity = (0.06 + Math.random() * 0.16).toFixed(2);
    }

    el.style.width  = size + 'px';
    el.style.height = size + 'px';
    el.style.left   = (2 + Math.random() * 94) + '%';
    el.style.top    = (4 + (i / total) * 240 + Math.random() * 20) + 'vh';
    const rot = Math.floor(Math.random() * 360);   // every bean its own angle
    el.dataset.speed = (0.04 + Math.random() * 0.12).toFixed(3);
    el.dataset.rot   = rot;
    el.dataset.spin  = (Math.random() * 0.04 - 0.02).toFixed(4);
    el.style.transform = `rotate(${rot}deg)`;
    field.appendChild(el);
    beans.push(el);
  }

  let ticking = false;
  function update() {
    const y = window.scrollY;
    beans.forEach(b => {
      const drift = -(y * parseFloat(b.dataset.speed));
      const rot = parseFloat(b.dataset.rot) + y * parseFloat(b.dataset.spin);
      b.style.transform = `translateY(${drift}px) rotate(${rot}deg)`;
    });
    ticking = false;
  }
  window.addEventListener('scroll', () => {
    if (!ticking) { requestAnimationFrame(update); ticking = true; }
  }, { passive: true });
  update();
})();

// ── Milk pour — starts once when the reviews section scrolls into view ──
(function () {
  const section = document.getElementById('reviewsHome');
  if (!section || !('IntersectionObserver' in window)) {
    if (section) section.classList.add('pouring');
    return;
  }
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        section.classList.add('pouring');
        obs.disconnect();
      }
    });
  }, { threshold: 0.25 });
  obs.observe(section);
})();

// ── Review card tilt — presses down toward the pointer ────────────
document.querySelectorAll('.review-card').forEach(card => {
  const MAX = 7; // degrees
  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const dx = (e.clientX - rect.left - rect.width / 2)  / (rect.width / 2);   // -1 .. 1
    const dy = (e.clientY - rect.top  - rect.height / 2) / (rect.height / 2);
    // The side under the cursor dips away; the opposite side lifts toward you
    card.style.transform = `perspective(700px) rotateY(${(dx * MAX).toFixed(2)}deg) rotateX(${(-dy * MAX).toFixed(2)}deg) scale(0.99)`;
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = 'perspective(700px) rotateY(0deg) rotateX(0deg) scale(1)';
  });
});
</script>


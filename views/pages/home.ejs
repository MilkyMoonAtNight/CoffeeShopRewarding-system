  <!-- Upcoming events — always shown -->
  <section class="section events-home">
    <div class="container">
      <p class="section-eyebrow">What's On</p>
      <h2 class="section-title">Coming Up</h2>
      <% if (upcomingEvents && upcomingEvents.length > 0) { %>

      <%
        // Build unique category list for the filter bar
        const eventCategories = [...new Set(upcomingEvents.map(e => e.type).filter(Boolean))];
        function eventLabel(type) {
          return type === 'truck_location' ? '🚐 Truck'
               : type === 'run_club'       ? '🏃 Run Club'
               : type === 'painting'       ? '🎨 Painting'
               : type === 'pop_up'         ? '⭐ Pop-Up'
               : type === 'special'        ? '🎉 Special'
               : '⭐ ' + type.replace(/_/g, ' ');
        }
      %>

      <!-- Category filter pills -->
      <div class="events-filter-bar">
        <button class="events-filter-pill active" data-filter="all">All</button>
        <% eventCategories.forEach(cat => { %>
        <button class="events-filter-pill" data-filter="<%= cat %>"><%= eventLabel(cat) %></button>
        <% }) %>
      </div>

      <div class="events-grid" id="eventsRow">
        <% upcomingEvents.forEach(function(event) {
          const imgSrc = event.image ? (event.image.startsWith('/') ? event.image : '/images/events/' + event.image) : null;
          const typeLabel = eventLabel(event.type);
          const typeEmoji = event.type === 'truck_location' ? '🚐' : event.type === 'run_club' ? '🏃' : event.type === 'painting' ? '🎨' : '⭐';
          const recLabel = event.recurringType === 'daily' ? 'Daily' : event.recurringType === 'weekly' ? 'Weekly' : (event.recurring ? 'Weekly' : null);
        %>
        <div class="event-tile event-tile-<%= event.type %>" data-category="<%= event.type %>"
             onclick="openEventModal(this)"
             data-title="<%= encodeURIComponent(event.title) %>"
             data-desc="<%= encodeURIComponent(event.description || '') %>"
             data-img="<%= imgSrc || '' %>"
             data-date="<%= event.date.toISOString() %>"
             data-date-label="<%= event.date.toLocaleDateString('en-ZA', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) %>"
             data-time="<%= event.date.toLocaleTimeString('en-ZA', { hour:'2-digit', minute:'2-digit' }) %><%= event.endDate ? ' – ' + event.endDate.toLocaleTimeString('en-ZA', { hour:'2-digit', minute:'2-digit' }) : '' %>"
             data-location="<%= encodeURIComponent(event.location || '') %>"
             data-type="<%= typeLabel %>"
             data-rec="<%= recLabel || '' %>"
             data-phone="<%= event.contactPhone || '' %>"
             data-cname="<%= encodeURIComponent(event.contactName || '') %>"
             data-socials="<%= encodeURIComponent(event.socials || '') %>">

          <div class="event-tile-img-wrap">
            <% if (imgSrc) { %>
              <img src="<%= imgSrc %>" alt="<%= event.title %>" class="event-tile-img" loading="lazy" />
            <% } else { %>
              <div class="event-tile-placeholder"><span><%= typeEmoji %></span></div>
            <% } %>
            <div class="event-tile-overlay"></div>
            <div class="event-tile-date">
              <span class="event-tile-day"><%= event.date.toLocaleDateString('en-ZA', { day: 'numeric' }) %></span>
              <span class="event-tile-month"><%= event.date.toLocaleDateString('en-ZA', { month: 'short' }) %></span>
            </div>
          </div>

          <div class="event-tile-body">
            <div class="event-tags">
              <span class="event-tag event-tag-<%= event.type %>"><%= typeLabel %></span>
              <% if (recLabel) { %><span class="event-tag event-tag-recurring"><%= recLabel === 'Daily' ? '🔁 Daily' : '📅 Weekly' %></span><% } %>
            </div>
            <h3 class="event-tile-title"><%= event.title %></h3>
            <% if (event.location) { %><p class="event-tile-location">📍 <%= event.location %></p><% } %>
            <p class="event-tile-time">
              <%= event.date.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) %>
              <%= event.endDate ? '– ' + event.endDate.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) : '' %>
            </p>
            <% if (event.description) { %>
            <p class="event-tile-desc"><%= event.description %></p>
            <% } %>
          </div>

        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="events-empty-home">
        <p>No events posted yet — follow <strong>@conleche_coffee</strong> on Instagram for real-time truck locations and updates.</p>
      </div>
      <% } %>
      <a href="/events" class="btn btn-primary events-see-all">See All Events</a>
    </div>
  </section>

  <!-- ── Grogu easter egg (rare — 1 in 30 chance per visit) ── -->
  <div class="bean-field" id="beanField" aria-hidden="true"></div>
</main>

<script>
// ── Grogu easter egg ──────────────────────────────────────────────
// 1 in 30 chance per page load. Once clicked he's gone for this session.
// Returning from /the-bean-awakens also clears him.
(function () {
  const CLICKED_KEY = 'grogu_clicked';

  // If he was clicked this session, stay gone
  if (sessionStorage.getItem(CLICKED_KEY)) return;

  // Roll the dice — 1 in 30
  if (Math.floor(Math.random() * 30) !== 0) return;

  const field = document.getElementById('beanField');
  if (!field) return;

  const el = document.createElement('span');
  el.className = 'bean bean-grogu';
  el.innerHTML = `<img src="/images/baby-yoda.png" alt="" class="bean-grogu-img" />`;
  el.style.width   = '28px';
  el.style.height  = '28px';
  el.style.opacity = '0.4';
  el.style.setProperty('--fx',  (Math.random() * 10 - 5).toFixed(1) + 'px');
  el.style.setProperty('--fy',  (Math.random() * 10 - 5).toFixed(1) + 'px');
  el.style.setProperty('--fr',  (Math.random() * 8 - 4).toFixed(1) + 'deg');
  el.style.setProperty('--fd',  (10 + Math.random() * 5).toFixed(1) + 's');
  el.style.setProperty('--fdel', '0s');
  el.style.left = (5 + Math.random() * 88) + '%';
  el.style.top  = (10 + Math.random() * 80) + '%';
  el.style.transform = `rotate(${Math.floor(Math.random() * 360)}deg)`;

  el.addEventListener('click', () => {
    sessionStorage.setItem(CLICKED_KEY, '1');
    window.location = '/the-bean-awakens';
  });

  field.appendChild(el);

  // Appear only once the hero strip has scrolled past (same trigger as before)
  const strip = document.querySelector('.strip-section');
  function revealCheck() {
    const triggerY = strip ? (strip.offsetTop + strip.offsetHeight) : 400;
    if (window.scrollY + window.innerHeight * 0.4 > triggerY) {
      field.classList.add('beans-visible');
    } else {
      field.classList.remove('beans-visible');
    }
  }
  revealCheck();
  window.addEventListener('scroll', revealCheck, { passive: true });
  window.addEventListener('resize', revealCheck);
})();

// ── Events category filter ────────────────────────────────────────
document.querySelectorAll('.events-filter-pill').forEach(pill => {
  pill.addEventListener('click', () => {
    document.querySelectorAll('.events-filter-pill').forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    const filter = pill.dataset.filter;
    document.querySelectorAll('#eventsRow .event-tile').forEach(card => {
      card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
    });
  });
});

// ── Review card tilt — presses down toward the pointer ────────────
document.querySelectorAll('.review-card').forEach(card => {
  const MAX = 7; // degrees
  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const dx = (e.clientX - rect.left - rect.width / 2)  / (rect.width / 2);   // -1 .. 1
    const dy = (e.clientY - rect.top  - rect.height / 2) / (rect.height / 2);
    // The side under the cursor dips away; the opposite side lifts toward you
    card.style.transform = `perspective(700px) rotateY(${(dx * MAX).toFixed(2)}deg) rotateX(${(-dy * MAX).toFixed(2)}deg) scale(0.99)`;
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = 'perspective(700px) rotateY(0deg) rotateX(0deg) scale(1)';
  });
});

// ── Reviews carousel — smooth horizontal loop with dot indicator ──
(function () {
  const track = document.getElementById('reviewsTrack');
  const dotsWrap = document.getElementById('reviewsDots');
  if (!track || !dotsWrap) return;
  const cards = Array.from(track.children);
  if (!cards.length) return;

  let perView = 1, pages = 1, current = 0, timer = null, paused = false;

  function measure() {
    const styles = getComputedStyle(track);
    const gap = parseFloat(styles.columnGap || styles.gap) || 0;
    const cardW = cards[0].getBoundingClientRect().width + gap;
    perView = Math.max(1, Math.round(track.clientWidth / cardW));
    pages = Math.ceil(cards.length / perView);
  }

  function pageTarget(i) {
    const idx = Math.min(i * perView, cards.length - 1);
    return cards[idx].offsetLeft - track.offsetLeft;
  }

  function buildDots() {
    measure();
    if (current > pages - 1) current = pages - 1;
    dotsWrap.innerHTML = '';
    for (let i = 0; i < pages; i++) {
      const dot = document.createElement('button');
      dot.className = 'reviews-dot' + (i === current ? ' active' : '');
      dot.setAttribute('aria-label', 'Review group ' + (i + 1));
      dot.addEventListener('click', () => { goTo(i); restart(); });
      dotsWrap.appendChild(dot);
    }
    dotsWrap.style.display = pages > 1 ? 'flex' : 'none';
  }

  function setActive(i) {
    current = Math.max(0, Math.min(i, pages - 1));
    dotsWrap.querySelectorAll('.reviews-dot').forEach((d, idx) => d.classList.toggle('active', idx === current));
  }

  function goTo(i) {
    if (i >= pages) i = 0;
    if (i < 0) i = pages - 1;
    track.scrollTo({ left: pageTarget(i), behavior: 'smooth' });
    setActive(i);
  }

  function next()    { goTo(current + 1); }
  function start()   { if (!timer) timer = setInterval(() => { if (!paused) next(); }, 4500); }
  function restart() { clearInterval(timer); timer = null; start(); }

  // Keep the active dot in sync when the user scrolls/swipes manually
  let scrollDebounce;
  track.addEventListener('scroll', () => {
    clearTimeout(scrollDebounce);
    scrollDebounce = setTimeout(() => {
      let nearest = 0, best = Infinity;
      for (let i = 0; i < pages; i++) {
        const diff = Math.abs(track.scrollLeft - pageTarget(i));
        if (diff < best) { best = diff; nearest = i; }
      }
      setActive(nearest);
    }, 120);
  }, { passive: true });

  // Pause while the visitor is interacting
  ['mouseenter', 'touchstart'].forEach(ev => track.addEventListener(ev, () => paused = true, { passive: true }));
  ['mouseleave', 'touchend'].forEach(ev => track.addEventListener(ev, () => paused = false, { passive: true }));

  let resizeT;
  window.addEventListener('resize', () => { clearTimeout(resizeT); resizeT = setTimeout(buildDots, 200); });

  buildDots();
  start();
})();
</script>


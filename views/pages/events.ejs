<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">Where We'll Be</p>
      <h1 class="page-title light">Events & Calendar</h1>
    </div>
  </section>

  <div class="events-tabs-wrap">
    <div class="events-tabs">
      <button class="events-tab active" data-filter="all">All</button>
      <button class="events-tab" data-filter="truck_location"><span class="legend-dot event-truck_location"></span>Trailer Location</button>
      <button class="events-tab" data-filter="run_club"><span class="legend-dot event-run_club"></span>Run Club</button>
      <button class="events-tab" data-filter="painting"><span class="legend-dot event-painting"></span>Fun Classes</button>
      <button class="events-tab" data-filter="special"><span class="legend-dot event-special"></span>Special Event</button>
    </div>
  </div>

  <section class="section events-section section-bloop">
    <div class="container">

      <% if (events.length === 0) { %>
      <div class="events-empty">
        <p>No upcoming events yet — follow <strong>@conleche_coffee</strong> on Instagram for real-time updates.</p>
      </div>
      <% } else { %>
      <div class="events-grid">
        <% events.forEach(function(event) {
          const imgSrc = event.image ? (event.image.startsWith('/') ? event.image : '/images/events/' + event.image) : null;
          const typeLabel = event.type === 'truck_location' ? '🚐 Truck' : event.type === 'run_club' ? '🏃 Run Club' : event.type === 'painting' ? '🎨 Painting' : event.type === 'pop_up' ? '⭐ Pop-Up' : event.type === 'special' ? '🎉 Special' : '⭐ ' + (event.type || 'Event').replace(/_/g, ' ');
          const typeEmoji = event.type === 'truck_location' ? '🚐' : event.type === 'run_club' ? '🏃' : event.type === 'painting' ? '🎨' : '⭐';
          const recLabel = event.recurringType === 'daily' ? 'Daily' : event.recurringType === 'weekly' ? 'Weekly' : (event.recurring ? 'Weekly' : null);
        %>
        <div class="event-tile event-tile-<%= event.type %>"
             onclick="openEventModal(this)"
             data-title="<%= encodeURIComponent(event.title) %>"
             data-desc="<%= encodeURIComponent(event.description || '') %>"
             data-img="<%= imgSrc || '' %>"
             data-date="<%= event.date.toISOString() %>"
             data-date-label="<%= event.date.toLocaleDateString('en-ZA', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) %>"
             data-time="<%= event.date.toLocaleTimeString('en-ZA', { hour:'2-digit', minute:'2-digit' }) %><%= event.endDate ? ' – ' + event.endDate.toLocaleTimeString('en-ZA', { hour:'2-digit', minute:'2-digit' }) : '' %>"
             data-location="<%= encodeURIComponent(event.location || '') %>"
             data-type="<%= typeLabel %>"
             data-rec="<%= recLabel || '' %>"
             data-phone="<%= event.contactPhone || '' %>"
             data-cname="<%= encodeURIComponent(event.contactName || '') %>"
             data-socials="<%= encodeURIComponent(event.socials || '') %>">

          <div class="event-tile-img-wrap">
            <% if (imgSrc) { %>
              <img src="<%= imgSrc %>" alt="<%= event.title %>" class="event-tile-img" loading="lazy" />
            <% } else { %>
              <div class="event-tile-placeholder"><span><%= typeEmoji %></span></div>
            <% } %>
            <div class="event-tile-overlay"></div>
            <div class="event-tile-date">
              <span class="event-tile-day"><%= event.date.toLocaleDateString('en-ZA', { day: 'numeric' }) %></span>
              <span class="event-tile-month"><%= event.date.toLocaleDateString('en-ZA', { month: 'short' }) %></span>
            </div>
          </div>

          <div class="event-tile-body">
            <div class="event-tags">
              <span class="event-tag event-tag-<%= event.type %>"><%= typeLabel %></span>
              <% if (recLabel) { %><span class="event-tag event-tag-recurring"><%= recLabel === 'Daily' ? '🔁 Daily' : '📅 Weekly' %></span><% } %>
            </div>
            <h3 class="event-tile-title"><%= event.title %></h3>
            <p class="event-tile-location">📍 <%= event.location %></p>
            <p class="event-tile-time">
              <%= event.date.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) %>
              <%= event.endDate ? '– ' + event.endDate.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) : '' %>
            </p>
            <% if (event.description) { %>
            <p class="event-tile-desc"><%= event.description %></p>
            <% } %>
          </div>

        </div>
        <% }); %>
      </div>
      <% } %>

      <div class="events-cta-row">
        <p>Never miss a stop — follow <strong>@conleche_coffee</strong> on Instagram for real-time updates.</p>
        <a href="https://instagram.com/conleche_coffee" target="_blank" class="btn btn-primary">Follow us →</a>
      </div>

    </div>
  </section>
</main>

<%- include('../partials/event-modal') %>

<%- include('../partials/footer') %>

<script>
<%- include('../partials/event-modal-js') %>

(function () {
  const tabs  = document.querySelectorAll('.events-tab');
  const tiles = document.querySelectorAll('.event-tile');

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      tabs.forEach(function (t) { t.classList.remove('active'); });
      tab.classList.add('active');
      const filter = tab.dataset.filter;
      tiles.forEach(function (tile) {
        tile.style.display = (filter === 'all' || tile.classList.contains('event-tile-' + filter)) ? '' : 'none';
      });
    });
  });
}());
</script>

<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">Where We'll Be</p>
      <h1 class="page-title light">Events & Calendar</h1>
    </div>
  </section>

  <section class="section events-section">
    <div class="container">
      <div class="events-legend">
        <span class="legend-item"><span class="legend-dot event-truck_location"></span>Trailer Location</span>
        <span class="legend-item"><span class="legend-dot event-run_club"></span>Run Club</span>
        <span class="legend-item"><span class="legend-dot event-painting"></span>Fun Classes</span>
        <span class="legend-item"><span class="legend-dot event-special"></span>Special Event</span>
      </div>

      <% if (events.length === 0) { %>
      <div class="events-empty">
        <p>No upcoming events yet. Check back soon — we're always planning something.</p>
      </div>
      <% } else { %>
      <div class="events-list">
        <% events.forEach(event => { %>
        <div class="event-card event-card-<%= event.type %>">
          <div class="event-date-block">
            <span class="event-day"><%= event.date.toLocaleDateString('en-ZA', { day: 'numeric' }) %></span>
            <span class="event-month"><%= event.date.toLocaleDateString('en-ZA', { month: 'short' }) %></span>
            <span class="event-year"><%= event.date.getFullYear() %></span>
          </div>
          <div class="event-body">
            <div class="event-tags">
              <span class="event-tag event-tag-<%= event.type %>">
                <%= event.type === 'truck_location' ? '🚐 Truck' : event.type === 'run_club' ? '🏃 Run Club' : event.type === 'painting' ? '🎨 Painting' : '⭐ Event' %>
              </span>
              <% if (event.recurring) { %><span class="event-tag event-tag-recurring">Weekly</span><% } %>
            </div>
            <h3 class="event-title"><%= event.title %></h3>
            <p class="event-location">📍 <%= event.location %></p>
            <% if (event.description) { %>
            <p class="event-description"><%= event.description %></p>
            <% } %>
            <p class="event-time">
              <%= event.date.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) %>
              <%= event.endDate ? '– ' + event.endDate.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) : '' %>
            </p>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </section>

  <section class="section-cta">
    <div class="container text-center">
      <h3>Never miss a stop.</h3>
      <p>Follow us on Instagram <strong>@conleche.coffee</strong> for real-time truck locations and last-minute events.</p>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="auth-section">
    <div class="auth-card">
      <div class="auth-logo">
        <img src="/images/logo_nav.png" alt="Con Leche" />
      </div>
      <h1 class="auth-title">Join Con Leche</h1>
      <p class="auth-sub">Create your account and get your unique QR battlepass code.</p>

      <% if (error) { %>
      <div class="auth-error"><%= error %></div>
      <% } %>

      <form action="/register" method="POST" class="auth-form">
        <div class="form-group">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" required placeholder="e.g. Iwan Rademan"
                 pattern="[A-Za-z\s]+" title="Letters only — no numbers or special characters" autocomplete="name" />
          <span class="form-hint">First and last name preferred. Letters only.</span>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" />
        </div>
        <div class="form-group">
          <label>Birthday <span style="opacity:0.45;font-weight:400;">(optional — any fields)</span></label>
          <div class="birthday-fields">
            <input type="number" name="birthdayYear"  placeholder="Year"  min="1920" max="2009" style="flex:2;" />
            <input type="number" name="birthdayMonth" placeholder="Month" min="1"    max="12"   style="flex:1;" />
            <input type="number" name="birthdayDay"   placeholder="Day"   min="1"    max="31"   style="flex:1;" />
          </div>
          <span class="form-hint">Adding your birthday month &amp; day means we'll send you a birthday treat voucher.</span>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="8+ characters" minlength="8" />
        </div>
        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••" />
        </div>
        <!-- Notification opt-ins -->
        <div class="form-group notify-optin-group">
          <p class="notify-optin-label">Email notifications <span class="notify-optin-sub">(you can change these any time in your profile)</span></p>
          <label class="notify-check">
            <input type="checkbox" name="notifySpecials" value="on" checked />
            <span>Weekly specials, new drinks &amp; arrivals</span>
          </label>
          <label class="notify-check">
            <input type="checkbox" name="notifyEvents" value="on" checked />
            <span>Upcoming events &amp; truck locations</span>
          </label>
          <label class="notify-check">
            <input type="checkbox" name="notifyBirthday" value="on" checked />
            <span>Birthday treat email</span>
          </label>
        </div>

        <button type="submit" class="btn btn-primary btn-full">Create Account & Get QR Code</button>
      </form>
<script>
// Auto-capitalize each word and restrict to letters+spaces
const nameInput = document.getElementById('name');
if (nameInput) {
  nameInput.addEventListener('input', function () {
    const pos = this.selectionStart;
    this.value = this.value
      .replace(/[^A-Za-z\s]/g, '')
      .replace(/\b\w/g, c => c.toUpperCase());
    this.setSelectionRange(pos, pos);
  });
}
</script>

      <p class="auth-switch">Already have an account? <a href="/login">Sign in →</a></p>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

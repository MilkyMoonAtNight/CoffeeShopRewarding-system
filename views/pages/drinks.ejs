<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">What We Pour</p>
      <h1 class="page-title light">The Drinks</h1>
    </div>
  </section>

  <div class="drinks-tabs-wrap">
    <div class="drinks-tabs">
      <button class="drinks-tab active" data-tab="hot">☕ Hot Drinks</button>
      <button class="drinks-tab" data-tab="cold">🧊 Cold Drinks</button>
    </div>
  </div>

  <section class="section drinks-section section-bloop">
    <div class="container">

      <!-- HOT -->
      <div class="drinks-panel" id="tab-hot">
        <div class="drinks-size-legend"><span>Regular — 250ml</span><span class="legend-sep">·</span><span>Large — 350ml</span></div>
        <div class="drink-grid">
          <% hot.forEach((drink, idx) => { %>
          <%
            const isLatte = drink.name && drink.name.toLowerCase().includes('latte');
            const dispFlavours = isLatte ? ['Plain','Vanilla','Hazelnut','Chocolate','Cinnamon','American Fudge','Caramel','Popcorn'] : (drink.flavours||[]);
          %>
          <div class="drink-card order-item-card <%= drink.isSpecial ? 'drink-card-special' : '' %>"
               data-drink-idx="<%= idx %>" data-drink-cat="hot">
            <div class="drink-card-inner-wrap">
              <div class="drink-img-wrap drink-img-wrap-cup">
                <% if (drink.image) { %>
                  <img src="<%= drink.image.startsWith('/') ? drink.image : '/images/drinks/' + drink.image %>" alt="<%= drink.name %>" loading="lazy" />
                <% } else { %>
                  <div class="drink-cup-wrap">
                    <%- include('../partials/drink-cup', { drink: drink }) %>
                  </div>
                <% } %>
              </div>
              <div class="drink-card-top">
                <span class="drink-name"><%= drink.name %></span>
                <div class="drink-prices">
                  <% if (drink.prices&&drink.prices.regular) { %><span class="drink-price-pill">R<%= drink.prices.regular %><span class="drink-size-label"> reg</span></span><% } %>
                  <% if (drink.prices&&drink.prices.large)   { %><span class="drink-price-pill drink-price-large">R<%= drink.prices.large %><span class="drink-size-label"> lge</span></span><% } %>
                </div>
              </div>
              <% if (dispFlavours.length) { %>
              <div class="drink-flavours">
                <span class="flavours-label">Flavours</span>
                <span class="flavours-list"><%= dispFlavours.slice(0,4).join(' · ') %><%= dispFlavours.length>4?'…':'' %></span>
              </div>
              <% } %>
              <% if (drink.isSpecial) { %><span class="drink-special-tag">✦ Special</span><% } %>
              <span class="order-add-hint">Tap to customise →</span>
            </div>
          </div>
          <% }) %>
        </div>
        <% if (!hot.length) { %><p class="drinks-empty">Menu coming soon!</p><% } %>
      </div>

      <!-- COLD -->
      <div class="drinks-panel hidden" id="tab-cold">
        <div class="drinks-size-legend"><span>Regular — 350ml</span><span class="legend-sep">·</span><span>Large — 500ml</span></div>
        <div class="drink-grid">
          <% cold.forEach((drink, idx) => { %>
          <%
            const dn = (drink.name||'').toLowerCase();
            const LATTE_F  = ['Plain','Vanilla','Hazelnut','Chocolate','Cinnamon','American Fudge','Caramel','Popcorn'];
            const FREEZO_F = ['White Chocolate','Chai','Coffee','Chocolate','Salted Caramel'];
            const FY_F     = ['Plain','Vanilla','Hazelnut','Strawberry','Cherry','Litchi','Creamsoda'];
            const SLUSHI_F = ['Strawberry','Mango','Blue Raspberry','Watermelon','Grape'];
            const dispFlavours = dn.includes('frozen yogurt')||dn.includes('froyo') ? FY_F
                               : dn.includes('freezo')   ? FREEZO_F
                               : dn.includes('slush')    ? SLUSHI_F
                               : dn.includes('latte')    ? LATTE_F
                               : (drink.flavours||[]);
          %>
          <div class="drink-card order-item-card <%= drink.isSpecial ? 'drink-card-special' : '' %>"
               data-drink-idx="<%= idx %>" data-drink-cat="cold">
            <div class="drink-card-inner-wrap">
              <div class="drink-img-wrap drink-img-wrap-cup">
                <% if (drink.image) { %>
                  <img src="<%= drink.image.startsWith('/') ? drink.image : '/images/drinks/' + drink.image %>" alt="<%= drink.name %>" loading="lazy" />
                <% } else { %>
                  <div class="drink-cup-wrap">
                    <%- include('../partials/drink-cup', { drink: drink }) %>
                  </div>
                <% } %>
              </div>
              <div class="drink-card-top">
                <span class="drink-name"><%= drink.name %></span>
                <div class="drink-prices">
                  <% if (drink.prices&&drink.prices.regular) { %><span class="drink-price-pill">R<%= drink.prices.regular %><span class="drink-size-label"> reg</span></span><% } %>
                  <% if (drink.prices&&drink.prices.large)   { %><span class="drink-price-pill drink-price-large">R<%= drink.prices.large %><span class="drink-size-label"> lge</span></span><% } %>
                </div>
              </div>
              <% if (dispFlavours.length) { %>
              <div class="drink-flavours">
                <span class="flavours-label">Flavours</span>
                <span class="flavours-list"><%= dispFlavours.slice(0,4).join(' · ') %><%= dispFlavours.length>4?'…':'' %></span>
              </div>
              <% } %>
              <% if (drink.isSpecial) { %><span class="drink-special-tag">✦ Special</span><% } %>
              <span class="order-add-hint">Tap to customise →</span>
            </div>
          </div>
          <% }) %>
        </div>
        <% if (!cold.length) { %><p class="drinks-empty">Menu coming soon!</p><% } %>
      </div>

    </div>
  </section>
</main>

<!-- Inject menu data for shared modal -->
<script>
window.CL_DATA = {
  loggedIn: <%= !!(locals.session && session.userId) %>,
  hot: <%- JSON.stringify(hot.map(d => ({
    name:d.name, category:'hot', subcategory:d.subcategory, isSpecial:d.isSpecial,
    image:d.image?'/images/drinks/'+d.image:null, flavours:d.flavours||[],
    sizes:[
      d.prices&&d.prices.regular?{label:'Regular',ml:'250ml',price:d.prices.regular}:null,
      d.prices&&d.prices.large  ?{label:'Large',  ml:'350ml',price:d.prices.large  }:null
    ].filter(Boolean)
  }))).replace(/</g,"\\u003c") %>,
  cold: <%- JSON.stringify(cold.map(d => ({
    name:d.name, category:'cold', subcategory:d.subcategory, isSpecial:d.isSpecial,
    image:d.image?'/images/drinks/'+d.image:null, flavours:d.flavours||[],
    sizes:[
      d.prices&&d.prices.regular?{label:'Regular',ml:'350ml',price:d.prices.regular}:null,
      d.prices&&d.prices.large  ?{label:'Large',  ml:'500ml',price:d.prices.large  }:null
    ].filter(Boolean)
  }))).replace(/</g,"\\u003c") %>,
  pastries: []
};
</script>

<%- include('../partials/item-modal') %>

<script>
document.querySelectorAll('.drinks-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.drinks-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.drinks-panel').forEach(p => p.classList.add('hidden'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.remove('hidden');
  });
});
</script>

<%- include('../partials/footer') %>

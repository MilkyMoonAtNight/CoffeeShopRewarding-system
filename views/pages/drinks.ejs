<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">What We Pour</p>
      <h1 class="page-title light">The Drinks</h1>
    </div>
  </section>

  <div class="drinks-tabs-wrap">
    <div class="drinks-tabs">
      <button class="drinks-tab active" data-tab="hot">☕ Hot Drinks</button>
      <button class="drinks-tab" data-tab="cold">🧊 Cold Drinks</button>
    </div>
  </div>

  <section class="section drinks-section">
    <div class="container">

      <!-- HOT DRINKS -->
      <div class="drinks-panel" id="tab-hot">
        <div class="drinks-size-legend">
          <span>Regular — 250ml</span><span class="legend-sep">·</span><span>Large — 350ml</span>
        </div>
        <div class="drink-grid">
          <% hot.forEach(drink => { %>
          <%
            const latteFlavours = ['Plain','Vanilla','Hazelnut','Chocolate','Cinnamon','American Fudge','Caramel','Popcorn'];
            const isLatte = drink.name && drink.name.toLowerCase().includes('latte');
            const displayFlavours = isLatte ? latteFlavours : (drink.flavours && drink.flavours.length ? drink.flavours : []);
            const slug = encodeURIComponent(drink.name);
          %>
          <a href="/drinks/<%= slug %>" class="drink-card drink-card-link <%= drink.isSpecial ? 'drink-card-special' : '' %>">
            <div class="drink-card-inner-wrap">
              <div class="drink-img-wrap">
                <% if (drink.image) { %>
                  <img src="/images/drinks/<%= drink.image %>" alt="<%= drink.name %>" loading="lazy" />
                <% } else { %>
                  <div class="drink-img-placeholder">
                    <span><%= drink.subcategory === 'chocolate' ? '🍫' : drink.subcategory === 'tea' ? '🍵' : '☕' %></span>
                    <span><%= drink.name %></span>
                  </div>
                <% } %>
              </div>
              <div class="drink-card-top">
                <span class="drink-name"><%= drink.name %></span>
                <div class="drink-prices">
                  <% if (drink.prices && drink.prices.regular) { %><span class="drink-price-pill">R<%= drink.prices.regular %><span class="drink-size-label"> reg</span></span><% } %>
                  <% if (drink.prices && drink.prices.large)   { %><span class="drink-price-pill drink-price-large">R<%= drink.prices.large %><span class="drink-size-label"> lge</span></span><% } %>
                </div>
              </div>
              <% if (displayFlavours.length) { %>
              <div class="drink-flavours">
                <span class="flavours-label">Flavours</span>
                <span class="flavours-list"><%= displayFlavours.slice(0,4).join(' · ') %><%= displayFlavours.length > 4 ? '…' : '' %></span>
              </div>
              <% } %>
              <% if (drink.isSpecial) { %><span class="drink-special-tag">✦ Special</span><% } %>
              <span class="drink-tap-hint">Tap for details →</span>
            </div>
          </a>
          <% }) %>
        </div>
        <% if (!hot.length) { %><p class="drinks-empty">Menu coming soon — ask our barista!</p><% } %>
      </div>

      <!-- COLD DRINKS -->
      <div class="drinks-panel hidden" id="tab-cold">
        <div class="drinks-size-legend">
          <span>Regular — 350ml</span><span class="legend-sep">·</span><span>Large — 500ml</span>
        </div>
        <div class="drink-grid">
          <% cold.forEach(drink => { %>
          <%
            const latteFlavoursC = ['Plain','Vanilla','Hazelnut','Chocolate','Cinnamon','American Fudge','Caramel','Popcorn'];
            const freezoFlavours = ['White Chocolate','Chai','Coffee','Chocolate','Salted Caramel'];
            const frozenYogurtFlavours = [...latteFlavoursC,'Strawberry','Cherry','Litchi','Creamsoda','Apple'];
            const dn = drink.name ? drink.name.toLowerCase() : '';
            const coldFlavours = dn.includes('frozen yogurt')||dn.includes('froyo') ? frozenYogurtFlavours
                                : dn.includes('freezo') ? freezoFlavours
                                : dn.includes('latte')  ? latteFlavoursC
                                : (drink.flavours && drink.flavours.length ? drink.flavours : []);
            const slug = encodeURIComponent(drink.name);
          %>
          <a href="/drinks/<%= slug %>" class="drink-card drink-card-link <%= drink.isSpecial ? 'drink-card-special' : '' %>">
            <div class="drink-card-inner-wrap">
              <div class="drink-img-wrap">
                <% if (drink.image) { %>
                  <img src="/images/drinks/<%= drink.image %>" alt="<%= drink.name %>" loading="lazy" />
                <% } else { %>
                  <div class="drink-img-placeholder">
                    <span><%= drink.subcategory === 'frozen' ? '🍦' : drink.subcategory === 'tea' ? '🍵' : '🧊' %></span>
                    <span><%= drink.name %></span>
                  </div>
                <% } %>
              </div>
              <div class="drink-card-top">
                <span class="drink-name"><%= drink.name %></span>
                <div class="drink-prices">
                  <% if (drink.prices && drink.prices.regular) { %><span class="drink-price-pill">R<%= drink.prices.regular %><span class="drink-size-label"> reg</span></span><% } %>
                  <% if (drink.prices && drink.prices.large)   { %><span class="drink-price-pill drink-price-large">R<%= drink.prices.large %><span class="drink-size-label"> lge</span></span><% } %>
                </div>
              </div>
              <% if (coldFlavours.length) { %>
              <div class="drink-flavours">
                <span class="flavours-label">Flavours</span>
                <span class="flavours-list"><%= coldFlavours.slice(0,4).join(' · ') %><%= coldFlavours.length > 4 ? '…' : '' %></span>
              </div>
              <% } %>
              <% if (drink.isSpecial) { %><span class="drink-special-tag">✦ Special</span><% } %>
              <span class="drink-tap-hint">Tap for details →</span>
            </div>
          </a>
          <% }) %>
        </div>
        <% if (!cold.length) { %><p class="drinks-empty">Menu coming soon — ask our barista!</p><% } %>
      </div>

    </div>
  </section>

  <section class="section-cta section-dark">
    <div class="container text-center">
      <p>Every drink you buy earns you a scan on your battlepass.</p>
      <a href="/register" class="btn btn-outline-light">Get Your QR Code →</a>
    </div>
  </section>
</main>

<script>
  document.querySelectorAll('.drinks-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.drinks-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.drinks-panel').forEach(p => p.classList.add('hidden'));
      tab.classList.add('active');
      document.getElementById('tab-' + tab.dataset.tab).classList.remove('hidden');
    });
  });
</script>

<%- include('../partials/footer') %>

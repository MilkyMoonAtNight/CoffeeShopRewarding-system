<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="auth-section">
    <div class="auth-card">
      <div class="auth-logo">
        <img src="/images/logo_nav.png" alt="Con Leche" />
      </div>
      <h1 class="auth-title">Forgot Password</h1>
      <p class="auth-sub">Enter your email and we'll send you a reset link.</p>

      <% if (success) { %>
      <div class="auth-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
      <div class="auth-error"><%= error %></div>
      <% } %>

      <% if (!success) { %>
      <form action="/forgot-password" method="POST" class="auth-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" autofocus />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
      </form>
      <% } %>

      <p class="auth-switch"><a href="/login">← Back to sign in</a></p>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

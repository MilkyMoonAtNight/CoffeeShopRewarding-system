<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css" />
  <style>
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; background:var(--cream); flex-direction:column; gap:1.5rem; font-family:var(--font-body); }
    .redirect-logo { width:64px; height:64px; object-fit:contain; }
    .redirect-spinner { width:40px; height:40px; border:3px solid rgba(88,18,23,0.15); border-top-color:var(--maroon); border-radius:50%; animation:spin 0.8s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .redirect-text { font-size:0.9rem; color:rgba(44,44,44,0.55); text-align:center; }
    .redirect-title { font-family:var(--font-nimbus); font-size:1.4rem; color:var(--charcoal); }
  </style>
</head>
<body>
  <img src="/images/logo.png" alt="Con Leche" class="redirect-logo" />
  <p class="redirect-title">Redirecting to Ozow</p>
  <div class="redirect-spinner"></div>
  <p class="redirect-text">You're being securely redirected to complete your payment.<br/>Please don't close this page.</p>

  <form id="ozowForm" action="<%= ozowUrl %>" method="POST">
    <% Object.entries(fields).forEach(([key, val]) => { %>
      <input type="hidden" name="<%= key %>" value="<%= val %>" />
    <% }) %>
  </form>
  <script>
    setTimeout(() => document.getElementById('ozowForm').submit(), 800);
  </script>
</body>
</html>

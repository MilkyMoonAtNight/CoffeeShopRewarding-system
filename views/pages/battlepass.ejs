<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
<section class="bp-page">
  <div class="bp-container">

    <!-- ── INTERNAL NAV ── -->
    <div class="bp-tabs">
      <button class="bp-tab active" data-tab="profile">Profile</button>
      <button class="bp-tab" data-tab="rewards">Rewards</button>
      <button class="bp-tab" data-tab="history">History</button>
    </div>

    <!-- ════════════ TAB: PROFILE ════════════ -->
    <div class="bp-tab-panel" id="tab-profile">

      <div class="bp-qr-card">
        <div class="bp-card-logo">
          <img src="/images/logo_nav.png" alt="Con Leche" />
        </div>
        <div class="bp-name-row">
          <h2 class="bp-name" id="bpNameDisplay"><%= user.name %></h2>
          <button class="bp-edit-name-btn" id="bpEditNameBtn" title="Edit name">&#9998;</button>
        </div>
        <form id="bpNameForm" class="bp-name-form hidden" autocomplete="off">
          <input type="text" id="bpNameInput" class="bp-name-input" value="<%= user.name %>"
                 pattern="[A-Za-z\s]+" maxlength="80" required />
          <button type="submit" class="btn btn-primary" style="padding:0.4rem 1rem;font-size:0.82rem;">Save</button>
          <button type="button" id="bpNameCancel" style="background:none;border:none;cursor:pointer;font-size:0.82rem;color:rgba(253,246,237,0.4);">Cancel</button>
        </form>
        <p class="bp-email"><%= user.email %></p>
        <div class="bp-qr-box">
          <img src="<%= qrDataUrl %>" alt="QR Code" class="bp-qr-img" />
        </div>

        <span style="display:block;height:0.75rem;"></span>

        <div class="bp-tier-chip">
          <%= user.tier === 'Kitten' ? '🐱' : user.tier === 'Cat' ? '🐈' : user.tier === 'Tom Cat' ? '😸' : '🐆' %>
          <%= user.tier %>
        </div>
        <p class="bp-qr-hint">Show this to your barista when ordering</p>

        <!-- Backup token — works even if the camera scan fails -->
        <div class="bp-token-box" onclick="copyToken()" title="Tap to copy">
          <span class="bp-token-label">Backup code — if scanning fails, the barista can type this:</span>
          <span class="bp-token" id="bpToken"><%= user.qrCode %></span>
          <span class="bp-token-copy" id="bpTokenCopy">tap to copy</span>
        </div>
      </div>

      <div class="bp-stats-row">
        <div class="bp-stat-box">
          <span class="bp-stat-num"><%= user.totalDrinks %></span>
          <span class="bp-stat-lbl">drinks</span>
        </div>
        <div class="bp-stat-box">
          <span class="bp-stat-num"><%= claimableItems.length %></span>
          <span class="bp-stat-lbl">to claim</span>
        </div>
        <div class="bp-stat-box">
          <span class="bp-stat-num"><%= activeVouchers.length %></span>
          <span class="bp-stat-lbl">vouchers</span>
        </div>
      </div>

      <!-- ── Email preferences ── -->
      <div class="bp-section-card bp-prefs-card">
        <p class="bp-section-label">Email Notifications</p>
        <p class="bp-section-hint">Choose what Con Leche can send you. Changes save instantly.</p>
        <form id="prefsForm" class="bp-prefs-form">
          <label class="bp-pref-toggle">
            <div class="bp-pref-info">
              <span class="bp-pref-name">Specials &amp; new arrivals</span>
              <span class="bp-pref-desc">Weekly drinks, monthly features, new menu items</span>
            </div>
            <input type="checkbox" name="specials" id="prefSpecials" class="bp-toggle-input" <%= user.emailPreferences && user.emailPreferences.specials ? 'checked' : '' %> />
            <span class="bp-toggle-track"><span class="bp-toggle-thumb"></span></span>
          </label>
          <label class="bp-pref-toggle">
            <div class="bp-pref-info">
              <span class="bp-pref-name">Events &amp; truck locations</span>
              <span class="bp-pref-desc">Where to find us — markets, pop-ups, run clubs</span>
            </div>
            <input type="checkbox" name="events" id="prefEvents" class="bp-toggle-input" <%= user.emailPreferences && user.emailPreferences.events ? 'checked' : '' %> />
            <span class="bp-toggle-track"><span class="bp-toggle-thumb"></span></span>
          </label>
          <label class="bp-pref-toggle">
            <div class="bp-pref-info">
              <span class="bp-pref-name">Birthday treat</span>
              <span class="bp-pref-desc">Free cookie + 10% off on your birthday</span>
            </div>
            <input type="checkbox" name="birthday" id="prefBirthday" class="bp-toggle-input" <%= user.emailPreferences && user.emailPreferences.birthday ? 'checked' : '' %> />
            <span class="bp-toggle-track"><span class="bp-toggle-thumb"></span></span>
          </label>
          <p class="bp-prefs-saved hidden" id="prefsSaved">✓ Saved</p>
        </form>
      </div>

      <!-- ── Danger zone ── -->
      <div class="bp-danger-zone">
        <p class="bp-danger-label">Danger zone</p>
        <p class="bp-danger-sub">Permanently delete your Con Leche account. This removes your battlepass, all stamps, rewards, and order history. This cannot be undone.</p>
        <button class="btn bp-delete-btn" onclick="document.getElementById('deleteAccountOverlay').classList.add('open')">
          Delete my account
        </button>
      </div>

    </div>

    <!-- ════════════ TAB: REWARDS ════════════ -->
    <div class="bp-tab-panel hidden" id="tab-rewards">

      <!-- 9 LIVES -->
      <div class="bp-section-card">
        <p class="bp-section-label">9 Lives — every 10th drink is free 🐾</p>
        <% const livesUsed = user.totalDrinks % 10; %>
        <div class="lives-row">
          <% for (let i = 1; i <= 9; i++) { %>
          <div class="life-dot <%= i <= livesUsed ? 'life-used' : 'life-empty' %>">
            <span><%= i <= livesUsed ? '🐾' : '' %></span>
          </div>
          <% } %>
          <div class="life-dot life-free">
            <span>☕</span>
          </div>
        </div>
        <p class="lives-count"><%= livesUsed %> / 9 — <%= 10 - livesUsed %> drinks to go</p>
      </div>

      <!-- PROGRESS TO NEXT REWARD -->
      <% if (next) { %>
      <div class="bp-section-card">
        <p class="bp-section-label">Next Reward</p>
        <div class="bp-next-reward-row">
          <span class="bp-next-icon">
            <%= next.type === 'free_drink' ? '☕' : next.type === 'special' ? '✨' : next.type === 'merch' ? '🎁' : next.type === 'store_voucher' ? '💳' : '🎫' %>
          </span>
          <div class="bp-next-info">
            <p class="bp-next-desc"><%= next.description %></p>
            <p class="bp-next-count"><%= drinksToNext %> drink<%= drinksToNext !== 1 ? 's' : '' %> away</p>
          </div>
        </div>
        <% const pct = Math.min(100, Math.max(0, progressPct)); %>
        <div class="bp-prog-track">
          <div class="bp-prog-fill" data-pct="<%= pct %>"></div>
        </div>
      </div>
      <% } %>

      <!-- UPCOMING MILESTONES -->
      <% if (upcomingMilestones.length > 0) { %>
      <div class="bp-section-card">
        <p class="bp-section-label">Coming Up</p>
        <div class="bp-ms-list">
          <% upcomingMilestones.forEach((m, i) => { %>
          <div class="bp-ms-item <%= i === 0 ? 'bp-ms-next' : '' %>">
            <span class="bp-ms-icon">
              <%= m.type === 'free_drink' ? '☕' : m.type === 'special' ? '✨' : m.type === 'merch' ? '🎁' : m.type === 'store_voucher' ? '💳' : '🎫' %>
            </span>
            <div class="bp-ms-body">
              <p class="bp-ms-desc"><%= m.description %></p>
              <p class="bp-ms-num">Drink #<%= m.drinkNumber %><% if (m.expires) { %> · 7-day voucher<% } %></p>
            </div>
            <% if (i === 0) { %><span class="bp-ms-badge">Next</span><% } %>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- INVENTORY — banked rewards, kept until claimed -->
      <% if (claimableItems.length > 0) { %>
      <div class="bp-section-card">
        <p class="bp-section-label">🎁 Inventory — Ready to Claim</p>
        <p class="bp-section-hint">These never expire — claim whenever you like. Tap Claim and show the code to your barista.</p>
        <div class="bp-claim-list">
          <% claimableItems.forEach(reward => { %>
          <div class="bp-claim-item" data-reward-id="<%= reward._id %>">
            <span class="bp-claim-icon">
              <%= reward.type === 'free_drink' ? '☕' : reward.type === 'special' ? '✨' : reward.type === 'merch' ? '🎁' : '💳' %>
            </span>
            <div class="bp-claim-body">
              <p class="bp-claim-title"><%= reward.description %></p>
              <p class="bp-claim-earned">Earned at drink #<%= reward.drinkNumber %></p>
            </div>
            <div class="bp-claim-action">
              <% const codeAge = reward.claimCodeGeneratedAt ? (new Date() - new Date(reward.claimCodeGeneratedAt)) / 1000 / 60 : 99; %>
              <% if (reward.claimCode && codeAge < 10) { %>
                <div class="bp-claim-show">
                  <% if (claimQrs && claimQrs[reward._id]) { %>
                  <div class="bp-claim-qr">
                    <img src="<%= claimQrs[reward._id] %>" alt="Reward QR" />
                    <span class="bp-claim-qr-hint">Barista scans this</span>
                  </div>
                  <% } %>
                  <div class="bp-code-display">
                    <span class="bp-code"><%= reward.claimCode %></span>
                    <span class="bp-code-hint">Read this to your barista</span>
                  </div>
                </div>
              <% } else { %>
                <button class="btn btn-primary claim-btn" data-id="<%= reward._id %>">Claim</button>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- ACTIVE VOUCHERS — 7 days, gone once redeemed -->
      <% if (activeVouchers.length > 0) { %>
      <div class="bp-section-card">
        <p class="bp-section-label">🎫 Active Vouchers</p>
        <p class="bp-section-hint">Valid 7 days from when you earned them. Tap Redeem at the counter — once redeemed, it's used up.</p>
        <div class="bp-voucher-list">
          <% activeVouchers.forEach(v => { %>
          <% const daysLeft = v.expiresAt ? Math.max(0, Math.ceil((new Date(v.expiresAt) - new Date()) / (1000*60*60*24))) : null; %>
          <div class="bp-voucher-item <%= daysLeft !== null && daysLeft <= 1 ? 'voucher-urgent' : '' %>" id="voucher-<%= v._id %>">
            <span class="bp-voucher-icon">🎫</span>
            <div class="bp-voucher-body">
              <p class="bp-voucher-desc"><%= v.description %></p>
              <p class="bp-voucher-sub">Earned at drink #<%= v.drinkNumber %></p>
            </div>
            <div class="bp-voucher-side">
              <% if (daysLeft !== null) { %>
              <div class="bp-days-left">
                <span class="bp-days-num"><%= daysLeft %></span>
                <span class="bp-days-lbl">day<%= daysLeft !== 1 ? 's' : '' %></span>
              </div>
              <% } %>
              <button class="btn btn-outline bp-redeem-btn" data-id="<%= v._id %>" data-desc="<%= v.description %>">Redeem</button>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if (claimableItems.length === 0 && activeVouchers.length === 0) { %>
      <div class="bp-section-card" style="text-align:center;">
        <p style="font-size:2rem;margin-bottom:0.5rem;">🐾</p>
        <p class="bp-section-label" style="margin-bottom:0.25rem;">Nothing to claim yet</p>
        <p class="bp-section-hint">Keep sipping — your next reward is on its way.</p>
      </div>
      <% } %>

    </div>

    <!-- ════════════ TAB: HISTORY ════════════ -->
    <div class="bp-tab-panel hidden" id="tab-history">

      <!-- STAMP HISTORY — when, by whom, how many -->
      <div class="bp-section-card">
        <p class="bp-section-label">☕ Stamp History</p>
        <% if (stampHistory && stampHistory.length > 0) { %>
        <div class="bp-voucher-list">
          <% stampHistory.forEach(log => { %>
          <div class="bp-voucher-item">
            <span class="bp-voucher-icon">☕</span>
            <div class="bp-voucher-body">
              <p class="bp-voucher-desc"><strong><%= log.quantity %></strong> drink<%= log.quantity !== 1 ? 's' : '' %> added<% if (log.totalAfter) { %> · total <%= log.totalAfter %><% } %></p>
              <p class="bp-voucher-sub">by <%= log.adminName || 'Staff' %> · <%= new Date(log.at).toLocaleString('en-ZA', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></p>
            </div>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="bp-section-hint">Your stamps will show up here after your first scan.</p>
        <% } %>
      </div>

      <!-- REDEEMED REWARDS -->
      <% if (claimedItems.length > 0 || redeemedVouchers.length > 0) { %>
      <div class="bp-section-card">
        <p class="bp-section-label">✓ Redeemed Rewards</p>
        <div class="bp-voucher-list">
          <% claimedItems.forEach(r => { %>
          <div class="bp-voucher-item bp-item-faded">
            <span class="bp-voucher-icon">✓</span>
            <div class="bp-voucher-body">
              <p class="bp-voucher-desc"><%= r.description %></p>
              <p class="bp-voucher-sub">
                Claimed <%= (r.redeemedAt || r.claimedAt) ? new Date(r.redeemedAt || r.claimedAt).toLocaleDateString('en-ZA', { day:'numeric', month:'short', year:'numeric' }) : '' %><% if (r.claimedBy || r.redeemedBy) { %> · confirmed by <%= r.claimedBy || r.redeemedBy %><% } %>
              </p>
            </div>
          </div>
          <% }) %>
          <% redeemedVouchers.forEach(v => { %>
          <div class="bp-voucher-item bp-item-faded">
            <span class="bp-voucher-icon">🎫</span>
            <div class="bp-voucher-body">
              <p class="bp-voucher-desc"><%= v.description %></p>
              <p class="bp-voucher-sub">Redeemed <%= v.redeemedAt ? new Date(v.redeemedAt).toLocaleString('en-ZA', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) : '' %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- PAST / EXPIRED -->
      <% if (expiredVouchers.length > 0) { %>
      <div class="bp-section-card bp-history-card">
        <p class="bp-section-label">⌛ Past Rewards</p>
        <div class="bp-voucher-list">
          <% expiredVouchers.forEach(v => { %>
          <div class="bp-voucher-item bp-item-faded">
            <span class="bp-voucher-icon">⌛</span>
            <div class="bp-voucher-body">
              <p class="bp-voucher-desc"><%= v.description %></p>
              <p class="bp-voucher-sub">Expired <%= new Date(v.expiresAt).toLocaleDateString('en-ZA') %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- PURCHASE HISTORY -->
      <div class="bp-section-card" style="text-align:center;">
        <p class="bp-section-label">🛒 Purchase History</p>
        <p class="bp-section-hint" style="margin-bottom:0.85rem;">Your orders, live status and past slips live on the orders page.</p>
        <a href="/order/my-orders" class="btn btn-outline" style="border-color:rgba(88,18,23,0.35);color:var(--maroon);">View My Orders →</a>
      </div>

    </div>

  </div><!-- end bp-container -->
</section>
</main>

<!-- ── Live "barista is serving you" overlay ── -->
<div class="bp-live-overlay" id="bpLiveOverlay">
  <div class="bp-live-card">
    <div class="bp-live-spinner" id="bpLiveSpinner"></div>
    <div class="bp-live-check" id="bpLiveCheck">✓</div>
    <h2 class="bp-live-title" id="bpLiveTitle">Barista is loading your drinks…</h2>
    <p class="bp-live-sub" id="bpLiveSub">Hang tight, this only takes a moment.</p>
  </div>
</div>

<!-- Voucher redeem confirmation overlay -->
<div class="modal-overlay" id="redeemOverlay">
  <div class="modal-sheet" style="max-width:400px;border-radius:var(--radius-lg);">
    <button class="modal-close" onclick="closeRedeem()">✕</button>
    <div class="modal-body" style="padding-top:1.75rem;text-align:center;">
      <div style="font-size:2.5rem;margin-bottom:0.75rem;">🎫</div>
      <h2 style="font-family:var(--font-nimbus);font-size:1.3rem;margin-bottom:0.5rem;">Redeem this voucher?</h2>
      <p id="redeemDesc" style="color:rgba(44,44,44,0.7);margin-bottom:0.75rem;font-weight:600;"></p>
      <p style="color:rgba(44,44,44,0.5);font-size:0.82rem;margin-bottom:1.5rem;">Only tap Redeem <strong>at the counter with your barista watching</strong> — once redeemed it's used up and can't be brought back.</p>
      <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
        <button id="redeemConfirmBtn" class="btn btn-primary" style="min-width:150px;" onclick="confirmRedeem()">Redeem now</button>
        <button type="button" class="btn btn-outline" style="border-color:rgba(44,44,44,0.2);color:var(--charcoal);" onclick="closeRedeem()">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete account confirmation overlay -->
<div class="modal-overlay" id="deleteAccountOverlay">
  <div class="modal-sheet" style="max-width:420px;border-radius:var(--radius-lg);">
    <button class="modal-close" onclick="document.getElementById('deleteAccountOverlay').classList.remove('open')">✕</button>
    <div class="modal-body" style="padding-top:1.75rem;text-align:center;">
      <div style="font-size:2.5rem;margin-bottom:0.75rem;">💔</div>
      <h2 style="font-family:var(--font-nimbus);font-size:1.4rem;margin-bottom:0.5rem;">We'll miss you</h2>
      <p style="color:rgba(44,44,44,0.6);margin-bottom:0.5rem;">Are you sure you want to delete your account?</p>
      <p style="color:rgba(44,44,44,0.5);font-size:0.82rem;margin-bottom:1rem;">You have <strong><%= user.totalDrinks %> stamps</strong> and <strong><%= claimableItems.length %> unclaimed rewards</strong>. All of this will be gone forever.</p>
      <p style="color:rgba(44,44,44,0.45);font-size:0.78rem;margin-bottom:1.5rem;">Type <strong>DELETE</strong> to confirm.</p>
      <input type="text" id="deleteConfirmInput" class="confirm-input"
             placeholder="Type DELETE here" style="text-align:center;margin-bottom:1rem;letter-spacing:0.1em;" />
      <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
        <button id="confirmDeleteBtn" class="btn btn-primary" style="background:#c83232;min-width:160px;" disabled
                onclick="submitDelete()">Delete my account</button>
        <button type="button" class="btn btn-outline" style="border-color:rgba(44,44,44,0.2);color:var(--charcoal);"
                onclick="document.getElementById('deleteAccountOverlay').classList.remove('open')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Tabs ──────────────────────────────────────────────────────────
document.querySelectorAll('.bp-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.bp-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.bp-tab-panel').forEach(p => p.classList.add('hidden'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
});

// ── Copy token ────────────────────────────────────────────────────
function copyToken() {
  const token = document.getElementById('bpToken').textContent.trim();
  navigator.clipboard.writeText(token).then(() => {
    const hint = document.getElementById('bpTokenCopy');
    hint.textContent = '✓ copied';
    setTimeout(() => { hint.textContent = 'tap to copy'; }, 2000);
  }).catch(() => {});
}

// ── Progress bar ──────────────────────────────────────────────────
document.querySelectorAll('.bp-prog-fill').forEach(el => {
  el.style.width = el.dataset.pct + '%';
});

// ── Claim buttons (free drinks / merch — 4-digit code flow) ───────
document.querySelectorAll('.claim-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id;
    btn.textContent = '…';
    btn.disabled = true;
    try {
      const res = await fetch(`/battlepass/claim/${id}`, { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        const action = btn.closest('.bp-claim-action');
        action.innerHTML = `
          <div class="bp-claim-show">
            ${data.qrDataUrl ? `<div class="bp-claim-qr"><img src="${data.qrDataUrl}" alt="Reward QR" /><span class="bp-claim-qr-hint">Barista scans this</span></div>` : ''}
            <div class="bp-code-display">
              <span class="bp-code">${data.code}</span>
              <span class="bp-code-hint">Read this to your barista</span>
            </div>
          </div>`;
      } else {
        btn.textContent = 'Claim';
        btn.disabled = false;
        alert(data.message);
      }
    } catch (e) {
      btn.textContent = 'Claim';
      btn.disabled = false;
    }
  });
});

// ── Voucher redeem (confirm → mark used → big REDEEMED state) ─────
let redeemTargetId = null;
document.querySelectorAll('.bp-redeem-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    redeemTargetId = btn.dataset.id;
    document.getElementById('redeemDesc').textContent = btn.dataset.desc;
    document.getElementById('redeemOverlay').classList.add('open');
  });
});
function closeRedeem() {
  document.getElementById('redeemOverlay').classList.remove('open');
  redeemTargetId = null;
}
async function confirmRedeem() {
  if (!redeemTargetId) return;
  const id = redeemTargetId;
  const btn = document.getElementById('redeemConfirmBtn');
  btn.disabled = true; btn.textContent = 'Redeeming…';
  try {
    const res = await fetch(`/battlepass/redeem-voucher/${id}`, { method: 'POST' });
    const data = await res.json();
    btn.disabled = false; btn.textContent = 'Redeem now';
    if (data.success) {
      const item = document.getElementById('voucher-' + id);
      if (item) {
        const time = new Date(data.redeemedAt).toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' });
        item.innerHTML = `
          <div class="bp-redeemed-flash">
            <span class="bp-redeemed-check">✓</span>
            <div>
              <p class="bp-redeemed-title">REDEEMED</p>
              <p class="bp-redeemed-sub">${data.description} · ${time}</p>
            </div>
          </div>`;
        item.classList.add('bp-voucher-redeemed');
      }
      closeRedeem();
    } else {
      alert(data.message);
      closeRedeem();
    }
  } catch (e) {
    btn.disabled = false; btn.textContent = 'Redeem now';
  }
}
document.getElementById('redeemOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeRedeem();
});

// ── Email preferences toggles ─────────────────────────────────────
(function () {
  const form = document.getElementById('prefsForm');
  if (!form) return;
  let saveTimer = null;
  form.querySelectorAll('.bp-toggle-input').forEach(input => {
    input.addEventListener('change', () => {
      clearTimeout(saveTimer);
      saveTimer = setTimeout(async () => {
        const data = new FormData(form);
        // Unchecked boxes don't appear in FormData — explicitly add them
        ['specials','events','birthday'].forEach(k => { if (!data.has(k)) data.append(k, 'off'); });
        const body = new URLSearchParams(data);
        const res  = await fetch('/battlepass/preferences', { method: 'POST', body });
        const json = await res.json();
        if (json.success) {
          const saved = document.getElementById('prefsSaved');
          saved.classList.remove('hidden');
          setTimeout(() => saved.classList.add('hidden'), 2500);
        }
      }, 400);
    });
  });
})();

// ── Delete account ────────────────────────────────────────────────
const deleteInput = document.getElementById('deleteConfirmInput');
const confirmBtn  = document.getElementById('confirmDeleteBtn');
if (deleteInput) {
  deleteInput.addEventListener('input', () => {
    confirmBtn.disabled = deleteInput.value.trim().toUpperCase() !== 'DELETE';
  });
}
function submitDelete() {
  if (deleteInput.value.trim().toUpperCase() !== 'DELETE') return;
  confirmBtn.disabled = true;
  confirmBtn.textContent = 'Deleting…';
  fetch('/account/delete', { method: 'POST' })
    .then(r => r.json())
    .then(d => { if (d.ok) window.location = '/'; })
    .catch(() => { confirmBtn.disabled = false; confirmBtn.textContent = 'Delete my account'; });
}
document.getElementById('deleteAccountOverlay').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

// ── Live stamp updates ────────────────────────────────────────────
// Poll the server. While a barista is mid-scan, show "Barista is loading
// your drinks…" with a spinner; when the drink count goes up, swap to a
// check mark, then refresh the page so stamps/rewards/history are current.
(function () {
  const overlay = document.getElementById('bpLiveOverlay');
  const spinner = document.getElementById('bpLiveSpinner');
  const check   = document.getElementById('bpLiveCheck');
  const title   = document.getElementById('bpLiveTitle');
  const sub     = document.getElementById('bpLiveSub');
  let knownTotal = <%= Number(user.totalDrinks) || 0 %>;
  let celebrating = false;

  function showLoading() {
    spinner.style.display = 'block';
    check.style.display   = 'none';
    title.textContent = 'Barista is loading your drinks…';
    sub.textContent   = 'Hang tight, this only takes a moment.';
    overlay.classList.add('open');
  }
  function showAdded(added, newTotal) {
    celebrating = true;
    spinner.style.display = 'none';
    check.style.display   = 'flex';
    title.textContent = added + (added === 1 ? ' drink added!' : ' drinks added!');
    sub.textContent   = 'You now have ' + newTotal + ' drinks. Refreshing…';
    overlay.classList.add('open');
    setTimeout(() => window.location.reload(), 2200);
  }

  async function poll() {
    if (celebrating) return;
    try {
      const res = await fetch('/battlepass/status', { headers: { 'Accept': 'application/json' } });
      if (!res.ok) return;
      const d = await res.json();
      if (!d.ok) return;
      if (d.totalDrinks > knownTotal) {
        const added = d.totalDrinks - knownTotal;
        knownTotal = d.totalDrinks;
        showAdded(added, d.totalDrinks);
      } else if (d.pending) {
        showLoading();
      } else {
        overlay.classList.remove('open');
      }
    } catch (_) { /* offline / transient — try again next tick */ }
  }

  setInterval(poll, 2500);
  poll();
})();
</script>

<script>
// ── Edit name ────────────────────────────────────────────────────
const bpNameDisplay = document.getElementById('bpNameDisplay');
const bpEditBtn     = document.getElementById('bpEditNameBtn');
const bpNameForm    = document.getElementById('bpNameForm');
const bpNameInput   = document.getElementById('bpNameInput');
const bpNameCancel  = document.getElementById('bpNameCancel');

if (bpEditBtn) {
  bpEditBtn.addEventListener('click', () => {
    bpNameForm.classList.remove('hidden');
    bpEditBtn.classList.add('hidden');
    bpNameInput.focus();
  });
  bpNameCancel.addEventListener('click', () => {
    bpNameForm.classList.add('hidden');
    bpEditBtn.classList.remove('hidden');
  });
  bpNameInput.addEventListener('input', function () {
    const pos = this.selectionStart;
    this.value = this.value.replace(/[^A-Za-z\s]/g, '').replace(/\b\w/g, c => c.toUpperCase());
    this.setSelectionRange(pos, pos);
  });
  bpNameForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const newName = bpNameInput.value.trim();
    if (!newName) return;
    try {
      const r = await fetch('/battlepass/update-name', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: newName })
      });
      const d = await r.json();
      if (d.ok) {
        bpNameDisplay.textContent = d.name;
        bpNameForm.classList.add('hidden');
        bpEditBtn.classList.remove('hidden');
      }
    } catch(err) {}
  });
}
</script>


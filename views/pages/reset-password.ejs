<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="auth-section">
    <div class="auth-card">
      <div class="auth-logo">
        <img src="/images/logo_nav.png" alt="Con Leche" />
      </div>
      <h1 class="auth-title">Reset Password</h1>

      <% if (error) { %>
      <div class="auth-error"><%= error %></div>
      <% } %>

      <% if (valid) { %>
      <form action="/reset-password/<%= token %>" method="POST" class="auth-form">
        <div class="form-group">
          <label for="password">New Password</label>
          <input type="password" id="password" name="password" required placeholder="8+ characters" minlength="8" autofocus />
        </div>
        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••" />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Update Password</button>
      </form>
      <% } else { %>
      <p class="auth-sub" style="text-align:center;margin-top:1rem;">
        <a href="/forgot-password" class="btn btn-primary" style="display:inline-flex;">Request a new link</a>
      </p>
      <% } %>

      <p class="auth-switch"><a href="/login">← Back to sign in</a></p>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

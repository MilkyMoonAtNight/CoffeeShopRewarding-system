<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main>
  <section class="page-hero page-hero-short section-dark">
    <div class="container">
      <p class="section-eyebrow light">Order Online</p>
      <h1 class="page-title light">Place Your Order</h1>
      <p style="color:rgba(253,246,237,0.55);font-size:0.9rem;margin-top:0.5rem;">Hi <%= user.name %> — tap any item to customise and add to your cart</p>
    </div>
  </section>

  <div class="drinks-tabs-wrap">
    <div class="drinks-tabs">
      <button class="order-tab active" data-tab="hot">☕ Hot Drinks</button>
      <button class="order-tab" data-tab="cold">🧊 Cold Drinks</button>
      <button class="order-tab" data-tab="pastries">🥐 Pastries</button>
    </div>
  </div>

  <section class="section drinks-section">
    <div class="container">

      <!-- HOT -->
      <div class="order-panel" id="otab-hot">
        <div class="drinks-size-legend"><span>Regular — 250ml</span><span class="legend-sep">·</span><span>Large — 350ml</span></div>
        <div class="drink-grid">
          <% hot.forEach((drink, idx) => { %>
          <div class="drink-card order-item-card <%= drink.isSpecial ? 'drink-card-special' : '' %>"
               data-drink-idx="<%= idx %>" data-drink-cat="hot">
            <div class="drink-card-inner-wrap">
              <div class="drink-img-wrap">
                <% if (drink.image) { %>
                  <img src="/images/drinks/<%= drink.image %>" alt="<%= drink.name %>" loading="lazy" />
                <% } else { %>
                  <div class="drink-img-placeholder">
                    <span><%= drink.subcategory === 'chocolate' ? '🍫' : drink.subcategory === 'tea' ? '🍵' : '☕' %></span>
                    <span><%= drink.name %></span>
                  </div>
                <% } %>
              </div>
              <div class="drink-card-top">
                <span class="drink-name"><%= drink.name %></span>
                <div class="drink-prices">
                  <% if (drink.prices && drink.prices.regular) { %><span class="drink-price-pill">R<%= drink.prices.regular %><span class="drink-size-label"> reg</span></span><% } %>
                  <% if (drink.prices && drink.prices.large)   { %><span class="drink-price-pill drink-price-large">R<%= drink.prices.large %><span class="drink-size-label"> lge</span></span><% } %>
                </div>
              </div>
              <% if (drink.isSpecial) { %><span class="drink-special-tag">✦ Special</span><% } %>
              <span class="order-add-hint">Tap to customise & add →</span>
            </div>
          </div>
          <% }) %>
        </div>
        <% if (!hot.length) { %><p class="drinks-empty">Menu coming soon — ask our barista!</p><% } %>
      </div>

      <!-- COLD -->
      <div class="order-panel hidden" id="otab-cold">
        <div class="drinks-size-legend"><span>Regular — 350ml</span><span class="legend-sep">·</span><span>Large — 500ml</span></div>
        <div class="drink-grid">
          <% cold.forEach((drink, idx) => { %>
          <div class="drink-card order-item-card <%= drink.isSpecial ? 'drink-card-special' : '' %>"
               data-drink-idx="<%= idx %>" data-drink-cat="cold">
            <div class="drink-card-inner-wrap">
              <div class="drink-img-wrap">
                <% if (drink.image) { %>
                  <img src="/images/drinks/<%= drink.image %>" alt="<%= drink.name %>" loading="lazy" />
                <% } else { %>
                  <div class="drink-img-placeholder">
                    <span><%= drink.subcategory === 'frozen' ? '🍦' : drink.subcategory === 'tea' ? '🍵' : '🧊' %></span>
                    <span><%= drink.name %></span>
                  </div>
                <% } %>
              </div>
              <div class="drink-card-top">
                <span class="drink-name"><%= drink.name %></span>
                <div class="drink-prices">
                  <% if (drink.prices && drink.prices.regular) { %><span class="drink-price-pill">R<%= drink.prices.regular %><span class="drink-size-label"> reg</span></span><% } %>
                  <% if (drink.prices && drink.prices.large)   { %><span class="drink-price-pill drink-price-large">R<%= drink.prices.large %><span class="drink-size-label"> lge</span></span><% } %>
                </div>
              </div>
              <% if (drink.isSpecial) { %><span class="drink-special-tag">✦ Special</span><% } %>
              <span class="order-add-hint">Tap to customise & add →</span>
            </div>
          </div>
          <% }) %>
        </div>
        <% if (!cold.length) { %><p class="drinks-empty">Menu coming soon — ask our barista!</p><% } %>
      </div>

      <!-- PASTRIES -->
      <div class="order-panel hidden" id="otab-pastries">
        <div class="drink-grid">
          <% pastries.forEach((pastry, idx) => { %>
          <div class="drink-card order-item-card" data-pastry-idx="<%= idx %>">
            <div class="drink-card-inner-wrap">
              <div class="drink-img-wrap">
                <% if (pastry.image) { %>
                  <img src="<%= pastry.image %>" alt="<%= pastry.name %>" loading="lazy" />
                <% } else { %>
                  <div class="drink-img-placeholder"><span>🥐</span><span><%= pastry.name %></span></div>
                <% } %>
              </div>
              <div class="drink-card-top">
                <span class="drink-name"><%= pastry.name %></span>
                <span class="drink-price-pill">R<%= pastry.price %></span>
              </div>
              <p style="font-size:0.78rem;color:rgba(44,44,44,0.55);line-height:1.4;margin-top:auto;"><%= pastry.description %></p>
              <span class="order-add-hint">Tap to add →</span>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

    </div>
  </section>
</main>

<!-- Floating cart button -->
<button class="cart-fab fab-hidden" id="cartFab" aria-label="View cart">
  <span class="cart-fab-icon">🛒</span>
  <span class="cart-fab-count" id="cartCount">0</span>
  <span class="cart-fab-total" id="cartTotal">R0</span>
</button>

<!-- ===== DRINK MODAL ===== -->
<div class="modal-overlay" id="drinkModalOverlay">
  <div class="modal-sheet" id="drinkModal">
    <button class="modal-close" id="drinkModalClose">✕</button>
    <div class="modal-img-wrap" id="modalImgWrap"></div>
    <div class="modal-body">
      <div class="modal-header-row">
        <div>
          <h2 class="modal-title" id="modalTitle"></h2>
          <p class="modal-subtitle" id="modalSubtitle"></p>
        </div>
        <span class="modal-price-badge" id="modalPriceBadge"></span>
      </div>
      <div class="modal-chips">
        <div class="modal-chip"><span class="chip-icon">🔥</span><div><span class="chip-label">Calories</span><span class="chip-val" id="chipCal">~120 kcal</span></div></div>
        <div class="modal-chip"><span class="chip-icon">🥛</span><div><span class="chip-label">Milk</span><span class="chip-val" id="chipMilk">Full cream</span></div></div>
        <div class="modal-chip"><span class="chip-icon">💪</span><div><span class="chip-label">Protein</span><span class="chip-val" id="chipProtein">6g</span></div></div>
        <div class="modal-chip"><span class="chip-icon">☕</span><div><span class="chip-label">Caffeine</span><span class="chip-val" id="chipCaff">~80mg</span></div></div>
      </div>

      <div class="modal-section-label">Size</div>
      <div class="size-slider-wrap" id="sizeSliderWrap"></div>

      <div class="modal-section-label">Milk alternative</div>
      <div class="alt-pills" id="milkPills">
        <button class="alt-pill active" data-val="Full cream">Full cream</button>
        <button class="alt-pill" data-val="Oat milk">Oat milk</button>
        <button class="alt-pill" data-val="Almond milk">Almond milk</button>
        <button class="alt-pill" data-val="Soy milk">Soy milk</button>
        <button class="alt-pill" data-val="Lactose free">Lactose free</button>
      </div>

      <div id="flavourSection" style="display:none;">
        <div class="modal-section-label">Flavour</div>
        <div class="alt-pills" id="flavourPills"></div>
      </div>

      <div class="modal-section-label">Sugar</div>
      <div class="alt-pills" id="sugarPills">
        <button class="alt-pill active" data-val="Regular">Regular</button>
        <button class="alt-pill" data-val="Less sugar">Less sugar</button>
        <button class="alt-pill" data-val="No sugar">No sugar</button>
      </div>

      <div class="modal-section-label">Special note <span style="opacity:0.4;font-weight:400;">(optional)</span></div>
      <textarea class="modal-notes" id="modalNotes" placeholder="e.g. extra hot, no foam…" rows="2"></textarea>
      <button class="btn btn-primary modal-add-btn" id="modalAddBtn">Add to cart — <span id="modalAddPrice"></span></button>
    </div>
  </div>
</div>

<!-- ===== PASTRY MODAL ===== -->
<div class="modal-overlay" id="pastryModalOverlay">
  <div class="modal-sheet" id="pastryModal">
    <button class="modal-close" id="pastryModalClose">✕</button>
    <div class="modal-img-wrap" id="pastryModalImgWrap"></div>
    <div class="modal-body">
      <div class="modal-header-row">
        <div>
          <h2 class="modal-title" id="pastryModalTitle"></h2>
          <p class="modal-subtitle" id="pastryModalDesc"></p>
        </div>
        <span class="modal-price-badge" id="pastryModalPrice"></span>
      </div>
      <div class="modal-chips">
        <div class="modal-chip"><span class="chip-icon">🔥</span><div><span class="chip-label">Calories</span><span class="chip-val">~280 kcal</span></div></div>
        <div class="modal-chip"><span class="chip-icon">🌾</span><div><span class="chip-label">Contains</span><span class="chip-val">Gluten, Dairy</span></div></div>
        <div class="modal-chip"><span class="chip-icon">🧈</span><div><span class="chip-label">Baked</span><span class="chip-val">Fresh daily</span></div></div>
        <div class="modal-chip"><span class="chip-icon">⏰</span><div><span class="chip-label">Best before</span><span class="chip-val">Same day</span></div></div>
      </div>
      <div class="modal-section-label">Quantity</div>
      <div class="qty-row">
        <button class="qty-circle" id="pastryMinus">−</button>
        <span class="qty-display" id="pastryQtyDisplay">1</span>
        <button class="qty-circle" id="pastryPlus">+</button>
      </div>
      <div class="modal-section-label">Note <span style="opacity:0.4;font-weight:400;">(optional)</span></div>
      <textarea class="modal-notes" id="pastryNotes" placeholder="e.g. warmed up…" rows="2"></textarea>
      <button class="btn btn-primary modal-add-btn" id="pastryAddBtn">Add to cart — <span id="pastryAddPrice"></span></button>
    </div>
  </div>
</div>

<!-- ===== CART SHEET ===== -->
<div class="modal-overlay" id="cartOverlay">
  <div class="cart-sheet">
    <div class="cart-header">
      <h2 class="cart-title">Your Order</h2>
      <button class="modal-close" id="cartClose">✕</button>
    </div>
    <div class="cart-items" id="cartItems"></div>
    <div class="cart-footer" id="cartFooter" style="display:none;">
      <div class="cart-total-row"><span>Total</span><span id="cartTotalFooter">R0</span></div>
      <p class="cart-note">Orders prepared fresh. Estimated wait 10–15 min.</p>
      <a href="/order/confirm" class="btn btn-primary" style="width:100%;text-align:center;display:block;">Confirm Order →</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
// ── Menu data injected safely from server ─────────────────────────
const LATTE_FLAVOURS = ['Plain','Vanilla','Hazelnut','Chocolate','Cinnamon','American Fudge','Caramel','Popcorn'];
const FREEZO_FLAVOURS = ['White Chocolate','Chai','Coffee','Chocolate','Salted Caramel'];
const FROZENYOG_FLAVOURS = [...LATTE_FLAVOURS,'Strawberry','Cherry','Litchi','Creamsoda','Apple'];

const HOT_DRINKS = <%- JSON.stringify(hot.map(d => ({
  name: d.name,
  category: 'hot',
  subcategory: d.subcategory,
  isSpecial: d.isSpecial,
  image: d.image ? '/images/drinks/' + d.image : null,
  prices: d.prices,
  sizes: [
    d.prices && d.prices.regular ? { label: 'Regular', ml: '250ml', price: d.prices.regular } : null,
    d.prices && d.prices.large   ? { label: 'Large',   ml: '350ml', price: d.prices.large   } : null
  ].filter(Boolean)
}))) %>;

const COLD_DRINKS = <%- JSON.stringify(cold.map(d => ({
  name: d.name,
  category: 'cold',
  subcategory: d.subcategory,
  isSpecial: d.isSpecial,
  image: d.image ? '/images/drinks/' + d.image : null,
  prices: d.prices,
  sizes: [
    d.prices && d.prices.regular ? { label: 'Regular', ml: '350ml', price: d.prices.regular } : null,
    d.prices && d.prices.large   ? { label: 'Large',   ml: '500ml', price: d.prices.large   } : null
  ].filter(Boolean)
}))) %>;

const PASTRIES = <%- JSON.stringify(pastries.map(p => ({
  name: p.name,
  description: p.description,
  price: p.price,
  image: p.image || null
}))) %>;

// Attach flavour list to cold drinks
COLD_DRINKS.forEach(d => {
  const n = d.name.toLowerCase();
  if (n.includes('frozen yogurt') || n.includes('froyo')) d.flavours = FROZENYOG_FLAVOURS;
  else if (n.includes('freezo')) d.flavours = FREEZO_FLAVOURS;
  else if (n.includes('latte'))  d.flavours = LATTE_FLAVOURS;
  else d.flavours = [];
});
HOT_DRINKS.forEach(d => {
  d.flavours = d.name.toLowerCase().includes('latte') ? LATTE_FLAVOURS : [];
});

// ── State ─────────────────────────────────────────────────────────
let cart = JSON.parse(sessionStorage.getItem('cl_cart') || '[]');
let activeDrink = null, activePastry = null;
let selSize = null, selMilk = 'Full cream', selFlavour = null, selSugar = 'Regular';
let pastryQty = 1;

const FILLER = {
  espresso:{ cal:'~80 kcal', protein:'1g', caff:'~150mg' },
  specialty:{ cal:'~180 kcal', protein:'5g', caff:'~95mg' },
  chocolate:{ cal:'~240 kcal', protein:'7g', caff:'~30mg' },
  tea:{ cal:'~20 kcal', protein:'0g', caff:'~40mg' },
  freezo:{ cal:'~310 kcal', protein:'4g', caff:'~60mg' },
  iced:{ cal:'~140 kcal', protein:'5g', caff:'~95mg' },
  frozen:{ cal:'~280 kcal', protein:'6g', caff:'~50mg' },
  other:{ cal:'~120 kcal', protein:'4g', caff:'~80mg' },
};

// ── Tabs ──────────────────────────────────────────────────────────
document.querySelectorAll('.order-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.order-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.order-panel').forEach(p => p.classList.add('hidden'));
    tab.classList.add('active');
    document.getElementById('otab-' + tab.dataset.tab).classList.remove('hidden');
  });
});

// ── Card click handlers ───────────────────────────────────────────
document.querySelectorAll('[data-drink-idx]').forEach(card => {
  card.addEventListener('click', () => {
    const idx = parseInt(card.dataset.drinkIdx);
    const cat = card.dataset.drinkCat;
    openDrinkModal(cat === 'hot' ? HOT_DRINKS[idx] : COLD_DRINKS[idx]);
  });
});
document.querySelectorAll('[data-pastry-idx]').forEach(card => {
  card.addEventListener('click', () => openPastryModal(PASTRIES[parseInt(card.dataset.pastryIdx)]));
});

// ── Drink modal ───────────────────────────────────────────────────
function openDrinkModal(drink) {
  activeDrink = drink;
  selMilk = 'Full cream'; selSugar = 'Regular';
  selFlavour = drink.flavours && drink.flavours.length ? drink.flavours[0] : null;

  // Image
  document.getElementById('modalImgWrap').innerHTML = drink.image
    ? `<img src="${drink.image}" alt="${drink.name}" class="modal-img" />`
    : `<div class="modal-img-placeholder"><span>${drink.category==='cold'?'🧊':'☕'}</span></div>`;

  document.getElementById('modalTitle').textContent = drink.name;
  document.getElementById('modalSubtitle').textContent =
    (drink.category === 'hot' ? 'Hot' : 'Cold') +
    (drink.subcategory ? ' · ' + drink.subcategory : '') +
    (drink.isSpecial ? ' · ✦ Special' : '');

  const info = FILLER[drink.subcategory] || FILLER.other;
  document.getElementById('chipCal').textContent = info.cal;
  document.getElementById('chipProtein').textContent = info.protein;
  document.getElementById('chipCaff').textContent = info.caff;
  document.getElementById('chipMilk').textContent = 'Full cream';

  buildSizeSlider(drink.sizes);
  buildPills('milkPills', ['Full cream','Oat milk','Almond milk','Soy milk','Lactose free'], 'Full cream', v => { selMilk = v; document.getElementById('chipMilk').textContent = v; });
  buildPills('sugarPills', ['Regular','Less sugar','No sugar'], 'Regular', v => { selSugar = v; });
  buildFlavourPills(drink.flavours || []);
  document.getElementById('modalNotes').value = '';

  openModal('drinkModalOverlay');
}

function buildSizeSlider(sizes) {
  const wrap = document.getElementById('sizeSliderWrap');
  if (!sizes || !sizes.length) {
    wrap.innerHTML = '<p style="font-size:0.8rem;opacity:0.4;">One size only</p>';
    selSize = null; return;
  }
  selSize = sizes[0];
  updateDrinkPrice();

  wrap.innerHTML = `
    <div class="size-track"><div class="size-track-fill" id="sizeFill" style="width:${sizes.length===1?100:0}%"></div></div>
    <div class="size-btns" id="sizeBtns">
      ${sizes.map((s,i) => `
        <button class="size-btn${i===0?' active':''}" data-idx="${i}">
          <span class="size-btn-label">${s.label}</span>
          <span class="size-btn-ml">${s.ml}</span>
          <span class="size-btn-price">R${s.price}</span>
        </button>`).join('')}
    </div>`;

  document.querySelectorAll('.size-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.idx);
      selSize = sizes[idx];
      document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const pct = sizes.length <= 1 ? 100 : (idx / (sizes.length-1)) * 100;
      document.getElementById('sizeFill').style.width = pct + '%';
      updateDrinkPrice();
    });
  });
}

function buildPills(containerId, values, defaultVal, onChange) {
  const wrap = document.getElementById(containerId);
  wrap.innerHTML = values.map((v,i) =>
    `<button class="alt-pill${v===defaultVal?' active':''}" data-val="${v}">${v}</button>`
  ).join('');
  wrap.querySelectorAll('.alt-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      wrap.querySelectorAll('.alt-pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      onChange(btn.dataset.val);
    });
  });
}

function buildFlavourPills(flavours) {
  const section = document.getElementById('flavourSection');
  if (!flavours.length) { section.style.display = 'none'; selFlavour = null; return; }
  section.style.display = 'block';
  selFlavour = flavours[0];
  buildPills('flavourPills', flavours, flavours[0], v => { selFlavour = v; });
}

function updateDrinkPrice() {
  const p = selSize ? `R${selSize.price}` : '';
  document.getElementById('modalPriceBadge').textContent = p;
  document.getElementById('modalAddPrice').textContent = p;
}

document.getElementById('modalAddBtn').addEventListener('click', () => {
  if (!selSize) return;
  cart.push({
    id: Date.now(), type: 'drink',
    name: activeDrink.name, size: selSize.label, ml: selSize.ml, price: selSize.price,
    milk: selMilk, flavour: selFlavour, sugar: selSugar,
    notes: document.getElementById('modalNotes').value.trim(),
    image: activeDrink.image, category: activeDrink.category,
  });
  saveCart(); closeModal('drinkModalOverlay');
  showToast(`${activeDrink.name} added`);
});

// ── Pastry modal ──────────────────────────────────────────────────
function openPastryModal(pastry) {
  activePastry = pastry; pastryQty = 1;
  document.getElementById('pastryQtyDisplay').textContent = '1';
  document.getElementById('pastryModalTitle').textContent = pastry.name;
  document.getElementById('pastryModalDesc').textContent = pastry.description || '';
  document.getElementById('pastryModalPrice').textContent = `R${pastry.price}`;
  document.getElementById('pastryAddPrice').textContent = `R${pastry.price}`;
  document.getElementById('pastryNotes').value = '';
  document.getElementById('pastryModalImgWrap').innerHTML = pastry.image
    ? `<img src="${pastry.image}" alt="${pastry.name}" class="modal-img" />`
    : `<div class="modal-img-placeholder"><span>🥐</span></div>`;
  openModal('pastryModalOverlay');
}

document.getElementById('pastryMinus').addEventListener('click', () => {
  pastryQty = Math.max(1, pastryQty - 1);
  document.getElementById('pastryQtyDisplay').textContent = pastryQty;
  document.getElementById('pastryAddPrice').textContent = `R${activePastry.price * pastryQty}`;
});
document.getElementById('pastryPlus').addEventListener('click', () => {
  pastryQty++;
  document.getElementById('pastryQtyDisplay').textContent = pastryQty;
  document.getElementById('pastryAddPrice').textContent = `R${activePastry.price * pastryQty}`;
});
document.getElementById('pastryAddBtn').addEventListener('click', () => {
  for (let i = 0; i < pastryQty; i++) {
    cart.push({ id: Date.now()+i, type:'pastry', name:activePastry.name, price:activePastry.price, image:activePastry.image, notes: i===0 ? document.getElementById('pastryNotes').value.trim() : '' });
  }
  saveCart(); closeModal('pastryModalOverlay');
  showToast(`${pastryQty}× ${activePastry.name} added`);
});

// ── Modal open/close ──────────────────────────────────────────────
function openModal(id) {
  document.getElementById(id).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = '';
}

// Close on overlay click
['drinkModalOverlay','pastryModalOverlay','cartOverlay'].forEach(id => {
  document.getElementById(id).addEventListener('click', function(e) {
    if (e.target === this) closeModal(id);
  });
});
document.getElementById('drinkModalClose').addEventListener('click', () => closeModal('drinkModalOverlay'));
document.getElementById('pastryModalClose').addEventListener('click', () => closeModal('pastryModalOverlay'));
document.getElementById('cartClose').addEventListener('click', () => closeModal('cartOverlay'));

// ── Cart ──────────────────────────────────────────────────────────
document.getElementById('cartFab').addEventListener('click', openCart);

function openCart() {
  renderCartItems();
  openModal('cartOverlay');
}

function renderCartItems() {
  const el = document.getElementById('cartItems');
  const footer = document.getElementById('cartFooter');
  if (!cart.length) {
    el.innerHTML = '<div class="cart-empty"><span>🛒</span><p>Your cart is empty</p></div>';
    footer.style.display = 'none'; return;
  }
  footer.style.display = 'block';
  el.innerHTML = cart.map((item, idx) => `
    <div class="cart-item">
      <div class="cart-item-img">${item.image ? `<img src="${item.image}" alt="${item.name}"/>` : `<span>${item.type==='pastry'?'🥐':item.category==='cold'?'🧊':'☕'}</span>`}</div>
      <div class="cart-item-body">
        <p class="cart-item-name">${item.name}</p>
        <div class="cart-item-opts">
          ${item.size ? `<span class="cart-opt-pill">${item.size} · ${item.ml}</span>` : ''}
          ${item.flavour ? `<span class="cart-opt-pill">${item.flavour}</span>` : ''}
          ${item.milk && item.milk!=='Full cream' ? `<span class="cart-opt-pill">${item.milk}</span>` : ''}
          ${item.sugar && item.sugar!=='Regular' ? `<span class="cart-opt-pill">${item.sugar}</span>` : ''}
        </div>
        ${item.notes ? `<p class="cart-item-note">"${item.notes}"</p>` : ''}
      </div>
      <div class="cart-item-right">
        <span class="cart-item-price">R${item.price}</span>
        <button class="cart-remove-btn" data-idx="${idx}">✕</button>
      </div>
    </div>`).join('');

  document.querySelectorAll('.cart-remove-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      cart.splice(parseInt(btn.dataset.idx), 1);
      saveCart(); renderCartItems();
    });
  });

  document.getElementById('cartTotalFooter').textContent = `R${cart.reduce((s,i)=>s+i.price,0)}`;
}

function saveCart() {
  sessionStorage.setItem('cl_cart', JSON.stringify(cart));
  const count = cart.length;
  const total = cart.reduce((s,i) => s+i.price, 0);
  document.getElementById('cartCount').textContent = count;
  document.getElementById('cartTotal').textContent = `R${total}`;
  document.getElementById('cartFab').classList.toggle('fab-hidden', count === 0);
}

// ── Toast ─────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.createElement('div');
  t.className = 'cl-toast'; t.textContent = msg;
  document.body.appendChild(t);
  requestAnimationFrame(() => t.classList.add('show'));
  setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 2200);
}

// ── Init ──────────────────────────────────────────────────────────
saveCart();
</script>

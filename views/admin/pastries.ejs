<%- include('./layout-top') %>

<div class="admin-page-header">
  <h1 class="admin-page-title">Pastries</h1>
  <p class="admin-page-sub">Add, edit, remove or toggle availability of pastries</p>
</div>

<% if (msg) { %>
<div class="admin-alert <%= msg.startsWith('Error') ? 'admin-alert-error' : 'admin-alert-success' %>"><%= msg %></div>
<% } %>

<div class="admin-two-col">

  <!-- Add pastry -->
  <div class="admin-card">
    <h3 class="admin-card-title">Add New Pastry</h3>
    <form action="/admin/pastries/add" method="POST" enctype="multipart/form-data" class="auth-form">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required placeholder="e.g. Almond Croissant" />
      </div>
      <div class="form-group">
        <label>Category</label>
        <select name="category" class="scan-input">
          <option value="croissant">🥐 Croissant</option>
          <option value="donut">🍩 Donut</option>
          <option value="cookie">🍪 Cookie</option>
          <option value="sandwich">🥪 Sandwich</option>
          <option value="quiche">🥧 Quiche</option>
          <option value="cake">🎂 Cake</option>
          <option value="other">🍴 Other</option>
        </select>
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" placeholder="Short description…" />
      </div>
      <div class="form-group">
        <label>Price (R)</label>
        <input type="number" name="price" required placeholder="e.g. 42" min="0" step="0.50" />
      </div>
      <div class="form-group">
        <label>Special item?</label>
        <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.25rem;">
          <input type="checkbox" name="isSpecial" id="isSpecialPastry" style="width:auto;" />
          <label for="isSpecialPastry" style="margin:0;font-size:0.85rem;">Mark as ✦ Special</label>
        </div>
      </div>
      <div class="form-group">
        <label>Photo</label>
        <div class="upload-zone" id="pastryUploadZone" onclick="document.getElementById('pastryImageFile').click()">
          <div class="upload-zone-inner" id="pastryUploadInner">
            <span class="upload-icon">📷</span>
            <span class="upload-label">Tap to upload photo</span>
            <span class="upload-hint">JPG, PNG or WebP · max 5MB</span>
          </div>
        </div>
        <input type="file" id="pastryImageFile" name="imageFile" accept="image/*" style="display:none;"
               onchange="previewUpload(this,'pastryUploadInner','pastryUploadZone')" />
      </div>
      <input type="hidden" name="order" value="99" />
      <button type="submit" class="btn btn-primary btn-full">Add Pastry</button>
    </form>
  </div>

  <!-- Pastry list -->
  <div>
    <% if (pastries.length === 0) { %>
      <div class="admin-card"><p class="admin-empty">No pastries yet — add one to get started.</p></div>
    <% } else { %>
      <% pastries.forEach(pastry => { %>
      <div class="admin-card admin-drink-row <%= !pastry.available ? 'drink-unavailable' : '' %>" style="margin-bottom:0.75rem;">
        <div style="display:flex;gap:1rem;align-items:center;">
          <% const pImg = pastry.image ? (pastry.image.startsWith('/') ? pastry.image : '/images/pastries/' + pastry.image) : null; %>
          <% if (pImg) { %>
          <img src="<%= pImg %>" alt="<%= pastry.name %>"
               style="width:52px;height:52px;object-fit:cover;border-radius:8px;flex-shrink:0;" />
          <% } else { %>
          <div style="width:52px;height:52px;background:var(--cream-dark);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">🥐</div>
          <% } %>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:0.5rem;flex-wrap:wrap;">
              <div>
                <strong style="font-size:0.92rem;"><%= pastry.name %></strong>
                <% if (pastry.isSpecial) { %><span class="admin-item-tag tag-special" style="margin-left:0.3rem;">✦</span><% } %>
                <% if (!pastry.available) { %><span class="admin-item-tag tag-off" style="margin-left:0.3rem;">Off</span><% } %>
                <p style="font-size:0.75rem;color:rgba(44,44,44,0.45);margin-top:0.1rem;">
                  <%= pastry.category || 'other' %> · <%= pastry.description %> · R<%= pastry.price %>
                </p>
              </div>
              <div style="display:flex;gap:0.4rem;flex-shrink:0;">
                <form action="/admin/pastries/toggle/<%= pastry._id %>" method="POST" style="display:inline;">
                  <button type="submit" class="admin-toggle-btn"><%= pastry.available ? 'Hide' : 'Show' %></button>
                </form>
                <button onclick="toggleEdit('pedit-<%= pastry._id %>')" class="admin-toggle-btn">Edit</button>
                <form action="/admin/pastries/delete/<%= pastry._id %>" method="POST"
                      onsubmit="return confirm('Delete <%= pastry.name %>?')" style="display:inline;">
                  <button type="submit" class="admin-toggle-btn" style="color:#c83232;border-color:#c83232;">Del</button>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- Inline edit -->
        <div id="pedit-<%= pastry._id %>" style="display:none;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(44,44,44,0.08);">
          <form action="/admin/pastries/edit/<%= pastry._id %>" method="POST" enctype="multipart/form-data">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
              <div class="form-group" style="grid-column:span 2;">
                <label>Name</label>
                <input type="text" name="name" value="<%= pastry.name %>" required class="scan-input" />
              </div>
              <div class="form-group" style="grid-column:span 2;">
                <label>Category</label>
                <select name="category" class="scan-input">
                  <option value="croissant" <%= pastry.category==='croissant'?'selected':'' %>>🥐 Croissant</option>
                  <option value="donut"     <%= pastry.category==='donut'    ?'selected':'' %>>🍩 Donut</option>
                  <option value="cookie"    <%= pastry.category==='cookie'   ?'selected':'' %>>🍪 Cookie</option>
                  <option value="sandwich"  <%= pastry.category==='sandwich' ?'selected':'' %>>🥪 Sandwich</option>
                  <option value="quiche"    <%= pastry.category==='quiche'   ?'selected':'' %>>🥧 Quiche</option>
                  <option value="cake"      <%= pastry.category==='cake'     ?'selected':'' %>>🎂 Cake</option>
                  <option value="other"     <%= (!pastry.category||pastry.category==='other')?'selected':'' %>>🍴 Other</option>
                </select>
              </div>
              <div class="form-group" style="grid-column:span 2;">
                <label>Description</label>
                <input type="text" name="description" value="<%= pastry.description || '' %>" class="scan-input" />
              </div>
              <div class="form-group">
                <label>Price (R)</label>
                <input type="number" name="price" value="<%= pastry.price %>" required class="scan-input" min="0" step="0.50" />
              </div>
              <div class="form-group">
                <input type="hidden" name="order" value="<%= pastry.order %>" />
              </div>
              <div class="form-group" style="grid-column:span 2;">
                <label>Replace photo</label>
                <div class="upload-zone upload-zone-sm" id="pez-<%= pastry._id %>"
                     onclick="document.getElementById('pef-<%= pastry._id %>').click()">
                  <div class="upload-zone-inner" id="pei-<%= pastry._id %>">
                    <span class="upload-icon" style="font-size:1.2rem;">📷</span>
                    <span class="upload-label" style="font-size:0.78rem;">Tap to choose new photo</span>
                  </div>
                </div>
                <input type="file" id="pef-<%= pastry._id %>" name="imageFile" accept="image/*" style="display:none;"
                       onchange="previewUpload(this,'pei-<%= pastry._id %>','pez-<%= pastry._id %>')" />
              </div>
              <div class="form-group">
                <label>Available</label>
                <select name="available" class="scan-input">
                  <option value="true"  <%= pastry.available?'selected':'' %>>Yes</option>
                  <option value="false" <%= !pastry.available?'selected':'' %>>No</option>
                </select>
              </div>
              <div class="form-group" style="display:flex;align-items:center;gap:0.5rem;">
                <input type="checkbox" name="isSpecial" id="isp-<%= pastry._id %>"
                       style="width:auto;" <%= pastry.isSpecial?'checked':'' %> />
                <label for="isp-<%= pastry._id %>" style="margin:0;font-size:0.85rem;">✦ Special</label>
              </div>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:0.75rem;width:100%;">Save Changes</button>
          </form>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>

</div>

<script>
function toggleEdit(id) {
  const el = document.getElementById(id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
function previewUpload(input, innerId, zoneId) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById(innerId).innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />`;
    document.getElementById(zoneId).style.border = '2px solid var(--maroon)';
  };
  reader.readAsDataURL(input.files[0]);
}
</script>

<%- include('./layout-bottom') %>

<%- include('./layout-top') %>

<div class="admin-page-header">
  <h1 class="admin-page-title">History</h1>
  <p class="admin-page-sub">Who added drinks, for whom, and which rewards were redeemed</p>
</div>

<div class="admin-scan-tabs" style="margin-bottom:1rem;">
  <a href="/admin/history" class="admin-scan-tab <%= !activeType ? 'active' : '' %>" style="text-decoration:none;">All</a>
  <a href="/admin/history?type=drinks_added" class="admin-scan-tab <%= activeType === 'drinks_added' ? 'active' : '' %>" style="text-decoration:none;">☕ Stamps Given</a>
  <a href="/admin/history?type=reward_redeemed" class="admin-scan-tab <%= activeType === 'reward_redeemed' ? 'active' : '' %>" style="text-decoration:none;">🎁 Rewards</a>
  <a href="/admin/history?type=voucher_redeemed" class="admin-scan-tab <%= activeType === 'voucher_redeemed' ? 'active' : '' %>" style="text-decoration:none;">🎫 Vouchers</a>
</div>

<% if (logs.length === 0) { %>
<div class="admin-card"><p class="admin-empty">Nothing here yet — entries appear as soon as drinks are scanned or rewards redeemed.</p></div>
<% } else { %>
<div class="admin-card" style="padding:0.5rem 0;">
  <% logs.forEach(log => { %>
  <div class="history-row">
    <span class="history-icon">
      <%= log.type === 'drinks_added' ? '☕' : log.type === 'voucher_redeemed' ? '🎫' : '🎁' %>
    </span>
    <div class="history-body">
      <% if (log.type === 'drinks_added') { %>
        <p class="history-main">
          <strong><%= log.quantity %> stamp<%= log.quantity !== 1 ? 's' : '' %></strong> given to
          <strong><%= log.userName %></strong>
          <% if (log.totalAfter !== null) { %><span class="history-total">→ <%= log.totalAfter %> total</span><% } %>
        </p>
      <% } else { %>
        <p class="history-main">
          <strong><%= log.userName %></strong> redeemed:
          <%= log.rewardDescription || log.rewardType %>
        </p>
      <% } %>
      <p class="history-sub">
        by <%= log.adminName || 'Staff' %> ·
        <%= new Date(log.at).toLocaleString('en-ZA', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
      </p>
    </div>
  </div>
  <% }) %>
</div>
<p style="font-size:0.75rem;color:rgba(44,44,44,0.4);margin-top:0.75rem;">Showing the most recent <%= logs.length %> entries.</p>
<% } %>

<style>
.history-row {
  display: flex; gap: 0.85rem; align-items: flex-start;
  padding: 0.75rem 1.25rem;
  border-bottom: 1px solid rgba(44,44,44,0.05);
}
.history-row:last-child { border-bottom: none; }
.history-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 0.1rem; }
.history-main { font-size: 0.88rem; }
.history-total { color: var(--maroon); font-size: 0.8rem; margin-left: 0.25rem; }
.history-sub { font-size: 0.72rem; color: rgba(44,44,44,0.45); margin-top: 0.15rem; }
</style>

<%- include('./layout-bottom') %>

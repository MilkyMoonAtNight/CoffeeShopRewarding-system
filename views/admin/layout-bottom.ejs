  </main>
</div>

<script>
const toggle = document.getElementById('adminNavToggle');
const drawer = document.getElementById('adminNavDrawer');
if (toggle && drawer) {
  toggle.addEventListener('click', () => {
    toggle.classList.toggle('open');
    drawer.classList.toggle('open');
  });
  // Close drawer when a nav link is clicked (mobile)
  drawer.querySelectorAll('.admin-nav-item').forEach(link => {
    link.addEventListener('click', () => {
      toggle.classList.remove('open');
      drawer.classList.remove('open');
    });
  });
}

// Accordion groups — click label to expand/collapse
document.querySelectorAll('.admin-nav-group-label').forEach(label => {
  label.addEventListener('click', () => {
    const group = label.parentElement;
    // Close siblings
    document.querySelectorAll('.admin-nav-group').forEach(g => {
      if (g !== group) g.classList.remove('open');
    });
    group.classList.toggle('open');
  });
});
// Auto-open the group that contains the active link (JS fallback for browsers without :has())
document.querySelectorAll('.admin-nav-group').forEach(group => {
  if (group.querySelector('.admin-nav-item.active')) group.classList.add('open');
});
</script>
<script src="/js/main.js"></script>
</body></html>

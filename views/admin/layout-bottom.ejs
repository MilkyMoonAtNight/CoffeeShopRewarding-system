  </main>
</div>

<script>
const toggle = document.getElementById('adminNavToggle');
const drawer = document.getElementById('adminNavDrawer');

// Collapse the whole nav — close the mobile drawer and any open group
function collapseAdminNav() {
  if (toggle) toggle.classList.remove('open');
  if (drawer) drawer.classList.remove('open');
  document.querySelectorAll('.admin-nav-group.open').forEach(g => g.classList.remove('open'));
}

if (toggle && drawer) {
  toggle.addEventListener('click', () => {
    toggle.classList.toggle('open');
    drawer.classList.toggle('open');
  });
  // Selecting an actual page link collapses the whole nav
  drawer.querySelectorAll('a.admin-nav-item').forEach(link => {
    link.addEventListener('click', collapseAdminNav);
  });
}

// Accordion groups — click label to expand/collapse (siblings close)
document.querySelectorAll('.admin-nav-group-label').forEach(label => {
  label.addEventListener('click', () => {
    const group = label.parentElement;
    document.querySelectorAll('.admin-nav-group').forEach(g => {
      if (g !== group) g.classList.remove('open');
    });
    group.classList.toggle('open');
  });
});

// Stop accidental mouse-wheel scrolling from changing number inputs
// (this is what turned a typed "25" into "24.5" on the price fields)
document.addEventListener('wheel', e => {
  if (document.activeElement === e.target && e.target.type === 'number') {
    e.target.blur();
  }
}, { passive: true });
</script>
<script src="/js/main.js"></script>
</body></html>

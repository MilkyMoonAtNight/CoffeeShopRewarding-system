<%- include('../partials/head') %>

<main style="min-height:100vh;background:var(--black);display:flex;align-items:center;justify-content:center;padding:2rem;">
  <div style="max-width:400px;width:100%;text-align:center;">

    <img src="/images/logo.png" alt="Con Leche" style="width:64px;margin:0 auto 1.5rem;" />

    <% if (state === 'success') { %>
      <div class="nfc-card nfc-card-in">
        <div class="nfc-icon">☕</div>
        <h2 class="nfc-title">Checked In!</h2>
        <p class="nfc-msg"><%= message %></p>
        <p class="nfc-sub">Tap the tag again when you leave to check out.</p>
        <a href="/admin/dashboard" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Dashboard →</a>
      </div>

    <% } else if (state === 'checkout') { %>
      <div class="nfc-card nfc-card-out">
        <div class="nfc-icon">🐾</div>
        <h2 class="nfc-title">Checked Out!</h2>
        <p class="nfc-msg"><%= message %></p>
        <a href="/admin/dashboard" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Dashboard →</a>
      </div>

    <% } else if (state === 'already') { %>
      <div class="nfc-card nfc-card-done">
        <div class="nfc-icon">✓</div>
        <h2 class="nfc-title">All Done Today</h2>
        <p class="nfc-msg"><%= message %></p>
        <a href="/admin/dashboard" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Dashboard →</a>
      </div>

    <% } else { %>
      <div class="nfc-card nfc-card-err">
        <div class="nfc-icon">✗</div>
        <h2 class="nfc-title">Invalid Link</h2>
        <p class="nfc-msg"><%= message %></p>
      </div>
    <% } %>

  </div>
</main>

</body></html>

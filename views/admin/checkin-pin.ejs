<%- include('../partials/head') %>

<main style="min-height:100vh;background:var(--black);display:flex;align-items:center;justify-content:center;padding:2rem;">
  <div style="max-width:380px;width:100%;text-align:center;">

    <img src="/images/logo.png" alt="Con Leche" style="width:56px;margin:0 auto 1.5rem;" />
    <h2 style="font-family:var(--font-nimbus);color:var(--cream);font-size:1.6rem;margin-bottom:0.4rem;">PIN Check-in</h2>
    <p style="color:rgba(253,246,237,0.4);font-size:0.82rem;margin-bottom:1.75rem;">Ask your manager for today's 4-digit PIN</p>

    <% if (success) { %>
    <div style="background:rgba(91,158,110,0.1);border:1px solid rgba(91,158,110,0.3);border-radius:var(--radius-lg);padding:2rem;margin-bottom:1.5rem;">
      <div style="font-size:2.5rem;margin-bottom:0.75rem;">✓</div>
      <p style="color:rgba(253,246,237,0.8);"><%= success %></p>
      <a href="/admin/dashboard" class="btn btn-primary" style="margin-top:1.25rem;display:inline-flex;">Dashboard →</a>
    </div>
    <% } else { %>

    <% if (error) { %>
    <div style="background:rgba(200,50,50,0.1);border:1px solid rgba(200,50,50,0.2);border-radius:var(--radius);padding:0.75rem;margin-bottom:1rem;color:#c83232;font-size:0.85rem;">
      <%= error %>
    </div>
    <% } %>

    <form action="/admin/checkin-pin" method="POST" style="display:flex;flex-direction:column;gap:1rem;">
      <input
        type="text"
        name="pin"
        maxlength="4"
        placeholder="_ _ _ _"
        autocomplete="off"
        style="text-align:center;font-size:2rem;letter-spacing:0.4em;font-weight:700;padding:1rem;border:2px solid rgba(255,255,255,0.1);border-radius:var(--radius);background:rgba(255,255,255,0.05);color:var(--cream);font-family:var(--font-body);width:100%;"
        autofocus
      />
      <button type="submit" class="btn btn-primary btn-full" style="font-size:1rem;">Check In</button>
    </form>

    <% } %>

    <p style="margin-top:1.5rem;">
      <a href="/admin/dashboard" style="color:rgba(253,246,237,0.2);font-size:0.75rem;">← Back to dashboard</a>
    </p>
  </div>
</main>

</body></html>

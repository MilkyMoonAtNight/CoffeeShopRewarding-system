<%- include('../partials/head') %>
<%- include('./layout-top') %>

<div class="admin-page-header">
  <h1 class="admin-page-title">🕐 Check In / Out</h1>
  <p class="admin-page-sub">Use the same PIN to check in at the start and check out at the end of your shift</p>
</div>

<div style="max-width:520px;">

  <% if (success) { %>
  <div class="checkin-success-card <%= action === 'checkout' ? 'checkin-success-out' : '' %>" style="margin-bottom:1rem;">
    <div class="checkin-success-icon"><%= action === 'checkout' ? '🐾' : action === 'done' ? '✓' : '☕' %></div>
    <h3 class="checkin-success-title"><%= action === 'checkout' ? 'Checked Out!' : action === 'done' ? 'All Done Today' : 'Checked In!' %></h3>
    <p class="checkin-success-msg"><%= success %></p>
    <% if (action === 'checkin') { %>
    <p style="font-size:0.78rem;color:rgba(44,44,44,0.45);margin-top:0.4rem;">Enter the PIN again at the end of your shift to check out.</p>
    <% } %>
  </div>
  <% } %>

  <!-- PIN form — hide if both done -->
  <% if (action !== 'done') { %>
  <div class="admin-card" style="margin-bottom:1rem;">
    <% if (!success) { %><h3 class="admin-card-title"><%= action === 'checkin' ? 'Check Out' : 'Check In' %></h3><% } %>
    <% if (error) { %>
    <div class="admin-alert admin-alert-error" style="margin-bottom:1rem;"><%= error %></div>
    <% } %>
    <form action="/admin/checkin-pin" method="POST">
      <div class="form-group">
        <label><%= success ? 'Check Out PIN' : 'Enter PIN' %></label>
        <input
          type="text" name="pin" maxlength="4"
          placeholder="_ _ _ _" autocomplete="off"
          class="pin-input"
          <% if (!success) { %>autofocus<% } %>
        />
        <span class="form-hint">Ask your manager for today's 4-digit PIN</span>
      </div>
      <button type="submit" class="btn btn-primary btn-full" style="margin-top:0.5rem;">
        <%= success && action === 'checkin' ? '← Check Out' : '✓ Check In' %>
      </button>
    </form>
  </div>
  <% } %>

  <!-- Attendance table -->
  <div class="admin-card">
    <h3 class="admin-card-title">My Attendance — Last 7 Days</h3>
    <% if (!myCheckIns || myCheckIns.length === 0) { %>
      <p class="admin-empty">No check-ins recorded yet.</p>
    <% } else { %>
    <div class="checkin-table-wrap">
      <table class="checkin-table">
        <thead>
          <tr>
            <th>Day</th>
            <th>In</th>
            <th>Out</th>
            <th>Duration</th>
          </tr>
        </thead>
        <tbody>
          <% myCheckIns.forEach(c => { %>
          <%
            let duration = '—';
            if (c.checkedOutAt) {
              const mins = Math.round((new Date(c.checkedOutAt) - new Date(c.checkedInAt)) / 1000 / 60);
              const hrs = Math.floor(mins / 60);
              const rem = mins % 60;
              duration = hrs > 0 ? hrs + 'h ' + rem + 'm' : mins + 'm';
            }
          %>
          <tr>
            <td class="checkin-td-day">
              <%= c.checkedInAt.toLocaleDateString('en-ZA', { weekday: 'short', day: 'numeric', month: 'short' }) %>
            </td>
            <td class="checkin-td-time"><%= c.checkedInAt.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) %></td>
            <td class="checkin-td-time <%= c.checkedOutAt ? '' : 'checkin-td-absent' %>">
              <%= c.checkedOutAt ? new Date(c.checkedOutAt).toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' }) : '—' %>
            </td>
            <td><span class="checkin-badge"><%= duration %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

</div>

<%- include('./layout-bottom') %>

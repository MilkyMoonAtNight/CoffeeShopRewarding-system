<%- include('./layout-top') %>

<div class="admin-page-header">
  <h1 class="admin-page-title">Scan QR Code</h1>
  <p class="admin-page-sub">Record a drink or confirm a customer reward claim</p>
</div>

<div class="admin-scan-tabs">
  <button class="admin-scan-tab active" data-panel="camera">📷 Camera Scan</button>
  <button class="admin-scan-tab" data-panel="record">⌨️ Manual Entry</button>
  <button class="admin-scan-tab" data-panel="confirm">🎁 Confirm Claim</button>
</div>

<div class="admin-scan-layout">

  <!-- ── CAMERA SCAN ── -->
  <div class="admin-scan-panel" id="panel-camera">
    <div class="admin-card" style="padding:0;overflow:hidden;">

      <!-- Camera view -->
      <div id="camera-wrap">
        <video id="qr-video" playsinline></video>

        <!-- Scanning frame overlay -->
        <div class="qr-overlay">
          <div class="qr-frame" id="qrFrame">
            <span class="qr-corner qr-tl"></span>
            <span class="qr-corner qr-tr"></span>
            <span class="qr-corner qr-bl"></span>
            <span class="qr-corner qr-br"></span>
            <div class="qr-laser" id="qrLaser"></div>
          </div>
        </div>

        <!-- Live status badge inside the camera -->
        <div class="camera-live-badge" id="liveBadge">
          <span class="live-dot" id="liveDot"></span>
          <span class="live-text" id="liveText">Starting…</span>
        </div>
      </div>

      <!-- Animated scanning text below camera -->
      <div class="camera-status-bar" id="statusBar">
        <div class="scan-anim-wrap" id="scanAnimWrap">
          <span class="scan-anim-icon">📷</span>
          <span class="scan-anim-text" id="scanAnimText">Starting camera</span>
          <span class="scan-anim-dots" id="scanDots"></span>
        </div>
      </div>

      <!-- ── Live diagnostics (tap header to expand) ── -->
      <div class="scan-diag" id="scanDiag">
        <button type="button" class="scan-diag-head" onclick="document.getElementById('scanDiag').classList.toggle('open')">
          <span>🔧 Live diagnostics</span>
          <span class="scan-diag-toggle">tap</span>
        </button>
        <div class="scan-diag-body">
          <div class="scan-diag-row"><span>jsQR library</span><b id="dgLib">checking…</b></div>
          <div class="scan-diag-row"><span>Camera</span><b id="dgCam">—</b></div>
          <div class="scan-diag-row"><span>Resolution</span><b id="dgRes">—</b></div>
          <div class="scan-diag-row"><span>Decode rate</span><b id="dgFps">—</b></div>
          <div class="scan-diag-row"><span>Frames decoded</span><b id="dgFrames">0</b></div>
          <div class="scan-diag-row"><span>Last QR seen</span><b id="dgLast">none yet</b></div>
          <div class="scan-diag-row scan-diag-err" id="dgErrRow" style="display:none;"><span>Error</span><b id="dgErr">—</b></div>
        </div>
      </div>

      <button id="camera-toggle" class="btn btn-outline" style="margin:0.75rem 1rem 1rem;width:calc(100% - 2rem);">
        Stop Camera
      </button>
    </div>

    <!-- Result card -->
    <div id="camera-result" class="admin-card scan-result-card" style="display:none;"></div>
  </div>

  <!-- ── MANUAL ENTRY ── -->
  <div class="admin-scan-panel hidden" id="panel-record">
    <div class="admin-card">
      <form action="/admin/scan" method="POST">
        <input type="hidden" name="panel" value="record" />
        <div class="form-group">
          <label>QR Token</label>
          <input type="text" name="qrCode" required placeholder="Paste QR token…" class="scan-input" />
          <span class="form-hint">From the customer's battlepass screen</span>
        </div>
        <div class="form-group">
          <label>Number of Drinks</label>
          <div class="qty-selector">
            <button type="button" class="qty-btn" onclick="changeQty(-1)">−</button>
            <input type="number" name="quantity" id="qtyInput" value="1" min="1" max="20" class="qty-input" readonly />
            <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-full">✓ Record Drink</button>
      </form>
    </div>
    <% if (result && result.panel === 'record') { %>
    <div class="admin-card scan-result-card <%= result.success ? 'scan-success-card' : 'scan-error-card' %>">
      <% if (result.success) { %>
        <div class="scan-result-icon">✓</div>
        <h3><%= result.user.name %></h3>
        <% if (result.qty > 1) { %><p style="font-size:0.85rem;opacity:0.6;"><%= result.qty %> drinks recorded</p><% } %>
        <div class="scan-result-stats">
          <div class="scan-result-stat"><span class="scan-result-num"><%= result.user.totalDrinks %></span><span class="scan-result-lbl">Total drinks</span></div>
          <div class="scan-result-stat"><span class="scan-result-num"><%= result.user.tier %></span><span class="scan-result-lbl">Tier</span></div>
        </div>
        <% (result.newRewards || (result.newReward ? [result.newReward] : [])).forEach(r => { %>
        <div class="scan-new-reward">
          <span class="scan-reward-icon"><%= r.type === 'free_drink' ? '☕' : r.type === 'voucher' ? '🎫' : '🎁' %></span>
          <div><strong><%= r.type === 'voucher' ? 'Voucher added!' : 'Reward unlocked!' %></strong><p><%= r.description %></p></div>
        </div>
        <% }) %>
      <% } else { %>
        <div class="scan-result-icon scan-result-icon-err">✗</div>
        <h3>Not found</h3><p><%= result.message %></p>
      <% } %>
    </div>
    <% } %>
  </div>

  <!-- ── CONFIRM CLAIM ── -->
  <div class="admin-scan-panel hidden" id="panel-confirm">
    <div class="admin-card">
      <p style="margin-bottom:1.25rem;font-size:0.9rem;color:rgba(44,44,44,0.6);">Customer taps <strong>Claim</strong> on their battlepass. <strong>Scan their reward QR</strong> below — it identifies the reward automatically — then enter the 4-digit code they read out.</p>

      <div class="form-group">
        <label>Customer reward QR</label>
        <div class="confirm-scan-row">
          <input type="text" id="confirmQr" placeholder="Scan the reward QR…" class="scan-input" readonly />
          <button type="button" class="btn btn-outline confirm-scan-btn" id="confirmScanBtn" onclick="toggleConfirmScan()">📷 Scan</button>
        </div>
        <input type="hidden" id="confirmRewardId" />
        <!-- Mini camera for the confirm panel (hidden until "Scan" is tapped) -->
        <div id="confirmCamWrap" class="confirm-cam-wrap" style="display:none;">
          <video id="confirmVideo" playsinline></video>
          <div class="confirm-cam-status" id="confirmCamStatus">Starting camera…</div>
        </div>
      </div>

      <!-- Reward identity + validity, filled after a successful scan -->
      <div id="confirmReward" class="confirm-reward" style="display:none;"></div>

      <div class="form-group">
        <label>4-Digit Code</label>
        <input type="text" id="confirmCode" inputmode="numeric" placeholder="e.g. 4827" class="scan-input"
               maxlength="4" style="font-size:1.5rem;letter-spacing:0.3em;text-align:center;" />
      </div>
      <button type="button" id="confirmClaimBtn" class="btn btn-primary btn-full" onclick="submitConfirmClaim()" disabled>✓ Confirm Claim</button>
    </div>

    <!-- Result, JS-populated -->
    <div id="confirmResult" class="admin-card scan-result-card" style="display:none;"></div>
  </div>

</div>

<script src="/js/jsQR.min.js"></script>
<!-- ── Quantity popup (appears after a successful scan) ── -->
<div class="qty-modal-overlay" id="qtyModal">
  <div class="qty-modal">
    <div class="qty-modal-head">
      <span style="font-size:1.8rem;">☕</span>
      <h3 id="qmName">Customer</h3>
      <p class="qty-modal-sub"><span id="qmDrinks">0</span> drinks · <span id="qmTier">Kitten</span></p>
    </div>
    <p class="qty-modal-label">How many drinks?</p>
    <div class="qty-selector" style="justify-content:center;">
      <button type="button" class="qty-btn" onclick="changeModalQty(-1)">−</button>
      <input type="number" id="qmQty" value="1" min="1" max="20" class="qty-input" readonly />
      <button type="button" class="qty-btn" onclick="changeModalQty(1)">+</button>
    </div>
    <div class="qty-quick-row">
      <button type="button" class="qty-quick" onclick="setModalQty(1)">1</button>
      <button type="button" class="qty-quick" onclick="setModalQty(2)">2</button>
      <button type="button" class="qty-quick" onclick="setModalQty(3)">3</button>
      <button type="button" class="qty-quick" onclick="setModalQty(5)">5</button>
      <button type="button" class="qty-quick" onclick="setModalQty(10)">10</button>
    </div>
    <button id="qmConfirmBtn" class="btn btn-primary btn-full" onclick="confirmAddDrinks()">Add Drinks ✓</button>
    <button class="btn btn-outline btn-full" style="margin-top:0.5rem;border-color:rgba(44,44,44,0.2);color:var(--charcoal);" onclick="closeQtyModal()">Cancel</button>
  </div>
</div>

<script>
// ── Tabs ──────────────────────────────────────────────────────────
document.querySelectorAll('.admin-scan-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.admin-scan-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.admin-scan-panel').forEach(p => p.classList.add('hidden'));
    tab.classList.add('active');
    document.getElementById('panel-' + tab.dataset.panel).classList.remove('hidden');
    if (typeof stopConfirmScan === 'function') stopConfirmScan(); // release confirm camera on any switch
    if (tab.dataset.panel !== 'camera') stopCamera();
    else startCamera();
  });
});

// ── State ─────────────────────────────────────────────────────────
let stream    = null;
let scanning  = false;
let cooldown  = false;
let lastScanned = null;
let dotInterval = null;
let dotCount  = 0;
let framesSinceCode = 0;
let frameCount = 0;

const video      = document.getElementById('qr-video');
const resultBox  = document.getElementById('camera-result');
const toggleBtn  = document.getElementById('camera-toggle');
const liveDot    = document.getElementById('liveDot');
const liveText   = document.getElementById('liveText');
const scanText   = document.getElementById('scanAnimText');
const scanDots   = document.getElementById('scanDots');
const qrFrame    = document.getElementById('qrFrame');
const qrLaser    = document.getElementById('qrLaser');

// ── Live diagnostics ──────────────────────────────────────────────
const dg = {
  lib:    document.getElementById('dgLib'),
  cam:    document.getElementById('dgCam'),
  res:    document.getElementById('dgRes'),
  fps:    document.getElementById('dgFps'),
  frames: document.getElementById('dgFrames'),
  last:   document.getElementById('dgLast'),
  err:    document.getElementById('dgErr'),
  errRow: document.getElementById('dgErrRow'),
};
let decodedFrames = 0;
let fpsWindow = [];

function dgError(msg) {
  dg.errRow.style.display = 'flex';
  dg.err.textContent = msg;
}

// Verify the QR library actually loaded. If the CSP or network blocks it,
// fail loudly here instead of letting the scan loop die silently.
const jsQRReady = (typeof jsQR === 'function');
if (jsQRReady) {
  dg.lib.textContent = 'loaded ✓';
  dg.lib.style.color = '#1D9E75';
} else {
  dg.lib.textContent = 'NOT LOADED ✗';
  dg.lib.style.color = '#c83232';
  dgError('QR library blocked — check CSP / network. Use Manual Entry.');
  document.getElementById('scanDiag').classList.add('open');
}

// ── Animated dots ─────────────────────────────────────────────────
function startDotAnim(msg) {
  stopDotAnim();
  scanText.textContent = msg;
  scanDots.textContent = '';
  dotCount = 0;
  dotInterval = setInterval(() => {
    dotCount = (dotCount + 1) % 4;
    scanDots.textContent = '.'.repeat(dotCount);
  }, 400);
}
function stopDotAnim() {
  if (dotInterval) clearInterval(dotInterval);
  dotInterval = null;
}

// ── Status helpers ────────────────────────────────────────────────
function setStatus(state, msg) {
  // state: 'idle' | 'scanning' | 'found' | 'error' | 'off'
  liveText.textContent = msg;
  liveDot.className = 'live-dot live-dot-' + state;

  const colors = {
    idle:     'rgba(44,44,44,0.5)',
    scanning: '#1D9E75',
    found:    '#581217',
    error:    '#c83232',
    off:      'rgba(44,44,44,0.3)',
  };
  liveDot.style.background = colors[state] || colors.idle;

  if (state === 'scanning') startDotAnim('Scanning');
  else if (state === 'found') { stopDotAnim(); scanText.textContent = 'Code found!'; scanDots.textContent = ''; }
  else if (state === 'error') { stopDotAnim(); scanText.textContent = msg; scanDots.textContent = ''; }
  else if (state === 'off')   { stopDotAnim(); scanText.textContent = 'Camera off'; scanDots.textContent = ''; }
  else { startDotAnim('Starting camera'); }
}

// ── Camera ────────────────────────────────────────────────────────
async function startCamera() {
  setStatus('idle', 'Starting…');
  if (!jsQRReady) {                       // no point opening the camera if we can't decode
    setStatus('error', 'QR library not loaded — use Manual Entry');
    return;
  }
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    dg.cam.textContent = 'unsupported';
    dgError('getUserMedia unavailable — needs HTTPS + a modern browser.');
    setStatus('error', 'Camera API unavailable — use Manual Entry');
    return;
  }
  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } }
    });
    video.srcObject = stream;
    await video.play();
    scanning = true;
    dg.cam.textContent = 'live ✓';
    dg.cam.style.color = '#1D9E75';
    toggleBtn.textContent = 'Stop Camera';
    setStatus('scanning', 'Scanning');
    requestAnimationFrame(tick);
  } catch (e) {
    dg.cam.textContent = 'denied/failed';
    dg.cam.style.color = '#c83232';
    dgError((e && e.name ? e.name + ': ' : '') + (e && e.message ? e.message : 'camera error'));
    setStatus('error', 'Camera unavailable — use Manual Entry');
    toggleBtn.style.display = 'none';
  }
}

function stopCamera() {
  scanning = false;
  if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
  video.srcObject = null;
  toggleBtn.textContent = 'Start Camera';
  setStatus('off', 'Camera off');
  qrFrame.classList.remove('qr-frame-found');
  qrLaser.style.display = 'block';
}

toggleBtn.addEventListener('click', () => {
  if (stream) stopCamera(); else startCamera();
});

// ── Scan loop ─────────────────────────────────────────────────────
const offscreen = document.createElement('canvas');
const offCtx    = offscreen.getContext('2d');

function tick() {
  if (!scanning) return;

  if (video.readyState === video.HAVE_ENOUGH_DATA && video.videoWidth > 0) {
    const w = video.videoWidth;
    const h = video.videoHeight;
    offscreen.width  = w;
    offscreen.height = h;
    offCtx.drawImage(video, 0, 0, w, h);
    frameCount++;

    // ── diagnostics: resolution, decode rate, frame counter ──
    const nowMs = performance.now();
    fpsWindow.push(nowMs);
    while (fpsWindow.length && nowMs - fpsWindow[0] > 1000) fpsWindow.shift();
    decodedFrames++;
    if (frameCount % 10 === 0) {
      dg.res.textContent    = w + '×' + h;
      dg.fps.textContent    = fpsWindow.length + ' fps';
      dg.frames.textContent = decodedFrames;
    }
    // Show frame count every 60 frames so barista knows camera is live
    if (frameCount % 60 === 0 && scanning && !cooldown) {
      liveText.textContent = `Scanning (${w}×${h})`;
    }

    let code = null;
    try {
      // Try full frame first
      code = tryDecode(offCtx, 0, 0, w, h);
      // If not found, try centre crop (QR usually held in middle of frame)
      if (!code) {
        const cropSize = Math.min(w, h) * 0.7;
        const cx = (w - cropSize) / 2;
        const cy = (h - cropSize) / 2;
        code = tryDecode(offCtx, cx, cy, cropSize, cropSize);
      }
    } catch (err) {
      // A throw here (e.g. jsQR missing) would otherwise kill the loop silently.
      dgError('decode: ' + err.message);
      setStatus('error', 'Decode error — see diagnostics');
      return; // stop scheduling; the error is now visible on screen
    }

    if (code && !cooldown) {
      const raw   = code.data;
      const token = raw.startsWith('conleche:') ? raw.slice('conleche:'.length) : raw;

      if (token !== lastScanned) {
        lastScanned = token;
        cooldown    = true;
        framesSinceCode = 0;

        qrFrame.classList.add('qr-frame-found');
        qrLaser.style.display = 'none';
        setStatus('found', 'Code detected!');

        lookupCustomer(token);

        // Cooldown released when the popup closes (see closeQtyModal)
      }
    } else if (!code) {
      framesSinceCode++;
      if (framesSinceCode > 30 && !cooldown && scanning) {
        setStatus('scanning', 'Scanning');
      }
    }
  }
  requestAnimationFrame(tick);
}

function tryDecode(ctx, x, y, w, h) {
  const imageData = ctx.getImageData(x, y, w, h);
  const result = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: 'attemptBoth' });
  if (result) {
    // Show raw decoded value in status bar + diagnostics so we can see what jsQR found
    console.log('jsQR decoded:', result.data);
    document.getElementById('scanAnimText').textContent = 'Found: ' + result.data.slice(0, 30);
    dg.last.textContent = result.data.slice(0, 40);
    dg.last.style.color = '#1D9E75';
  }
  return result;
}

// ── Step 1: look up customer, open quantity popup ─────────────────
let pendingToken = null;

async function lookupCustomer(token) {
  resultBox.style.display = 'none';
  try {
    const res  = await fetch('/admin/scan-lookup', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ qrCode: token }),
    });
    const data = await res.json();
    if (data.success) {
      pendingToken = data.token;
      document.getElementById('qmName').textContent   = data.user.name;
      document.getElementById('qmDrinks').textContent = data.user.totalDrinks;
      document.getElementById('qmTier').textContent   = data.user.tier;
      document.getElementById('qmQty').value = 1;
      document.getElementById('qtyModal').classList.add('open');
      setStatus('found', 'Customer found');
    } else {
      releaseCooldown();
      setStatus('error', 'Not found');
      resultBox.style.display = 'block';
      resultBox.className = 'admin-card scan-result-card scan-error-card';
      resultBox.innerHTML = `<div class="scan-result-icon scan-result-icon-err">✗</div>
        <h3>Not found</h3><p>${data.message}</p>`;
    }
  } catch (e) {
    releaseCooldown();
    setStatus('error', 'Connection error');
  }
}

function releaseCooldown() {
  cooldown = false;
  lastScanned = null;
  qrFrame.classList.remove('qr-frame-found');
  qrLaser.style.display = 'block';
  if (scanning) setStatus('scanning', 'Scanning');
}

function closeQtyModal() {
  document.getElementById('qtyModal').classList.remove('open');
  pendingToken = null;
  setTimeout(releaseCooldown, 1200); // brief pause so the same code isn't instantly re-scanned
}

function changeModalQty(delta) {
  const input = document.getElementById('qmQty');
  input.value = Math.min(20, Math.max(1, parseInt(input.value || 1) + delta));
}
function setModalQty(n) { document.getElementById('qmQty').value = n; }

// ── Step 2: confirm — record the chosen quantity ──────────────────
async function confirmAddDrinks() {
  if (!pendingToken) return;
  const qty = Math.min(20, Math.max(1, parseInt(document.getElementById('qmQty').value) || 1));
  const btn = document.getElementById('qmConfirmBtn');
  btn.disabled = true; btn.textContent = 'Adding…';
  try {
    const res  = await fetch('/admin/scan-api', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ qrCode: pendingToken, quantity: qty }),
    });
    const data = await res.json();
    btn.disabled = false; btn.textContent = 'Add Drinks ✓';
    closeQtyModal();
    resultBox.style.display = 'block';

    if (data.success) {
      setStatus('found', '✓ Recorded!');
      let html = `
        <div class="scan-result-icon">✓</div>
        <h3>${data.user.name}</h3>
        <p style="font-size:0.85rem;opacity:0.6;">${data.qty} drink${data.qty !== 1 ? 's' : ''} added</p>
        <div class="scan-result-stats">
          <div class="scan-result-stat">
            <span class="scan-result-num">${data.user.totalDrinks}</span>
            <span class="scan-result-lbl">drinks</span>
          </div>
          <div class="scan-result-stat">
            <span class="scan-result-num">${data.user.tier}</span>
            <span class="scan-result-lbl">tier</span>
          </div>
        </div>`;
      (data.newRewards || []).forEach(r => {
        const icon = r.type === 'free_drink' ? '☕' : r.type === 'voucher' ? '🎫' : '🎁';
        html += `<div class="scan-new-reward">
          <span class="scan-reward-icon">${icon}</span>
          <div><strong>${r.type === 'voucher' ? 'Voucher added!' : 'Reward unlocked!'}</strong>
          <p>${r.description}</p></div></div>`;
      });
      resultBox.className = 'admin-card scan-result-card scan-success-card';
      resultBox.innerHTML = html;
    } else {
      setStatus('error', 'Error');
      resultBox.className = 'admin-card scan-result-card scan-error-card';
      resultBox.innerHTML = `<div class="scan-result-icon scan-result-icon-err">✗</div>
        <h3>Couldn't record</h3><p>${data.message}</p>`;
    }
  } catch (e) {
    btn.disabled = false; btn.textContent = 'Add Drinks ✓';
    setStatus('error', 'Connection error');
  }
}

function changeQty(delta) {
  const input = document.getElementById('qtyInput');
  input.value = Math.min(20, Math.max(1, parseInt(input.value) + delta));
}

// ── Confirm-Claim panel: scan the customer QR into the token field ─
let confirmStream = null;
let confirmScanning = false;
const confirmVideo  = document.getElementById('confirmVideo');
const confirmWrap   = document.getElementById('confirmCamWrap');
const confirmBtn    = document.getElementById('confirmScanBtn');
const confirmStatus = document.getElementById('confirmCamStatus');

function toggleConfirmScan() {
  if (confirmScanning) { stopConfirmScan(); } else { startConfirmScan(); }
}

async function startConfirmScan() {
  if (!jsQRReady) { confirmStatus.textContent = 'QR library not loaded — type the token instead.'; confirmWrap.style.display = 'block'; return; }
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    confirmWrap.style.display = 'block';
    confirmStatus.textContent = 'Camera unavailable — type the token instead.';
    return;
  }
  confirmWrap.style.display = 'block';
  confirmStatus.textContent = 'Starting camera…';
  try {
    confirmStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } }
    });
    confirmVideo.srcObject = confirmStream;
    await confirmVideo.play();
    confirmScanning = true;
    confirmBtn.textContent = '✕ Stop';
    confirmStatus.textContent = 'Point at the customer QR…';
    requestAnimationFrame(confirmTick);
  } catch (e) {
    confirmStatus.textContent = 'Camera blocked — type the token instead.';
  }
}

function stopConfirmScan() {
  confirmScanning = false;
  if (confirmStream) { confirmStream.getTracks().forEach(t => t.stop()); confirmStream = null; }
  confirmVideo.srcObject = null;
  confirmWrap.style.display = 'none';
  confirmBtn.textContent = '📷 Scan';
}

function confirmTick() {
  if (!confirmScanning) return;
  if (confirmVideo.readyState === confirmVideo.HAVE_ENOUGH_DATA && confirmVideo.videoWidth > 0) {
    const w = confirmVideo.videoWidth, h = confirmVideo.videoHeight;
    offscreen.width = w; offscreen.height = h;
    offCtx.drawImage(confirmVideo, 0, 0, w, h);
    let code = null;
    try {
      code = tryDecode(offCtx, 0, 0, w, h);
      if (!code) {
        const c = Math.min(w, h) * 0.7;
        code = tryDecode(offCtx, (w - c) / 2, (h - c) / 2, c, c);
      }
    } catch (err) {
      confirmStatus.textContent = 'Decode error: ' + err.message;
      return;
    }
    if (code) {
      stopConfirmScan();
      onConfirmScanned(code.data);
      return;
    }
  }
  requestAnimationFrame(confirmTick);
}

// Parse the scanned reward QR and look it up. Expected payload:
//   conleche-claim:<token>:<rewardId>
let confirmToken = null, confirmRewardId = null;
async function onConfirmScanned(raw) {
  const reward = document.getElementById('confirmReward');
  const btn    = document.getElementById('confirmClaimBtn');
  confirmToken = null; confirmRewardId = null;
  btn.disabled = true;

  let token = '', rewardId = '';
  if (raw.startsWith('conleche-claim:')) {
    const parts = raw.slice('conleche-claim:'.length).split(':');
    token = (parts[0] || '').trim();
    rewardId = (parts[1] || '').trim();
  } else {
    // Not a reward QR — most likely the plain battlepass QR
    reward.style.display = 'block';
    reward.className = 'confirm-reward confirm-reward-bad';
    reward.innerHTML = '✗ That\'s not a reward QR. Ask the customer to tap <strong>Claim</strong> first, then scan the QR it shows.';
    return;
  }

  document.getElementById('confirmQr').value = token;
  document.getElementById('confirmRewardId').value = rewardId;
  confirmStatus.textContent = 'Verifying reward…';
  reward.style.display = 'block';
  reward.className = 'confirm-reward';
  reward.innerHTML = 'Checking reward on our system…';

  try {
    const res = await fetch('/battlepass/claim-info', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ qrCode: token, rewardId }),
    });
    const d = await res.json();
    if (!d.success) {
      reward.className = 'confirm-reward confirm-reward-bad';
      reward.innerHTML = '✗ ' + (d.message || 'Reward not valid');
      return;
    }
    const icon = d.reward.type === 'free_drink' ? '☕' : d.reward.type === 'voucher' ? '🎫' : d.reward.type === 'special' ? '✨' : '🎁';
    if (d.valid) {
      confirmToken = token; confirmRewardId = rewardId;
      reward.className = 'confirm-reward confirm-reward-ok';
      reward.innerHTML = `<div class="confirm-reward-head">${icon} <strong>${d.reward.description}</strong></div>
        <div class="confirm-reward-meta">${d.customerName} · <span class="confirm-valid">Valid on our system ✓</span></div>
        <div class="confirm-reward-hint">${d.reason}</div>`;
      btn.disabled = false;
      document.getElementById('confirmCode').focus();
    } else {
      reward.className = 'confirm-reward confirm-reward-bad';
      reward.innerHTML = `<div class="confirm-reward-head">${icon} ${d.reward.description}</div>
        <div class="confirm-reward-meta">${d.customerName}</div>
        <div class="confirm-reward-hint">✗ ${d.reason}</div>`;
    }
  } catch (e) {
    reward.className = 'confirm-reward confirm-reward-bad';
    reward.innerHTML = '✗ Connection error — try again.';
  }
}

async function submitConfirmClaim() {
  const code = (document.getElementById('confirmCode').value || '').trim();
  const result = document.getElementById('confirmResult');
  const btn = document.getElementById('confirmClaimBtn');
  if (!confirmToken || !confirmRewardId) { alert('Scan the reward QR first.'); return; }
  if (code.length !== 4) { alert('Enter the 4-digit code the customer is showing.'); return; }
  btn.disabled = true; btn.textContent = 'Confirming…';
  try {
    const res = await fetch('/battlepass/confirm-claim', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ qrCode: confirmToken, rewardId: confirmRewardId, code }),
    });
    const d = await res.json();
    result.style.display = 'block';
    if (d.success) {
      result.className = 'admin-card scan-result-card scan-success-card';
      result.innerHTML = `<div class="scan-result-icon">✓</div><h3>Redeemed!</h3><p>${d.reward ? d.reward.description : ''}</p>`;
      // Reset for the next customer
      confirmToken = null; confirmRewardId = null;
      document.getElementById('confirmQr').value = '';
      document.getElementById('confirmRewardId').value = '';
      document.getElementById('confirmCode').value = '';
      document.getElementById('confirmReward').style.display = 'none';
      btn.textContent = '✓ Confirm Claim';
    } else {
      result.className = 'admin-card scan-result-card scan-error-card';
      result.innerHTML = `<div class="scan-result-icon scan-result-icon-err">✗</div><h3>Failed</h3><p>${d.message || 'Could not confirm'}</p>`;
      btn.disabled = false; btn.textContent = '✓ Confirm Claim';
    }
  } catch (e) {
    result.style.display = 'block';
    result.className = 'admin-card scan-result-card scan-error-card';
    result.innerHTML = `<div class="scan-result-icon scan-result-icon-err">✗</div><h3>Error</h3><p>Connection error</p>`;
    btn.disabled = false; btn.textContent = '✓ Confirm Claim';
  }
}

// Auto-start
startCamera();
</script>


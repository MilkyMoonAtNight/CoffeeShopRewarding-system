<%- include('./layout-top') %>

<div class="admin-page-header">
  <h1 class="admin-page-title">Drinks Menu</h1>
  <p class="admin-page-sub">Add, edit, delete or toggle availability of drinks</p>
</div>

<% if (msg) { %><div class="admin-alert <%= msg.startsWith('Error') ? 'admin-alert-error' : 'admin-alert-success' %>"><%= msg %></div><% } %>

<div class="admin-two-col">

  <!-- Add drink -->
  <div class="admin-card">
    <h3 class="admin-card-title">Add New Drink</h3>
    <form action="/admin/drinks/add" method="POST" class="auth-form">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required placeholder="e.g. Oat Latte" />
      </div>
      <div class="form-group">
        <label>Category</label>
        <select name="category" class="scan-input">
          <option value="hot">☕ Hot</option>
          <option value="cold">🧊 Cold</option>
        </select>
      </div>
      <div class="form-group">
        <label>Subcategory</label>
        <select name="subcategory" class="scan-input">
          <option value="espresso">Espresso</option>
          <option value="specialty">Specialty</option>
          <option value="chocolate">Chocolate</option>
          <option value="tea">Tea / Matcha</option>
          <option value="freezo">Freezo</option>
          <option value="iced">Iced</option>
          <option value="frozen">Frozen</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
        <div class="form-group">
          <label>Regular Price (R)</label>
          <input type="number" name="priceRegular" placeholder="e.g. 35" min="0" />
        </div>
        <div class="form-group">
          <label>Large Price (R)</label>
          <input type="number" name="priceLarge" placeholder="e.g. 45" min="0" />
        </div>
        <div class="form-group">
          <label>Regular Size</label>
          <input type="text" name="sizeRegular" placeholder="e.g. 250ml" />
        </div>
        <div class="form-group">
          <label>Large Size</label>
          <input type="text" name="sizeLarge" placeholder="e.g. 350ml" />
        </div>
      </div>
      <div class="form-group">
        <label>Flavours (comma separated)</label>
        <input type="text" name="flavours" placeholder="Vanilla, Caramel, Hazelnut…" />
      </div>
      <div class="form-group">
        <label>Image filename</label>
        <input type="text" name="image" placeholder="e.g. flat-white.jpg" />
        <span class="form-hint">Place image in <code>public/images/drinks/</code> then enter filename</span>
      </div>
      <div class="form-group" style="grid-column:span 2;">
        <label>Display Order</label>
        <input type="number" name="order" placeholder="1" min="1" value="99" />
      </div>
      <div class="form-group" style="flex-direction:row;align-items:center;gap:0.5rem;">
        <input type="checkbox" name="isSpecial" id="isSpecial" style="width:auto;" />
        <label for="isSpecial" style="margin:0;">Mark as Special (e.g. Latte of the Month)</label>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Add Drink</button>
    </form>
  </div>

  <!-- Drink list -->
  <div>
    <% ['hot','cold'].forEach(cat => { %>
    <h3 class="drinks-cat-heading <%= cat === 'cold' ? 'drinks-cat-cold' : '' %>">
      <%= cat === 'hot' ? '☕ Hot Drinks' : '🧊 Cold Drinks' %>
    </h3>
    <% drinks.filter(d => d.category === cat).forEach(drink => { %>
    <div class="admin-card admin-drink-row <%= !drink.available ? 'drink-unavailable' : '' %>">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;">
        <div style="flex:1;">
          <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
            <strong style="font-size:0.95rem;"><%= drink.name %></strong>
            <% if (!drink.available) { %><span style="font-size:0.7rem;background:rgba(200,50,50,0.1);color:#c83232;padding:0.1rem 0.5rem;border-radius:50px;">Unavailable</span><% } %>
            <% if (drink.isSpecial) { %><span style="font-size:0.7rem;background:rgba(88,18,23,0.1);color:var(--maroon);padding:0.1rem 0.5rem;border-radius:50px;">Special</span><% } %>
          </div>
          <p style="font-size:0.78rem;color:rgba(44,44,44,0.5);margin-top:0.2rem;">
            <% if (drink.prices.regular) { %>R<%= drink.prices.regular %> reg<% } %>
            <% if (drink.prices.regular && drink.prices.large) { %> · <% } %>
            <% if (drink.prices.large) { %>R<%= drink.prices.large %> lge<% } %>
            <% if (drink.flavours && drink.flavours.length) { %> · <%= drink.flavours.length %> flavours<% } %>
          </p>
        </div>
        <div style="display:flex;gap:0.4rem;flex-shrink:0;">
          <form action="/admin/drinks/toggle/<%= drink._id %>" method="POST">
            <button type="submit" class="admin-toggle-btn"><%= drink.available ? 'Hide' : 'Show' %></button>
          </form>
          <button onclick="toggleDrinkEdit('<%= drink._id %>')" class="admin-toggle-btn">Edit</button>
          <form action="/admin/drinks/delete/<%= drink._id %>" method="POST" onsubmit="return confirm('Delete <%= drink.name %>?')">
            <button type="submit" class="admin-toggle-btn" style="color:#c83232;border-color:#c83232;">Del</button>
          </form>
        </div>
      </div>
      <!-- Inline edit -->
      <div id="dedit-<%= drink._id %>" style="display:none;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(44,44,44,0.08);">
        <form action="/admin/drinks/edit/<%= drink._id %>" method="POST">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
            <div class="form-group" style="grid-column:span 2;">
              <label>Name</label>
              <input type="text" name="name" value="<%= drink.name %>" required class="scan-input" />
            </div>
            <div class="form-group">
              <label>Regular Price (R)</label>
              <input type="number" name="priceRegular" value="<%= drink.prices.regular || '' %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Large Price (R)</label>
              <input type="number" name="priceLarge" value="<%= drink.prices.large || '' %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Regular Size</label>
              <input type="text" name="sizeRegular" value="<%= drink.sizeLabels?.regular || '' %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Large Size</label>
              <input type="text" name="sizeLarge" value="<%= drink.sizeLabels?.large || '' %>" class="scan-input" />
            </div>
            <div class="form-group" style="grid-column:span 2;">
              <label>Flavours (comma separated)</label>
              <input type="text" name="flavours" value="<%= (drink.flavours || []).join(', ') %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Order</label>
              <input type="number" name="order" value="<%= drink.order %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Available</label>
              <select name="available" class="scan-input">
                <option value="true" <%= drink.available ? 'selected' : '' %>>Yes</option>
                <option value="false" <%= !drink.available ? 'selected' : '' %>>No</option>
              </select>
            </div>
            <input type="hidden" name="category" value="<%= drink.category %>" />
            <input type="hidden" name="subcategory" value="<%= drink.subcategory %>" />
            <input type="hidden" name="isSpecial" value="<%= drink.isSpecial %>" />
          </div>
          <button type="submit" class="btn btn-primary" style="margin-top:0.5rem;">Save Changes</button>
        </form>
      </div>
    </div>
    <% }) %>
    <% }) %>
  </div>
</div>

<script>
function toggleDrinkEdit(id) {
  const el = document.getElementById('dedit-' + id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>

<%- include('./layout-bottom') %>

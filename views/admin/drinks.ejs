<%- include('./layout-top') %>

<div class="admin-page-header">
  <h1 class="admin-page-title">Drinks Menu</h1>
  <p class="admin-page-sub">Add, edit, delete or toggle availability of drinks</p>
</div>

<% if (msg) { %><div class="admin-alert <%= msg.startsWith('Error') ? 'admin-alert-error' : 'admin-alert-success' %>"><%= msg %></div><% } %>

<div class="admin-two-col">

  <!-- Add drink -->
  <div class="admin-card">
    <h3 class="admin-card-title">Add New Drink</h3>
    <form action="/admin/drinks/add" method="POST" enctype="multipart/form-data" class="auth-form">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required placeholder="e.g. Oat Latte" />
      </div>
      <div class="form-group">
        <label>Category</label>
        <select name="category" class="scan-input">
          <option value="hot">☕ Hot</option>
          <option value="cold">🧊 Cold</option>
        </select>
      </div>
      <div class="form-group">
        <label>Subcategory</label>
        <select name="subcategory" class="scan-input">
          <option value="espresso">Espresso</option>
          <option value="specialty">Specialty</option>
          <option value="chocolate">Chocolate</option>
          <option value="tea">Tea / Matcha</option>
          <option value="freezo">Freezo</option>
          <option value="iced">Iced</option>
          <option value="frozen">Frozen</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
        <div class="form-group">
          <label>Regular Price (R)</label>
          <input type="number" name="priceRegular" placeholder="e.g. 35" min="0" />
        </div>
        <div class="form-group">
          <label>Large Price (R)</label>
          <input type="number" name="priceLarge" placeholder="e.g. 45" min="0" />
        </div>
        <div class="form-group">
          <label>Regular Size</label>
          <input type="text" name="sizeRegular" placeholder="e.g. 250ml" />
        </div>
        <div class="form-group">
          <label>Large Size</label>
          <input type="text" name="sizeLarge" placeholder="e.g. 350ml" />
        </div>
      </div>
      <div class="form-group">
        <label>Flavours (comma separated)</label>
        <input type="text" name="flavours" placeholder="Vanilla, Caramel, Hazelnut…" />
      </div>

      <!-- Image upload -->
      <div class="form-group">
        <label>Photo</label>
        <div class="upload-zone" id="drinkUploadZone" onclick="document.getElementById('drinkImageFile').click()">
          <div class="upload-zone-inner" id="drinkUploadInner">
            <span class="upload-icon">📷</span>
            <span class="upload-label">Tap to upload photo</span>
            <span class="upload-hint">JPG, PNG, WebP or SVG · max 10MB</span>
          </div>
        </div>
        <input type="file" id="drinkImageFile" name="imageFile" accept="image/*,.svg" style="display:none;" onchange="previewUpload(this,'drinkUploadInner','drinkUploadZone')" />
        <span class="form-hint">Or enter a filename if already uploaded:</span>
        <input type="text" name="image" placeholder="e.g. flat-white.jpg" style="margin-top:0.35rem;" />
      </div>

      <div class="form-group" style="flex-direction:row;align-items:center;gap:0.5rem;">
        <input type="hidden" name="order" value="99" />
        <input type="checkbox" name="isSpecial" id="isSpecial" style="width:auto;" />
        <label for="isSpecial" style="margin:0;font-size:0.85rem;">Mark as Special</label>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Add Drink</button>
    </form>
  </div>

  <!-- Drink list -->
  <div>
    <div class="admin-card admin-filter-bar">
      <input type="text" id="drinkSearch" class="scan-input" placeholder="🔍 Search drinks…" oninput="filterAdminList()" />
      <select id="drinkCatFilter" class="scan-input" onchange="filterAdminList()">
        <option value="">All categories</option>
        <option value="hot">☕ Hot</option>
        <option value="cold">🧊 Cold</option>
        <option value="espresso">Espresso</option>
        <option value="specialty">Specialty</option>
        <option value="chocolate">Chocolate</option>
        <option value="tea">Tea</option>
        <option value="iced">Iced</option>
        <option value="freezo">Freezo</option>
        <option value="frozen">Frozen</option>
      </select>
    </div>
    <% ['hot','cold'].forEach(cat => { %>
    <h3 class="drinks-cat-heading <%= cat==='cold'?'drinks-cat-cold':'' %>">
      <%= cat==='hot' ? '☕ Hot Drinks' : '🧊 Cold Drinks' %>
    </h3>
    <% drinks.filter(d => d.category === cat).forEach(drink => { %>
    <div class="admin-card admin-drink-row filterable-row <%= !drink.available ? 'drink-unavailable' : '' %>" style="margin-bottom:0.75rem;" data-name="<%= (drink.name || '').toLowerCase() %>" data-cat="<%= drink.category %> <%= drink.subcategory || '' %>">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;flex:1;min-width:0;">
          <% if (drink.image) { %>
          <img src="<%= drink.image.startsWith('/') ? drink.image : '/images/drinks/' + drink.image %>" alt="<%= drink.name %>"
               style="width:44px;height:44px;object-fit:cover;border-radius:8px;flex-shrink:0;" />
          <% } else { %>
          <div style="width:44px;height:44px;border-radius:8px;background:var(--cream-dark);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">☕</div>
          <% } %>
          <div>
            <div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;">
              <strong style="font-size:0.92rem;"><%= drink.name %></strong>
              <% if (!drink.available) { %><span class="admin-item-tag tag-off">Off</span><% } %>
              <% if (drink.isSpecial) { %><span class="admin-item-tag tag-special">Special</span><% } %>
            </div>
            <p style="font-size:0.75rem;color:rgba(44,44,44,0.45);margin-top:0.1rem;">
              <% if (drink.prices.regular) { %>R<%= drink.prices.regular %> reg<% } %>
              <% if (drink.prices.regular && drink.prices.large) { %> · <% } %>
              <% if (drink.prices.large) { %>R<%= drink.prices.large %> lge<% } %>
            </p>
          </div>
        </div>
        <div style="display:flex;gap:0.4rem;flex-shrink:0;">
          <form action="/admin/drinks/toggle/<%= drink._id %>" method="POST" style="display:inline;">
            <button type="submit" class="admin-toggle-btn"><%= drink.available ? 'Hide' : 'Show' %></button>
          </form>
          <button onclick="toggleEdit('dedit-<%= drink._id %>')" class="admin-toggle-btn">Edit</button>
          <form action="/admin/drinks/delete/<%= drink._id %>" method="POST" onsubmit="return confirm('Delete <%= drink.name %>?')" style="display:inline;">
            <button type="submit" class="admin-toggle-btn" style="color:#c83232;border-color:#c83232;">Del</button>
          </form>
        </div>
      </div>

      <!-- Inline edit panel -->
      <div id="dedit-<%= drink._id %>" style="display:none;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(44,44,44,0.08);">
        <form action="/admin/drinks/edit/<%= drink._id %>" method="POST" enctype="multipart/form-data">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
            <div class="form-group" style="grid-column:span 2;">
              <label>Name</label>
              <input type="text" name="name" value="<%= drink.name %>" required class="scan-input" />
            </div>
            <div class="form-group">
              <label>Regular Price (R)</label>
              <input type="number" name="priceRegular" value="<%= drink.prices.regular || '' %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Large Price (R)</label>
              <input type="number" name="priceLarge" value="<%= drink.prices.large || '' %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Regular Size</label>
              <input type="text" name="sizeRegular" value="<%= drink.sizeLabels?.regular || '' %>" class="scan-input" />
            </div>
            <div class="form-group">
              <label>Large Size</label>
              <input type="text" name="sizeLarge" value="<%= drink.sizeLabels?.large || '' %>" class="scan-input" />
            </div>
            <div class="form-group" style="grid-column:span 2;">
              <label>Flavours (comma separated)</label>
              <input type="text" name="flavours" value="<%= (drink.flavours||[]).join(', ') %>" class="scan-input" />
            </div>
            <div class="form-group" style="grid-column:span 2;">
              <label>Replace photo</label>
              <div class="upload-zone upload-zone-sm" id="ez-<%= drink._id %>" onclick="document.getElementById('ef-<%= drink._id %>').click()">
                <div class="upload-zone-inner" id="ei-<%= drink._id %>">
                  <span class="upload-icon" style="font-size:1.2rem;">📷</span>
                  <span class="upload-label" style="font-size:0.78rem;">Tap to choose new photo</span>
                </div>
              </div>
              <input type="file" id="ef-<%= drink._id %>" name="imageFile" accept="image/*,.svg" style="display:none;"
                     onchange="previewUpload(this,'ei-<%= drink._id %>','ez-<%= drink._id %>')" />
            </div>
            <div class="form-group">
              <input type="hidden" name="order" value="<%= drink.order %>" />
              <label>Available</label>
              <select name="available" class="scan-input">
                <option value="true" <%= drink.available?'selected':'' %>>Yes</option>
                <option value="false" <%= !drink.available?'selected':'' %>>No</option>
              </select>
            </div>
            <input type="hidden" name="category" value="<%= drink.category %>" />
            <input type="hidden" name="subcategory" value="<%= drink.subcategory %>" />
            <input type="hidden" name="isSpecial" value="<%= drink.isSpecial %>" />
          </div>
          <button type="submit" class="btn btn-primary" style="margin-top:0.5rem;width:100%;">Save Changes</button>
        </form>
      </div>
    </div>
    <% }) %>
    <% }) %>
  </div>
</div>

<script>

function filterAdminList() {
  const q   = (document.getElementById('drinkSearch')?.value || document.getElementById('pastrySearch')?.value || document.getElementById('eventSearch')?.value || '').toLowerCase().trim();
  const cat = (document.getElementById('drinkCatFilter')?.value || document.getElementById('pastryCatFilter')?.value || document.getElementById('eventTypeFilter')?.value || '');
  document.querySelectorAll('.filterable-row').forEach(row => {
    const matchQ   = !q   || (row.dataset.name || '').includes(q);
    const matchCat = !cat || (row.dataset.cat || '').split(' ').includes(cat);
    row.style.display = (matchQ && matchCat) ? '' : 'none';
  });
  // Hide category headings whose rows are all hidden
  document.querySelectorAll('.drinks-cat-heading, .admin-cat-heading').forEach(h => {
    let el = h.nextElementSibling, any = false;
    while (el && !el.classList.contains('drinks-cat-heading') && !el.classList.contains('admin-cat-heading')) {
      if (el.classList.contains('filterable-row') && el.style.display !== 'none') { any = true; break; }
      el = el.nextElementSibling;
    }
    h.style.display = any ? '' : 'none';
  });
}

function toggleEdit(id) {
  const el = document.getElementById(id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
function previewUpload(input, innerId, zoneId) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  const reader = new FileReader();
  reader.onload = e => {
    const inner = document.getElementById(innerId);
    const zone  = document.getElementById(zoneId);
    inner.innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />`;
    zone.style.border = '2px solid var(--maroon)';
  };
  reader.readAsDataURL(file);
}
</script>

<%- include('./layout-bottom') %>

<%- include('./layout-top') %>

<div class="admin-page-header">
  <h1 class="admin-page-title">Events</h1>
  <p class="admin-page-sub">Manage truck locations, run club, painting classes and more</p>
</div>

<% if (msg) { %><div class="admin-alert <%= msg.startsWith('Error') ? 'admin-alert-error' : 'admin-alert-success' %>"><%= msg %></div><% } %>

<div class="admin-two-col">

  <!-- Add event -->
  <div class="admin-card">
    <h3 class="admin-card-title">Add New Event</h3>
    <form action="/admin/events/add" method="POST" enctype="multipart/form-data" class="auth-form">
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" required placeholder="e.g. Saturday Run Club" />
      </div>
      <div class="form-group">
        <label>Type</label>
        <select name="type" class="scan-input" onchange="toggleCustomType(this, 'customTypeAdd')">
          <option value="truck_location">🚐 Truck Location</option>
          <option value="run_club">🏃 Run Club</option>
          <option value="painting">🎨 Painting Class</option>
          <option value="pop_up">⭐ Pop-Up</option>
          <option value="special">🎉 Special Event</option>
          <option value="__custom">✏️ Custom type…</option>
        </select>
        <input type="text" name="customType" id="customTypeAdd" class="scan-input"
               placeholder="e.g. Open Mic Night" style="display:none;margin-top:0.5rem;" maxlength="30" />
      </div>
      <div class="form-group">
        <label>Date & Time</label>
        <input type="datetime-local" name="date" required />
      </div>
      <div class="form-group">
        <label>Location Name</label>
        <input type="text" name="location" placeholder="e.g. Zoo Lake, Johannesburg" />
      </div>
      <div class="form-group">
        <label>Address</label>
        <input type="text" name="address" placeholder="Street address" />
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="3" placeholder="What's happening…" style="width:100%;padding:0.75rem;border:1.5px solid rgba(44,44,44,0.15);border-radius:var(--radius);font-family:var(--font-body);resize:vertical;"></textarea>
      </div>

      <!-- Recurring -->
      <div class="form-group">
        <label>Recurring</label>
        <select name="recurringType" class="scan-input">
          <option value="none">Not recurring</option>
          <option value="daily">Daily</option>
          <option value="weekly">Weekly</option>
        </select>
      </div>

      <!-- Contact section -->
      <div style="border-top:1px solid rgba(44,44,44,0.1);margin:1rem 0;padding-top:1rem;">
        <p style="font-size:0.8rem;font-weight:600;color:var(--maroon);margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.06em;">Event Organiser Contact</p>
        <div class="form-group">
          <label>Organiser Name</label>
          <input type="text" name="contactName" placeholder="e.g. Sarah" />
        </div>
        <div class="form-group">
          <label>WhatsApp Number <span style="opacity:0.4;font-weight:400;">(digits only, incl. country code)</span></label>
          <input type="tel" name="contactPhone" placeholder="e.g. 27821234567" />
        </div>
        <div class="form-group">
          <label>Socials <span style="opacity:0.4;font-weight:400;">(optional — URL or @handle)</span></label>
          <input type="text" name="socials" placeholder="e.g. https://instagram.com/sarah or @sarah" />
        </div>
      </div>

      <div class="form-group">
        <label>Event Photo <span style="opacity:0.4;font-weight:400;">(optional)</span></label>
        <div class="upload-zone" id="eventUploadZone" onclick="document.getElementById('eventImageFile').click()">
          <div class="upload-zone-inner" id="eventUploadInner">
            <span class="upload-icon">📷</span>
            <span class="upload-label">Tap to upload photo</span>
            <span class="upload-hint">JPG, PNG or WebP · max 5MB</span>
          </div>
        </div>
        <input type="file" id="eventImageFile" name="imageFile" accept="image/*" style="display:none;"
               onchange="previewUpload(this,'eventUploadInner','eventUploadZone')" />
      </div>
      <button type="submit" class="btn btn-primary btn-full">Add Event</button>
    </form>
  </div>

  <!-- Event list -->
  <div>
    <div class="admin-card admin-filter-bar">
      <input type="text" id="eventSearch" class="scan-input" placeholder="🔍 Search events…" oninput="filterAdminList()" />
      <select id="eventTypeFilter" class="scan-input" onchange="filterAdminList()">
        <option value="">All types</option>
        <% [...new Set(events.map(e => e.type))].forEach(t => { %>
        <option value="<%= t %>"><%= t.replace(/_/g, ' ') %></option>
        <% }) %>
      </select>
    </div>
    <% if (events.length === 0) { %>
      <div class="admin-card"><p class="admin-empty">No events yet.</p></div>
    <% } else { %>
      <% const builtin = ['truck_location','run_club','painting','pop_up','special']; %>
      <% events.forEach(event => { %>
      <div class="admin-card filterable-row" style="margin-bottom:1rem;"
           data-name="<%= (event.title || '').toLowerCase() %> <%= (event.location || '').toLowerCase() %>"
           data-cat="<%= event.type %>">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;">
          <div style="display:flex;gap:0.85rem;align-items:flex-start;flex:1;min-width:0;">
            <% const evImg = event.image ? (event.image.startsWith('/') ? event.image : '/images/events/' + event.image) : null; %>
            <% if (evImg) { %>
            <img src="<%= evImg %>" alt="<%= event.title %>" style="width:60px;height:60px;object-fit:cover;border-radius:10px;flex-shrink:0;" />
            <% } else { %>
            <div style="width:60px;height:60px;border-radius:10px;background:var(--cream-dark);display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">
              <%= event.type === 'truck_location' ? '🚐' : event.type === 'run_club' ? '🏃' : event.type === 'painting' ? '🎨' : '⭐' %>
            </div>
            <% } %>
            <div>
            <span class="admin-badge" style="margin-bottom:0.5rem;display:inline-block;">
              <%= event.type === 'truck_location' ? '🚐' : event.type === 'run_club' ? '🏃' : event.type === 'painting' ? '🎨' : '⭐' %>
              <%= event.type.replace('_',' ') %>
            </span>
            <% if (event.recurringType && event.recurringType !== 'none') { %>
              <span class="admin-badge" style="margin-left:0.25rem;background:rgba(91,158,110,0.12);color:#3a7a50;"><%= event.recurringType === 'daily' ? '🔁 Daily' : '📅 Weekly' %></span>
            <% } %>
            <h4 style="font-family:var(--font-nimbus);font-size:1rem;"><%= event.title %></h4>
            <p style="font-size:0.8rem;color:rgba(44,44,44,0.5);margin-top:0.25rem;">
              <%= event.date.toLocaleDateString('en-ZA', { weekday:'short', day:'numeric', month:'short', year:'numeric' }) %>
              <% if (event.location) { %> · <%= event.location %><% } %>
            </p>
            <% if (event.contactPhone) { %><p style="font-size:0.78rem;color:rgba(44,44,44,0.5);margin-top:0.2rem;">📞 <%= event.contactName || '' %> · +<%= event.contactPhone %></p><% } %>
            <% if (event.description) { %><p style="font-size:0.82rem;color:rgba(44,44,44,0.6);margin-top:0.35rem;"><%= event.description %></p><% } %>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:0.4rem;flex-shrink:0;">
            <button onclick="toggleEdit('<%= event._id %>')" class="admin-toggle-btn">Edit</button>
            <form action="/admin/events/delete/<%= event._id %>" method="POST" onsubmit="return confirm('Delete this event?')">
              <button type="submit" class="admin-toggle-btn" style="color:#c83232;border-color:#c83232;width:100%;">Delete</button>
            </form>
          </div>
        </div>
        <!-- Inline edit form -->
        <div id="edit-<%= event._id %>" style="display:none;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(44,44,44,0.08);">
          <form action="/admin/events/edit/<%= event._id %>" method="POST" enctype="multipart/form-data" class="auth-form">
            <div class="form-group">
              <label>Title</label>
              <input type="text" name="title" value="<%= event.title %>" required />
            </div>
            <div class="form-group">
              <label>Type</label>
              <select name="type" class="scan-input" onchange="toggleCustomType(this, 'customType-<%= event._id %>')">
                <option value="truck_location" <%= event.type==='truck_location'?'selected':'' %>>🚐 Truck Location</option>
                <option value="run_club" <%= event.type==='run_club'?'selected':'' %>>🏃 Run Club</option>
                <option value="painting" <%= event.type==='painting'?'selected':'' %>>🎨 Painting Class</option>
                <option value="pop_up" <%= event.type==='pop_up'?'selected':'' %>>⭐ Pop-Up</option>
                <option value="special" <%= event.type==='special'?'selected':'' %>>🎉 Special Event</option>
                <option value="__custom" <%= !builtin.includes(event.type) ? 'selected' : '' %>>✏️ Custom type…</option>
              </select>
              <input type="text" name="customType" id="customType-<%= event._id %>" class="scan-input"
                     placeholder="e.g. Open Mic Night" maxlength="30"
                     value="<%= !builtin.includes(event.type) ? event.type.replace(/_/g, ' ') : '' %>"
                     style="display:<%= !builtin.includes(event.type) ? 'block' : 'none' %>;margin-top:0.5rem;" />
            </div>
            <div class="form-group">
              <label>Date & Time</label>
              <input type="datetime-local" name="date" value="<%= event.date.toISOString().slice(0,16) %>" required />
            </div>
            <div class="form-group">
              <label>Location</label>
              <input type="text" name="location" value="<%= event.location || '' %>" />
            </div>
            <div class="form-group">
              <label>Address</label>
              <input type="text" name="address" value="<%= event.address || '' %>" />
            </div>
            <div class="form-group">
              <label>Description</label>
              <textarea name="description" rows="2" style="width:100%;padding:0.75rem;border:1.5px solid rgba(44,44,44,0.15);border-radius:var(--radius);font-family:var(--font-body);"><%= event.description || '' %></textarea>
            </div>
            <div class="form-group">
              <label>Recurring</label>
              <select name="recurringType" class="scan-input">
                <option value="none" <%= (!event.recurringType || event.recurringType==='none')?'selected':'' %>>Not recurring</option>
                <option value="daily" <%= event.recurringType==='daily'?'selected':'' %>>Daily</option>
                <option value="weekly" <%= event.recurringType==='weekly'?'selected':'' %>>Weekly</option>
              </select>
            </div>
            <div style="border-top:1px solid rgba(44,44,44,0.1);margin:0.75rem 0;padding-top:0.75rem;">
              <p style="font-size:0.78rem;font-weight:600;color:var(--maroon);margin-bottom:0.6rem;text-transform:uppercase;letter-spacing:0.06em;">Organiser Contact</p>
              <div class="form-group">
                <label>Organiser Name</label>
                <input type="text" name="contactName" value="<%= event.contactName || '' %>" />
              </div>
              <div class="form-group">
                <label>WhatsApp Number</label>
                <input type="tel" name="contactPhone" value="<%= event.contactPhone || '' %>" placeholder="27821234567" />
              </div>
              <div class="form-group">
                <label>Socials <span style="opacity:0.4;font-weight:400;">(optional)</span></label>
                <input type="text" name="socials" value="<%= event.socials || '' %>" placeholder="URL or @handle" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </form>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>
</div>

<script>
function toggleEdit(id) {
  const el = document.getElementById('edit-' + id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
function previewUpload(input, innerId, zoneId) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById(innerId).innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />`;
    document.getElementById(zoneId).style.border = '2px solid var(--maroon)';
  };
  reader.readAsDataURL(input.files[0]);
}
function toggleCustomType(sel, inputId) {
  const input = document.getElementById(inputId);
  if (input) input.style.display = sel.value === '__custom' ? 'block' : 'none';
}
function filterAdminList() {
  const q   = (document.getElementById('eventSearch')?.value || '').toLowerCase().trim();
  const cat = document.getElementById('eventTypeFilter')?.value || '';
  document.querySelectorAll('.filterable-row').forEach(row => {
    const matchQ   = !q   || (row.dataset.name || '').includes(q);
    const matchCat = !cat || (row.dataset.cat || '') === cat;
    row.style.display = (matchQ && matchCat) ? '' : 'none';
  });
}
</script>

<%- include('./layout-bottom') %>
